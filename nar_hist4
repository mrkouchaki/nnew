# ==========================================================
# Logging / generic helpers
# ==========================================================


def elapsed_text() -> str:
    seconds = int(time.time() - RUN_START_TIME)
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def log(message: str, indent: int = 0) -> None:
    prefix = "  " * max(0, int(indent))
    print(f"[{time.strftime('%H:%M:%S')} | +{elapsed_text()}] {prefix}{message}", flush=True)


def header(title: str) -> None:
    print("\n" + "=" * 100, flush=True)
    log(title)
    print("=" * 100, flush=True)


def clean_col_name(c: object) -> str:
    return str(c).strip().strip('"').upper()


def normalize_key_value(x: object) -> str:
    if pd.isna(x):
        return ""
    s = str(x).strip().strip('"')
    if s.upper() in NULL_STRINGS:
        return ""
    s = re.sub(r"\.0$", "", s)
    s = re.sub(r"\s+", "", s)
    return s.upper()


def normalize_value_text(x: object) -> str:
    """Normalize for exact/default comparisons but keep punctuation/sign/decimal."""
    if pd.isna(x):
        return ""
    s = str(x).strip().strip('"')
    if s.upper() in NULL_STRINGS:
        return ""
    # Collapse numeric strings such as 25.0000 -> 25, 120.0 -> 120 when safe.
    try:
        f = float(s)
        if math.isfinite(f):
            if abs(f - round(f)) < 1e-12:
                return str(int(round(f)))
            return (f"{f:.10f}".rstrip("0").rstrip(".")).upper()
    except Exception:
        pass
    s = re.sub(r"\s+", "", s)
    return s.upper()


def excel_safe_ecgi(ecgi: object) -> str:
    s = normalize_key_value(ecgi)
    return f"ECGI_{s}" if s else ""


def short_value(v: object, max_len: int = 80) -> str:
    if pd.isna(v):
        return "<missing>"
    s = str(v)
    return s if len(s) <= max_len else s[: max_len - 3] + "..."


def transition_text(prev_value: object, current_value: object) -> str:
    return f"{short_value(prev_value)} -> {short_value(current_value)}"


def date_text(d: object) -> str:
    dt = pd.to_datetime(d, errors="coerce")
    if pd.isna(dt):
        return ""
    return str(dt.date())


def safe_numeric(series: Any, default: float = 0.0) -> pd.Series:
    if not isinstance(series, pd.Series):
        series = pd.Series(series)
    return pd.to_numeric(series, errors="coerce").replace([np.inf, -np.inf], np.nan).fillna(default)


def percentile_rank(series: pd.Series) -> pd.Series:
    s = safe_numeric(series)
    if len(s) == 0:
        return s
    if s.nunique(dropna=False) <= 1:
        return pd.Series(np.ones(len(s)) * 50.0, index=s.index)
    return s.rank(method="average", pct=True) * 100.0


def first_existing(cols: Iterable[str], candidates: Iterable[str]) -> Optional[str]:
    cset = set(cols)
    for c in candidates:
        if c in cset:
            return c
    return None


def is_id_like_col(col: str) -> bool:
    c = clean_col_name(col)
    return c in ID_LIKE_EXACT or c.endswith("_ID") or c.endswith("ID") or "CELLID" in c


def is_numeric_config_col(col: str) -> bool:
    c = clean_col_name(col)
    if is_id_like_col(c):
        return False
    return any(term in c for term in NUMERIC_CONFIG_TERMS)


def quote_ident(name: str) -> str:
    return '"' + str(name).replace('"', '""') + '"'


def sql_string(value: str) -> str:
    return "'" + str(value).replace("'", "''") + "'"


def sql_path(path: Path) -> str:
    return sql_string(str(path).replace("\\", "/"))


def chunks_list(items: List[str], size: int) -> List[List[str]]:
    size = max(1, int(size))
    return [items[i : i + size] for i in range(0, len(items), size)]


# ==========================================================
# DuckDB SQL expressions
# ==========================================================


def import_duckdb():
    try:
        import duckdb  # type: ignore

        return duckdb
    except Exception as exc:
        raise RuntimeError(
            "DuckDB is required for V4 large CSV processing.\n"
            "Install once with:\n"
            "  python -m pip install duckdb\n"
            f"Original import error: {exc}"
        ) from exc


def open_duckdb(
    temp_db_path: Optional[Path],
    threads: int,
    memory_limit: Optional[str],
    duckdb_temp_dir: Optional[Path] = None,
):
    log("Opening DuckDB connection")
    duckdb = import_duckdb()
    if temp_db_path:
        temp_db_path.parent.mkdir(parents=True, exist_ok=True)
        log(f"DuckDB database file: {temp_db_path}", indent=1)
        con = duckdb.connect(str(temp_db_path))
    else:
        log("DuckDB database: in-memory", indent=1)
        con = duckdb.connect()

    try:
        con.execute("SET preserve_insertion_order=false")
    except Exception:
        pass

    if duckdb_temp_dir:
        duckdb_temp_dir.mkdir(parents=True, exist_ok=True)
        log(f"DuckDB spill/temp directory: {duckdb_temp_dir}", indent=1)
        try:
            con.execute(f"SET temp_directory={sql_string(str(duckdb_temp_dir))}")
        except Exception as exc:
            log(f"Warning: could not set DuckDB temp_directory: {exc}", indent=1)

    if threads and threads > 0:
        con.execute(f"PRAGMA threads={int(threads)}")
    if memory_limit:
        con.execute(f"PRAGMA memory_limit={sql_string(memory_limit)}")

    log(f"DuckDB settings: threads={threads}, memory_limit={memory_limit or 'default'}", indent=1)
    return con


def base_norm_expr(sql_expr: str) -> str:
    cleaned = f"UPPER(REGEXP_REPLACE(TRIM(CAST({sql_expr} AS VARCHAR)), '\\\\.0$', ''))"
    null_list = ", ".join(sql_string(x) for x in sorted(NULL_STRINGS))
    return f"CASE WHEN {sql_expr} IS NULL THEN NULL WHEN {cleaned} IN ({null_list}) THEN NULL ELSE {cleaned} END"


def compact_norm_expr(sql_expr: str) -> str:
    """Uppercase, trim, remove spaces/trailing .0, convert null-like to NULL."""
    base = base_norm_expr(sql_expr)
    return f"CASE WHEN {base} IS NULL THEN NULL ELSE REGEXP_REPLACE({base}, '\\s+', '') END"


def feature_norm_expr(original_col: str, feature: str, latlon_decimals: int) -> str:
    q = quote_ident(original_col)
    base = compact_norm_expr(q)
    if is_numeric_config_col(feature):
        decimals = latlon_decimals if any(t in feature for t in ["LAT", "LON", "LONG"]) else 4
        # Cast rounded numeric back to VARCHAR. Python post-processing normalizes trailing .0 for default checks.
        return (
            f"CASE WHEN {base} IS NULL THEN NULL "
            f"WHEN TRY_CAST({base} AS DOUBLE) IS NOT NULL "
            f"THEN CAST(ROUND(TRY_CAST({base} AS DOUBLE), {int(decimals)}) AS VARCHAR) "
            f"ELSE {base} END"
        )
    return base


def date_parse_expr(original_col: str) -> str:
    q = quote_ident(original_col)
    trimmed = f"TRIM(CAST({q} AS VARCHAR))"
    return (
        "CAST(COALESCE("
        f"TRY_STRPTIME({trimmed}, '%Y-%m-%d %H:%M:%S'),"
        f"TRY_STRPTIME({trimmed}, '%Y-%m-%d'),"
        f"TRY_STRPTIME({trimmed}, '%m/%d/%Y %H:%M:%S'),"
        f"TRY_STRPTIME({trimmed}, '%m/%d/%Y'),"
        f"TRY_STRPTIME({trimmed}, '%d-%b-%y'),"
        f"TRY_STRPTIME({trimmed}, '%d-%b-%Y')"
        ") AS DATE)"
    )


def ecgi_expr_from_columns(colmap: Dict[str, str]) -> str:
    if "ECGI" in colmap:
        return compact_norm_expr(quote_ident(colmap["ECGI"]))
    required = ["MCC", "MNC", "CID"]
    if all(c in colmap for c in required):
        return (
            f"COALESCE({compact_norm_expr(quote_ident(colmap['MCC']))}, '') || '-' || "
            f"COALESCE({compact_norm_expr(quote_ident(colmap['MNC']))}, '') || '-' || "
            f"COALESCE({compact_norm_expr(quote_ident(colmap['CID']))}, '')"
        )
    raise ValueError("Input has no ECGI column and cannot build ECGI from MCC/MNC/CID.")


