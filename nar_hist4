# ==========================================================


def build_ecgi_summary(feature_metrics: pd.DataFrame, candidates: pd.DataFrame, min_report_score: float) -> pd.DataFrame:
    header("PHASE 1G - BUILD INCIDENT-LEVEL ECGI SUMMARY")
    fm = feature_metrics.copy()
    reportable = fm[(fm["REPORT_FLAG"] == 1) & (fm["SOURCE_PROBLEM_SEVERITY_SCORE"] >= float(min_report_score))].copy()

    if reportable.empty:
        log("No reportable feature incidents after suppressors and severity threshold.", indent=1)
        return pd.DataFrame()

    # Pick the top feature incident per ECGI.
    reportable = reportable.sort_values(["ECGI", "SOURCE_PROBLEM_SEVERITY_SCORE"], ascending=[True, False])
    top = reportable.groupby("ECGI", as_index=False).head(1).copy()
    top = top.rename(
        columns={
            "FEATURE": "MAIN_SOURCE_PROBLEM_FEATURE",
            "PROBLEM_CLASS": "PRIMARY_SOURCE_PROBLEM",
            "SOURCE_FEATURE_EVIDENCE_SUMMARY": "MAIN_SOURCE_EVIDENCE_SUMMARY",
            "SOURCE_PROBLEM_SEVERITY_SCORE": "MAIN_SOURCE_FEATURE_SEVERITY_SCORE",
            "SOURCE_PROBLEM_SEVERITY_PERCENTILE": "MAIN_SOURCE_FEATURE_SEVERITY_PERCENTILE",
            "SOURCE_CHANGE_DAYS_COUNT": "MAIN_SOURCE_FEATURE_CHANGED_DAYS_COUNT",
            "SOURCE_CHANGED_DAYS_PERCENT": "MAIN_SOURCE_FEATURE_CHANGED_DAYS_PERCENT",
            "SOURCE_FIRST_CHANGE_DATE": "MAIN_SOURCE_FIRST_CHANGE_DATE",
            "SOURCE_LAST_CHANGE_DATE": "MAIN_SOURCE_LAST_CHANGE_DATE",
            "SOURCE_LATEST_CHANGE": "MAIN_SOURCE_LATEST_CHANGE",
        }
    )

    agg = reportable.groupby("ECGI", as_index=False).agg(
        SOURCE_CHANGED_FEATURE_COUNT=("FEATURE", "nunique"),
        REPORTABLE_FEATURE_INCIDENT_COUNT=("FEATURE", "size"),
        TOTAL_SOURCE_CHANGE_DAYS_ACROSS_FEATURES=("SOURCE_CHANGE_DAYS_COUNT", "sum"),
        TOTAL_SOURCE_CHANGE_EVENTS=("SOURCE_CHANGE_COUNT", "sum"),
        MAX_SOURCE_CHANGED_DAYS_SINGLE_FEATURE=("SOURCE_CHANGE_DAYS_COUNT", "max"),
        SOURCE_BACK_AND_FORTH_FEATURE_COUNT=("REAL_BACK_AND_FORTH_FLAG", "sum"),
        SOURCE_HIGH_FREQUENCY_FEATURE_COUNT=("HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", "sum"),
        FALLBACK_TO_DEFAULT_FEATURE_COUNT=("FALLBACK_TO_DEFAULT_VALUE_FLAG", "sum"),
        INVALID_LATEST_SOURCE_VALUE_FEATURE_COUNT=("LATEST_SOURCE_INVALID_RANGE_FLAG", "sum"),
        SOURCE_SAME_DAY_CONFLICT_FEATURE_COUNT=("SOURCE_SAME_DAY_CONFLICT_FLAG", "sum"),
        SOURCE_PERSISTENT_FEATURE_COUNT=("PERSISTENT_SOURCE_INSTABILITY_FLAG", "sum"),
        LATEST_DAY_SOURCE_CHANGE_FEATURE_COUNT=("LATEST_DAY_SOURCE_CHANGE_FLAG", "sum"),
        SOURCE_RULE_SCORE_FROM_FEATURES=("SOURCE_PROBLEM_SEVERITY_SCORE", "sum"),
        MAX_FEATURE_SEVERITY_SCORE=("SOURCE_PROBLEM_SEVERITY_SCORE", "max"),
    )

    # Top features as compact text.
    top_feats = (
        reportable.sort_values(["ECGI", "SOURCE_PROBLEM_SEVERITY_SCORE"], ascending=[True, False])
        .groupby("ECGI")
        .head(8)
        .groupby("ECGI")
        .apply(lambda d: "; ".join(f"{r.FEATURE}:{r.PROBLEM_CLASS}:{float(r.SOURCE_PROBLEM_SEVERITY_SCORE):.1f}" for r in d.itertuples()))
        .rename("TOP_SOURCE_CHANGED_FEATURES")
        .reset_index()
    )

    keep_top_cols = [
        "ECGI",
        "ECGI_LABEL",
        "REGION",
        "MARKETCLUSTER",
        "MARKET",
        "SUBMARKET",
        "SERVER_ID",
        "ANALYSIS_DAYS",
        "ANALYSIS_START_DATE",
        "ANALYSIS_END_DATE",
        "LATEST_DB_MISMATCH_RAW_ROWS",
        "LATEST_CANDIDATE_DATE",
        "PRIMARY_SOURCE_PROBLEM",
        "MAIN_SOURCE_PROBLEM_FEATURE",
        "MAIN_SOURCE_FEATURE_SEVERITY_SCORE",
        "MAIN_SOURCE_FEATURE_SEVERITY_PERCENTILE",
        "MAIN_SOURCE_FEATURE_CHANGED_DAYS_COUNT",
        "MAIN_SOURCE_FEATURE_CHANGED_DAYS_PERCENT",
        "MAIN_SOURCE_FIRST_CHANGE_DATE",
        "MAIN_SOURCE_LAST_CHANGE_DATE",
        "MAIN_SOURCE_LATEST_CHANGE",
        "MAIN_SOURCE_EVIDENCE_SUMMARY",
        "LATEST_SOURCE_VALUE",
        "PREVIOUS_NONLATEST_SOURCE_VALUE",
        "FIRST_SOURCE_VALUE",
        "SEVERITY_BAND",
        "RECOMMENDED_ACTION",
    ]
    top_reduced = top[[c for c in keep_top_cols if c in top.columns]].copy()
    ecgi = agg.merge(top_reduced, on="ECGI", how="left").merge(top_feats, on="ECGI", how="left")

    ecgi["SOURCE_RULE_SCORE"] = (
        ecgi["SOURCE_RULE_SCORE_FROM_FEATURES"]
        + 12.0 * np.maximum(ecgi["SOURCE_CHANGED_FEATURE_COUNT"] - 1, 0)
        + 20.0 * (ecgi["FALLBACK_TO_DEFAULT_FEATURE_COUNT"] > 0).astype(int)
        + 15.0 * (ecgi["SOURCE_BACK_AND_FORTH_FEATURE_COUNT"] > 0).astype(int)
        + 15.0 * (ecgi["SOURCE_HIGH_FREQUENCY_FEATURE_COUNT"] > 0).astype(int)
    )
    ecgi["SOURCE_RULE_PERCENTILE"] = percentile_rank(ecgi["SOURCE_RULE_SCORE"])
    ecgi["FINAL_SOURCE_ANOMALY_SCORE"] = ecgi["SOURCE_RULE_SCORE"]
    ecgi["FINAL_SOURCE_ANOMALY_PERCENTILE"] = ecgi["SOURCE_RULE_PERCENTILE"]
    ecgi["MAIN_SOURCE_PROBLEM_TYPE"] = ecgi["PRIMARY_SOURCE_PROBLEM"]
    ecgi["SOURCE_HISTORY_ISSUE_TYPE"] = ecgi["PRIMARY_SOURCE_PROBLEM"]
    ecgi["PLAIN_ENGLISH_SUMMARY"] = ecgi.apply(
        lambda r: (
            f"{r.get('ECGI_LABEL','')} on server {r.get('SERVER_ID','')} is a latest-day DB_MISMATCH candidate. "
            f"V4 source-history rules found {int(r.get('REPORTABLE_FEATURE_INCIDENT_COUNT',0))} reportable feature incident(s). "
            f"Primary class: {r.get('PRIMARY_SOURCE_PROBLEM','')}; main feature: {r.get('MAIN_SOURCE_PROBLEM_FEATURE','')}; "
            f"absolute severity score={float(r.get('SOURCE_RULE_SCORE',0)):.1f}."
        ),
        axis=1,
    )

    ecgi = ecgi.sort_values("SOURCE_RULE_SCORE", ascending=False).reset_index(drop=True)
    ecgi.insert(0, "SOURCE_ANOMALY_RANK", np.arange(1, len(ecgi) + 1))
    log(f"Reportable ECGI incidents: {len(ecgi):,}", indent=1)
    return ecgi


def build_issue_summary(feature_metrics: pd.DataFrame, ecgi_summary: pd.DataFrame) -> pd.DataFrame:
    rows = []
    if not feature_metrics.empty:
        fm = feature_metrics.copy()
        for cls, d in fm.groupby("PROBLEM_CLASS"):
            rows.append(
                {
                    "PROBLEM_CLASS": cls,
                    "FEATURE_METRIC_ROWS": len(d),
                    "IMPACTED_ECGI_COUNT": d["ECGI"].nunique(),
                    "REPORTABLE_ROWS": int(d.get("REPORT_FLAG", pd.Series(dtype=int)).sum()),
                    "AVG_SEVERITY_SCORE": float(d["SOURCE_PROBLEM_SEVERITY_SCORE"].mean()),
                    "MAX_SEVERITY_SCORE": float(d["SOURCE_PROBLEM_SEVERITY_SCORE"].max()),
                }
            )
    out = pd.DataFrame(rows)
    if not out.empty:
        out = out.sort_values(["REPORTABLE_ROWS", "MAX_SEVERITY_SCORE"], ascending=[False, False])
    return out


def build_top_event_evidence(changes: pd.DataFrame, conflicts: pd.DataFrame, feature_metrics: pd.DataFrame, evidence_top_n: int) -> Tuple[pd.DataFrame, pd.DataFrame]:
    top_pairs = feature_metrics[feature_metrics["REPORT_FLAG"] == 1].sort_values("SOURCE_PROBLEM_SEVERITY_SCORE", ascending=False)
    top_pairs = top_pairs[["ECGI", "FEATURE", "SOURCE_PROBLEM_SEVERITY_SCORE", "PROBLEM_CLASS"]].head(evidence_top_n).copy()
    if top_pairs.empty:
        return pd.DataFrame(), pd.DataFrame()

    change_ev = pd.DataFrame()
    if not changes.empty:
        change_ev = changes.merge(top_pairs[["ECGI", "FEATURE", "PROBLEM_CLASS", "SOURCE_PROBLEM_SEVERITY_SCORE"]], on=["ECGI", "FEATURE"], how="inner")
        change_ev["ECGI_LABEL"] = change_ev["ECGI"].map(excel_safe_ecgi)
        change_ev = change_ev.sort_values(["SOURCE_PROBLEM_SEVERITY_SCORE", "ECGI", "FEATURE", "LOAD_DATE"], ascending=[False, True, True, True])

    conflict_ev = pd.DataFrame()
    if not conflicts.empty:
        conflict_ev = conflicts.merge(top_pairs[["ECGI", "FEATURE", "PROBLEM_CLASS", "SOURCE_PROBLEM_SEVERITY_SCORE"]], on=["ECGI", "FEATURE"], how="inner")
        conflict_ev["ECGI_LABEL"] = conflict_ev["ECGI"].map(excel_safe_ecgi)
        conflict_ev = conflict_ev.sort_values(["SOURCE_PROBLEM_SEVERITY_SCORE", "ECGI", "FEATURE", "LOAD_DATE"], ascending=[False, True, True, True])

    return change_ev, conflict_ev


def write_manual_markdown(out_dir: Path, ecgi_summary: pd.DataFrame, feature_metrics: pd.DataFrame, top_n: int) -> None:
    lines: List[str] = []
    lines.append("# CESMLC V4 Problem-Focused Manual Review Report")
    lines.append("")
    lines.append("This report starts from latest-day `DB_MISMATCH='YES'` ECGIs and uses 30-day source history only.")
    lines.append("It intentionally does not compare source fields to `_DB` fields in this V4 pass.")
    lines.append("")

    if ecgi_summary.empty:
        lines.append("No reportable ECGI incidents passed the configured severity/suppressor rules.")
        (out_dir / "cesmlc_v4_top_manual_review_report.md").write_text("\n".join(lines), encoding="utf-8")
        return

    for _, r in ecgi_summary.head(top_n).iterrows():
        ecgi = r.get("ECGI", "")
        lines.append(f"## Rank {int(r.get('SOURCE_ANOMALY_RANK', 0))}: {r.get('ECGI_LABEL', '')}")
        lines.append("")
        lines.append(f"- **Server / market**: {r.get('SERVER_ID','')} / {r.get('MARKET','')}")
        lines.append(f"- **Primary class**: {r.get('PRIMARY_SOURCE_PROBLEM','')}")
        lines.append(f"- **Main feature**: {r.get('MAIN_SOURCE_PROBLEM_FEATURE','')}")
        lines.append(f"- **Severity score**: {float(r.get('SOURCE_RULE_SCORE',0)):.1f} ({r.get('SEVERITY_BAND','')})")
        lines.append(f"- **Latest source value**: {short_value(r.get('LATEST_SOURCE_VALUE',''))}")
        lines.append(f"- **Previous non-latest source value**: {short_value(r.get('PREVIOUS_NONLATEST_SOURCE_VALUE',''))}")
        lines.append(f"- **Latest source change**: {r.get('MAIN_SOURCE_LATEST_CHANGE','')}")
        lines.append(f"- **Evidence**: {r.get('MAIN_SOURCE_EVIDENCE_SUMMARY','')}")
        lines.append(f"- **Recommended action**: {r.get('RECOMMENDED_ACTION','')}")
        sub = feature_metrics[(feature_metrics["ECGI"] == ecgi) & (feature_metrics["REPORT_FLAG"] == 1)].sort_values("SOURCE_PROBLEM_SEVERITY_SCORE", ascending=False).head(6)
        if not sub.empty:
            lines.append("- **Top feature incidents**:")
            for _, fr in sub.iterrows():
                lines.append(
                    f"  - {fr.get('FEATURE','')}: {fr.get('PROBLEM_CLASS','')} | "
                    f"score={float(fr.get('SOURCE_PROBLEM_SEVERITY_SCORE',0)):.1f} | "
                    f"latest={short_value(fr.get('LATEST_SOURCE_VALUE',''))} | "
                    f"changes={int(fr.get('SOURCE_CHANGE_DAYS_COUNT',0))} days | "
                    f"distinct={int(fr.get('DISTINCT_SOURCE_VALUES_30D',0))}"
                )
        lines.append("")

    (out_dir / "cesmlc_v4_top_manual_review_report.md").write_text("\n".join(lines), encoding="utf-8")


def write_readme(out_dir: Path, analysis_info: Dict[str, Any], args: argparse.Namespace) -> None:
    text = f"""# CESMLC V4 Problem-Focused Results Guide

## What this version does

V4 changes the target from "all source-history changes" to "latest-day DB_MISMATCH candidates with abnormal source history".

Pipeline:

1. Latest-day candidate gate: `DB_MISMATCH = 'YES'`.
2. Pull 30-day source history for those candidate ECGIs only.
3. Do not compare `FEATURE` to `FEATURE_DB` in this version.
4. Apply stricter abnormal-pattern rules:
   - `FALLBACK_TO_DEFAULT_VALUE`
   - `REAL_BACK_AND_FORTH_INSTABILITY`
   - `HIGH_FREQUENCY_DIFFERENT_VALUES`
   - `SAME_DAY_SOURCE_CONFLICT`
   - `PERSISTENT_SOURCE_INSTABILITY`
   - `LATEST_DAY_SOURCE_CHANGE`
   - `INVALID_LATEST_SOURCE_VALUE`
5. Suppress likely normal/stable source changes and candidate-population bulk refresh patterns.
6. Score with an absolute severity score before percentile ranking.

## Important limitation

This version uses `DB_MISMATCH` only as the latest-day ECGI candidate gate. It does not use field-level `_DB` values. Therefore, it cannot conclusively identify "audit cannot push to server". If many candidates fall into `DB_MISMATCH_CANDIDATE_STABLE_SOURCE_HISTORY`, the next step is to add field-level source-vs-DB comparison for those candidates only.

## Run settings

- Script version: `{SCRIPT_VERSION}`
- Input: `{analysis_info.get('input_file','')}`
- Window: `{analysis_info.get('window_start_date','')}` to `{analysis_info.get('window_end_date','')}`
- Candidate date: `{analysis_info.get('candidate_date','')}`
- Latest-day DB_MISMATCH YES rows: `{analysis_info.get('latest_db_mismatch_yes_rows','')}`
- Candidate ECGIs: `{analysis_info.get('latest_db_mismatch_candidate_ecgis','')}`
- Min report score: `{args.min_report_score}`
- Back-and-forth thresholds: A-B-A >= `{args.min_aba_for_backforth}`, reverse transitions >= `{args.min_reverses_for_backforth}`
- High-frequency thresholds: changed days >= `{args.high_frequency_days}`, distinct values >= `{args.high_frequency_distinct_values}`
- Bulk suppressor threshold among candidates: `{args.bulk_change_ratio_threshold}`

## Main files to open

1. `cesmlc_v4_ecgi_incident_summary_top.csv`  
   Top ECGI-level incidents after suppressors and absolute scoring.

2. `cesmlc_v4_feature_incidents_top.csv`  
   Top ECGI + feature incidents.

3. `cesmlc_v4_top_manual_review_report.md`  
   Human-readable top incident review.

4. `cesmlc_v4_issue_type_summary.csv`  
   Counts by problem class.

5. `cesmlc_v4_suppressed_or_informational_feature_rows.csv`  
   Rows suppressed as normal/stable/bulk or stable-source history after DB_MISMATCH gate.

6. `cesmlc_v4_candidate_ecgis_latest_db_mismatch.csv`  
   Distinct latest-day DB_MISMATCH candidate ECGIs.

## Compatibility files for current Phase 2

For compatibility with your current Phase 2 loader, V4 also writes:

- `cesmlc_source_only_ecgi_anomaly_summary_all.csv`
- `cesmlc_source_only_feature_metrics_all.csv`

These are populated from V4 reportable incidents, not from the old broad V3 source-only change detector.
"""
    (out_dir / "00_READ_ME_V4_PROBLEM_FOCUSED.md").write_text(text, encoding="utf-8")


def ensure_compatibility_columns(ecgi_summary: pd.DataFrame, feature_metrics: pd.DataFrame) -> Tuple[pd.DataFrame, pd.DataFrame]:
    ecgi = ecgi_summary.copy()
    fm = feature_metrics.copy()

    if not ecgi.empty:
        ecgi_defaults = {
            "PRIMARY_SOURCE_PROBLEM": "",
            "MAIN_SOURCE_PROBLEM_TYPE": "",
            "SOURCE_HISTORY_ISSUE_TYPE": "",
            "MAIN_SOURCE_PROBLEM_FEATURE": "",
            "MAIN_SOURCE_EVIDENCE_SUMMARY": "",
            "MAIN_SOURCE_LATEST_CHANGE": "",
            "TOP_SOURCE_CHANGED_FEATURES": "",
            "PLAIN_ENGLISH_SUMMARY": "",
            "RECOMMENDED_ACTION": "",
            "SOURCE_RULE_SCORE": 0,
            "SOURCE_RULE_PERCENTILE": 0,
            "FINAL_SOURCE_ANOMALY_SCORE": 0,
            "FINAL_SOURCE_ANOMALY_PERCENTILE": 0,
        }
        for c, v in ecgi_defaults.items():
            if c not in ecgi.columns:
                ecgi[c] = v

    if not fm.empty:
        rename_map = {
            "REAL_BACK_AND_FORTH_FLAG": "SOURCE_BACK_AND_FORTH_FLAG",
            "HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG": "SOURCE_HIGH_FREQUENCY_FLAG",
            "PERSISTENT_SOURCE_INSTABILITY_FLAG": "SOURCE_PERSISTENT_FLAG",
            "SOURCE_PROBLEM_SEVERITY_SCORE": "SOURCE_FEATURE_SCORE",
            "SOURCE_PROBLEM_SEVERITY_PERCENTILE": "SOURCE_FEATURE_SCORE_PERCENTILE",
            "PROBLEM_CLASS": "SOURCE_HISTORY_ISSUE_TYPE",
        }
        for src, dst in rename_map.items():
            if src in fm.columns and dst not in fm.columns:
                fm[dst] = fm[src]
        defaults = {
            "SOURCE_CHANGE_COUNT": 0,
            "SOURCE_CHANGE_DAYS_COUNT": 0,
            "SOURCE_A_B_A_REVERT_COUNT": 0,
            "SOURCE_REVERSE_TRANSITION_COUNT": 0,
            "SOURCE_SAME_DAY_CONFLICT_DAYS": 0,
            "SOURCE_SAME_DAY_CONFLICT_ROWS": 0,
            "RARE_LATEST_SOURCE_VALUE_FLAG": 0,
            "LATEST_DAY_SOURCE_CHANGE_FLAG": 0,
            "SOURCE_FEATURE_SCORE": 0,
            "SOURCE_FEATURE_SCORE_PERCENTILE": 0,
        }
        for c, v in defaults.items():
            if c not in fm.columns:
                fm[c] = v

    return ecgi, fm


def write_outputs(
    out_dir: Path,
    analysis_info: Dict[str, Any],
    args: argparse.Namespace,
    candidates: pd.DataFrame,
    feature_metrics: pd.DataFrame,
    ecgi_summary: pd.DataFrame,
    issue_summary: pd.DataFrame,
    changes: pd.DataFrame,
    conflicts: pd.DataFrame,
) -> None:
    header("PHASE 1G - WRITE OUTPUTS")
    out_dir.mkdir(parents=True, exist_ok=True)
    log(f"Writing output files to: {out_dir}", indent=1)

    write_readme(out_dir, analysis_info, args)
    pd.DataFrame([analysis_info]).to_csv(out_dir / "cesmlc_v4_processing_report.csv", index=False)
    candidates.to_csv(out_dir / "cesmlc_v4_candidate_ecgis_latest_db_mismatch.csv", index=False)
    issue_summary.to_csv(out_dir / "cesmlc_v4_issue_type_summary.csv", index=False)

    reportable_fm = feature_metrics[feature_metrics["REPORT_FLAG"] == 1].sort_values("SOURCE_PROBLEM_SEVERITY_SCORE", ascending=False).copy()
    suppressed_fm = feature_metrics[feature_metrics["REPORT_FLAG"] == 0].sort_values("SOURCE_PROBLEM_SEVERITY_SCORE", ascending=False).copy()

    reportable_fm.to_csv(out_dir / "cesmlc_v4_feature_incidents_all.csv", index=False)
    reportable_fm.head(args.top_n_features).to_csv(out_dir / "cesmlc_v4_feature_incidents_top.csv", index=False)
    suppressed_fm.to_csv(out_dir / "cesmlc_v4_suppressed_or_informational_feature_rows.csv", index=False)

    if not ecgi_summary.empty:
        ecgi_summary.to_csv(out_dir / "cesmlc_v4_ecgi_incident_summary_all.csv", index=False)
        ecgi_summary.head(args.top_n).to_csv(out_dir / "cesmlc_v4_ecgi_incident_summary_top.csv", index=False)
    else:
        pd.DataFrame().to_csv(out_dir / "cesmlc_v4_ecgi_incident_summary_all.csv", index=False)
        pd.DataFrame().to_csv(out_dir / "cesmlc_v4_ecgi_incident_summary_top.csv", index=False)

    change_ev, conflict_ev = build_top_event_evidence(changes, conflicts, feature_metrics, args.evidence_top_n)
    change_ev.to_csv(out_dir / "cesmlc_v4_source_change_events_top.csv", index=False)
    conflict_ev.to_csv(out_dir / "cesmlc_v4_same_day_conflicts_top.csv", index=False)

    # Current Phase 2 compatibility aliases. These aliases contain V4 reportable incidents, not old V3 broad source-only rows.
    compat_ecgi, compat_fm = ensure_compatibility_columns(ecgi_summary, reportable_fm)
    compat_ecgi.to_csv(out_dir / "cesmlc_source_only_ecgi_anomaly_summary_all.csv", index=False)
    compat_fm.to_csv(out_dir / "cesmlc_source_only_feature_metrics_all.csv", index=False)

    write_manual_markdown(out_dir, ecgi_summary, feature_metrics, args.manual_report_top_n)

    log(f"Reportable feature incidents written: {len(reportable_fm):,}", indent=1)
    log(f"Suppressed/informational feature rows written: {len(suppressed_fm):,}", indent=1)
    log(f"Reportable ECGI incidents written: {len(ecgi_summary):,}", indent=1)


