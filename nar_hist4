def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="CESMLC V4 problem-focused latest-day DB_MISMATCH candidate + source-history anomaly detector."
    )
    p.add_argument("--input", required=True, type=str, help="Raw CESMLC CSV input.")
    p.add_argument("--days", default=30, type=int, help="Analysis window length ending at --end-date or max LOAD_DATE.")
    p.add_argument("--end-date", default=None, type=str, help="Optional candidate/latest date YYYY-MM-DD. Default: max parsed LOAD_DATE.")
    p.add_argument("--out-dir", default=None, type=str, help="Output folder.")
    p.add_argument("--server-id", default=None, type=str, help="Optional SERVER_ID filter for latest-day candidate extraction.")
    p.add_argument("--include-features", default=",".join(DEFAULT_FEATURES), type=str, help="Comma-separated source/current feature columns to analyze.")
    p.add_argument("--exclude-features", default=None, type=str, help="Comma-separated features to exclude.")
    p.add_argument("--defaults-json", default=None, type=str, help="Optional JSON overriding default values, valid ranges, and criticality weights.")

    p.add_argument("--latlon-decimals", default=5, type=int, help="Coordinate rounding precision. Default 5.")
    p.add_argument("--feature-batch-size", default=1, type=int, help="Number of features per DuckDB batch. Default 1 for memory safety.")
    p.add_argument("--threads", default=1, type=int, help="DuckDB thread count. Default 1 for memory safety.")
    p.add_argument("--memory-limit", default="6GB", type=str, help="DuckDB memory limit, e.g. 6GB, 8GB, 16GB.")
    p.add_argument("--duckdb-file", default=None, type=str, help="Optional DuckDB database file. Default: output/temp/cesmlc_v4.duckdb")
    p.add_argument("--duckdb-temp-dir", default=None, type=str, help="DuckDB spill/temp directory. Default: output/temp/duckdb_spill")
    p.add_argument("--keep-duckdb", action="store_true", help="Keep temporary DuckDB files.")

    # Rule thresholds.
    p.add_argument("--high-frequency-days", default=5, type=int, help="Changed days threshold for high-frequency different-values class.")
    p.add_argument("--high-frequency-distinct-values", default=3, type=int, help="Distinct values threshold for high-frequency different-values class.")
    p.add_argument("--persistent-days", default=10, type=int, help="Changed days threshold for persistent source instability.")
    p.add_argument("--min-reverses-for-backforth", default=2, type=int, help="Reverse transition threshold for real back-and-forth.")
    p.add_argument("--min-aba-for-backforth", default=2, type=int, help="A-B-A revert threshold for real back-and-forth.")
    p.add_argument("--default-min-days", default=2, type=int, help="Latest default value must persist this many observed days for fallback class.")
    p.add_argument("--stable-change-suppress-days", default=5, type=int, help="Suppress one-time changes older than this many days.")
    p.add_argument("--bulk-change-ratio-threshold", default=0.25, type=float, help="Suppress likely bulk/refresh when candidate-population feature/day change ratio exceeds this.")
    p.add_argument("--min-report-score", default=35.0, type=float, help="Minimum absolute feature severity score to report.")

    p.add_argument("--top-n", default=300, type=int, help="Top N ECGI incidents output.")
    p.add_argument("--top-n-features", default=2000, type=int, help="Top N feature incidents output.")
    p.add_argument("--evidence-top-n", default=2000, type=int, help="Top ECGI-feature pairs for event evidence outputs.")
    p.add_argument("--manual-report-top-n", default=50, type=int, help="Top ECGIs in manual markdown report.")
    return p.parse_args()


def main() -> int:
    args = parse_args()
    input_path = Path(args.input).expanduser()
    if not input_path.exists():
        raise FileNotFoundError(f"Input file not found: {input_path}")

    out_dir = Path(args.out_dir).expanduser() if args.out_dir else input_path.parent / "cesmlc_v4_problem_focused_outputs"
    out_dir.mkdir(parents=True, exist_ok=True)
    temp_dir = out_dir / "temp"
    temp_dir.mkdir(parents=True, exist_ok=True)
    duckdb_path = Path(args.duckdb_file).expanduser() if args.duckdb_file else temp_dir / "cesmlc_v4.duckdb"
    duckdb_temp_dir = Path(args.duckdb_temp_dir).expanduser() if args.duckdb_temp_dir else temp_dir / "duckdb_spill"

    header("CESMLC V4 PROBLEM-FOCUSED SOURCE-HISTORY DETECTOR")
    log(f"Input: {input_path}")
    log(f"Output: {out_dir}")
    log("Candidate gate: latest-day DB_MISMATCH='YES'")
    log("Scoring evidence: 30-day source/current value history only; FEATURE_DB columns not compared")
    log(
        f"Run settings: days={args.days}, feature_batch_size={args.feature_batch_size}, "
        f"threads={args.threads}, memory_limit={args.memory_limit}, latlon_decimals={args.latlon_decimals}"
    )

    header_cols, colmap = read_header(input_path)
    date_col = first_existing(header_cols, DATE_CANDIDATES)
    if not date_col:
        raise ValueError(f"No date column found. Tried {DATE_CANDIDATES}. Found: {header_cols}")
    features = detect_features(header_cols, args.include_features, args.exclude_features)
    if not features:
        raise ValueError("No source features selected. Use --include-features with comma-separated column names.")
    missing = [f for f in features if f not in colmap]
    if missing:
        raise ValueError(f"Selected features not found in CSV header: {missing}")

    log(f"Date column: {date_col}")
    log(f"DB_MISMATCH column present: {'DB_MISMATCH' in colmap}")
    log(f"Source features ({len(features)}): {', '.join(features)}")

    rules = load_feature_rules(args.defaults_json)
    con = open_duckdb(duckdb_path, args.threads, args.memory_limit, duckdb_temp_dir=duckdb_temp_dir)
    try:
        analysis_info = create_latest_db_mismatch_candidates(
            con=con,
            input_path=input_path,
            colmap=colmap,
            date_col_clean=date_col,
            days=args.days,
            end_date=args.end_date,
            server_id_filter=args.server_id,
        )
        analysis_info["feature_count"] = int(len(features))
        analysis_info["features"] = ",".join(features)
        analysis_info["latlon_decimals"] = int(args.latlon_decimals)
        analysis_info["min_report_score"] = float(args.min_report_score)
        analysis_info["high_frequency_days"] = int(args.high_frequency_days)
        analysis_info["high_frequency_distinct_values"] = int(args.high_frequency_distinct_values)
        analysis_info["persistent_days"] = int(args.persistent_days)
        analysis_info["min_reverses_for_backforth"] = int(args.min_reverses_for_backforth)
        analysis_info["min_aba_for_backforth"] = int(args.min_aba_for_backforth)
        analysis_info["default_min_days"] = int(args.default_min_days)
        analysis_info["stable_change_suppress_days"] = int(args.stable_change_suppress_days)
        analysis_info["bulk_change_ratio_threshold"] = float(args.bulk_change_ratio_threshold)

        create_candidate_source_history_events_batched(
            con=con,
            input_path=input_path,
            colmap=colmap,
            date_col_clean=date_col,
            features=features,
            analysis_info=analysis_info,
            latlon_decimals=args.latlon_decimals,
            feature_batch_size=args.feature_batch_size,
        )

        candidates, hist, changes, conflicts = load_compact_tables(con)
        feature_metrics = build_feature_metrics(
            candidates=candidates,
            hist=hist,
            changes=changes,
            conflicts=conflicts,
            rules=rules,
            analysis_info=analysis_info,
            args=args,
        )
        ecgi_summary = build_ecgi_summary(feature_metrics, candidates, args.min_report_score)
        issue_summary = build_issue_summary(feature_metrics, ecgi_summary)

        # Update output stats.
        analysis_info["feature_history_metric_rows"] = int(len(hist))
        analysis_info["source_change_event_rows"] = int(len(changes))
        analysis_info["same_day_conflict_rows"] = int(len(conflicts))
        analysis_info["reportable_feature_incidents"] = int(feature_metrics["REPORT_FLAG"].sum()) if not feature_metrics.empty else 0
        analysis_info["reportable_ecgi_incidents"] = int(len(ecgi_summary)) if not ecgi_summary.empty else 0
        analysis_info["suppressed_or_informational_feature_rows"] = int((feature_metrics["REPORT_FLAG"] == 0).sum()) if not feature_metrics.empty else 0

        write_outputs(
            out_dir=out_dir,
            analysis_info=analysis_info,
            args=args,
            candidates=candidates,
            feature_metrics=feature_metrics,
            ecgi_summary=ecgi_summary,
            issue_summary=issue_summary,
            changes=changes,
            conflicts=conflicts,
        )

    finally:
        log("Closing DuckDB connection", indent=1)
        try:
            con.close()
        except Exception:
            pass
        if not args.keep_duckdb:
            log("Removing temporary DuckDB files because --keep-duckdb was not used", indent=1)
            shutil.rmtree(temp_dir, ignore_errors=True)
        else:
            log(f"Keeping temporary DuckDB files in: {temp_dir}", indent=1)

    header("DONE")
    log(f"Total runtime: {elapsed_text()}")
    log(f"Open first: {out_dir / 'cesmlc_v4_top_manual_review_report.md'}")
    log(f"Open second: {out_dir / 'cesmlc_v4_ecgi_incident_summary_top.csv'}")
    log(f"Open third: {out_dir / 'cesmlc_v4_feature_incidents_top.csv'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())