def load_compact_tables(con) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    header("PHASE 1D - LOAD COMPACT HISTORY TABLES FOR RULE SCORING")
    candidates = con.execute("SELECT * FROM candidate_ecgis").fetchdf()
    hist = con.execute("SELECT * FROM source_feature_history_metrics").fetchdf()
    changes = con.execute("SELECT * FROM source_change_events").fetchdf()
    conflicts = con.execute("SELECT * FROM source_same_day_conflicts").fetchdf()

    for df in [candidates, hist, changes, conflicts]:
        df.columns = [clean_col_name(c) for c in df.columns]
        for c in ["LOAD_DATE", "PREVIOUS_LOAD_DATE", "FIRST_OBSERVED_DATE", "LAST_OBSERVED_DATE", "LATEST_SOURCE_VALUE_FIRST_SEEN_DATE", "LATEST_SOURCE_VALUE_LAST_SEEN_DATE", "LATEST_CANDIDATE_DATE"]:
            if c in df.columns:
                df[c] = pd.to_datetime(df[c], errors="coerce").dt.normalize()
        if "ECGI" in df.columns:
            df["ECGI"] = df["ECGI"].map(normalize_key_value)
        if "FEATURE" in df.columns:
            df["FEATURE"] = df["FEATURE"].map(clean_col_name)

    for c in ["FIRST_SOURCE_VALUE", "LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "MODE_SOURCE_VALUE", "PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE", "REPRESENTATIVE_SOURCE_VALUE"]:
        for df in [hist, changes, conflicts]:
            if c in df.columns:
                df[c] = df[c].map(normalize_value_text)

    log(f"Candidate ECGIs: {len(candidates):,}", indent=1)
    log(f"Feature-history metric rows: {len(hist):,}", indent=1)
    log(f"Source-change event rows: {len(changes):,}", indent=1)
    log(f"Same-day conflict rows: {len(conflicts):,}", indent=1)
    return candidates, hist, changes, conflicts


def compute_reverse_transition_flags(changes: pd.DataFrame) -> pd.DataFrame:
    if changes.empty:
        changes["REVERSE_TRANSITION_FLAG"] = pd.Series(dtype=int)
        return changes
    changes = changes.sort_values(["ECGI", "FEATURE", "LOAD_DATE", "PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE"]).reset_index(drop=True)
    flags: List[int] = []
    seen: Dict[Tuple[str, str], set] = {}
    for _, row in changes.iterrows():
        key = (str(row["ECGI"]), str(row["FEATURE"]))
        prev = normalize_value_text(row.get("PREVIOUS_SOURCE_VALUE", ""))
        cur = normalize_value_text(row.get("CURRENT_SOURCE_VALUE", ""))
        pair = (prev, cur)
        rev = (cur, prev)
        flags.append(1 if rev in seen.get(key, set()) else 0)
        seen.setdefault(key, set()).add(pair)
    changes["REVERSE_TRANSITION_FLAG"] = flags
    return changes


def build_change_stats(changes: pd.DataFrame, candidate_date: pd.Timestamp, total_candidate_ecgis: int) -> pd.DataFrame:
    if changes.empty:
        return pd.DataFrame(columns=["ECGI", "FEATURE"])

    changes = compute_reverse_transition_flags(changes)
    group = changes.groupby(["ECGI", "FEATURE"], dropna=False)
    stats = group.agg(
        SOURCE_CHANGE_COUNT=("LOAD_DATE", "size"),
        SOURCE_CHANGE_DAYS_COUNT=("LOAD_DATE", "nunique"),
        SOURCE_FIRST_CHANGE_DATE=("LOAD_DATE", "min"),
        SOURCE_LAST_CHANGE_DATE=("LOAD_DATE", "max"),
        SOURCE_A_B_A_REVERT_COUNT=("A_B_A_REVERT_FLAG", "sum"),
        SOURCE_REVERSE_TRANSITION_COUNT=("REVERSE_TRANSITION_FLAG", "sum"),
        RAW_ROWS_SUPPORTING_SOURCE_CHANGES=("RAW_ROWS_PER_ECGI_DATE", "sum"),
        DISTINCT_PREVIOUS_SOURCE_VALUES_COUNT=("PREVIOUS_SOURCE_VALUE", pd.Series.nunique),
        DISTINCT_CURRENT_SOURCE_VALUES_COUNT=("CURRENT_SOURCE_VALUE", pd.Series.nunique),
    ).reset_index()

    # Latest change transition per ECGI/feature.
    latest = changes.sort_values(["ECGI", "FEATURE", "LOAD_DATE"]).groupby(["ECGI", "FEATURE"], as_index=False).tail(1)
    latest = latest[["ECGI", "FEATURE", "PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE", "LOAD_DATE"]].rename(
        columns={
            "PREVIOUS_SOURCE_VALUE": "LATEST_PREVIOUS_SOURCE_VALUE",
            "CURRENT_SOURCE_VALUE": "LATEST_CURRENT_SOURCE_VALUE",
            "LOAD_DATE": "LATEST_SOURCE_CHANGE_DATE",
        }
    )
    stats = stats.merge(latest, on=["ECGI", "FEATURE"], how="left")

    # Candidate-bulk stats among candidate ECGIs. This is not the full-server denominator, but it catches
    # mass refresh patterns inside the latest-mismatch candidate population.
    bulk = changes.groupby(["FEATURE", "LOAD_DATE"], as_index=False).agg(CHANGED_ECGIS_FEATURE_DAY=("ECGI", "nunique"))
    if not bulk.empty:
        denom = max(1, int(total_candidate_ecgis))
        bulk["CANDIDATE_BULK_CHANGE_RATIO"] = bulk["CHANGED_ECGIS_FEATURE_DAY"] / denom
        merge_bulk = changes[["ECGI", "FEATURE", "LOAD_DATE"]].merge(bulk, on=["FEATURE", "LOAD_DATE"], how="left")
        bulk_per_feature = merge_bulk.groupby(["ECGI", "FEATURE"], as_index=False).agg(
            MAX_CANDIDATE_BULK_CHANGE_RATIO=("CANDIDATE_BULK_CHANGE_RATIO", "max"),
            MAX_CHANGED_ECGIS_FEATURE_DAY=("CHANGED_ECGIS_FEATURE_DAY", "max"),
        )
        stats = stats.merge(bulk_per_feature, on=["ECGI", "FEATURE"], how="left")

    stats["LATEST_DAY_SOURCE_CHANGE_FLAG"] = (
        pd.to_datetime(stats["SOURCE_LAST_CHANGE_DATE"], errors="coerce").dt.normalize() == candidate_date
    ).astype(int)
    stats["SOURCE_LATEST_CHANGE"] = stats.apply(
        lambda r: transition_text(r.get("LATEST_PREVIOUS_SOURCE_VALUE", ""), r.get("LATEST_CURRENT_SOURCE_VALUE", "")), axis=1
    )
    return stats


def build_conflict_stats(conflicts: pd.DataFrame) -> pd.DataFrame:
    if conflicts.empty:
        return pd.DataFrame(columns=["ECGI", "FEATURE"])
    stats = conflicts.groupby(["ECGI", "FEATURE"], dropna=False).agg(
        SOURCE_SAME_DAY_CONFLICT_ROWS=("LOAD_DATE", "size"),
        SOURCE_SAME_DAY_CONFLICT_DAYS=("LOAD_DATE", "nunique"),
        SOURCE_FIRST_CONFLICT_DATE=("LOAD_DATE", "min"),
        SOURCE_LAST_CONFLICT_DATE=("LOAD_DATE", "max"),
        MAX_SAME_DAY_UNIQUE_SOURCE_VALUES=("SOURCE_VALUES_UNIQUE_COUNT", "max"),
    ).reset_index()
    return stats


def add_rule_flags_and_scores(
    feature_metrics: pd.DataFrame,
    rules: Dict[str, Dict[str, Any]],
    analysis_info: Dict[str, Any],
    high_frequency_days: int,
    high_frequency_distinct_values: int,
    persistent_days: int,
    min_reverses_for_backforth: int,
    min_aba_for_backforth: int,
    default_min_days: int,
    stable_change_suppress_days: int,
    bulk_change_ratio_threshold: float,
    min_report_score: float,
) -> pd.DataFrame:
    if feature_metrics.empty:
        return feature_metrics

    fm = feature_metrics.copy()
    numeric_defaults = {
        "OBSERVED_DAYS_FOR_FEATURE": 0,
        "DISTINCT_SOURCE_VALUES_30D": 0,
        "MODE_SOURCE_VALUE_DAYS": 0,
        "MODE_SOURCE_VALUE_SHARE_PERCENT": 0,
        "LATEST_SOURCE_VALUE_DAYS": 0,
        "RAW_ROWS_FOR_FEATURE": 0,
        "SOURCE_CHANGE_COUNT": 0,
        "SOURCE_CHANGE_DAYS_COUNT": 0,
        "SOURCE_A_B_A_REVERT_COUNT": 0,
        "SOURCE_REVERSE_TRANSITION_COUNT": 0,
        "RAW_ROWS_SUPPORTING_SOURCE_CHANGES": 0,
        "DISTINCT_PREVIOUS_SOURCE_VALUES_COUNT": 0,
        "DISTINCT_CURRENT_SOURCE_VALUES_COUNT": 0,
        "SOURCE_SAME_DAY_CONFLICT_ROWS": 0,
        "SOURCE_SAME_DAY_CONFLICT_DAYS": 0,
        "MAX_SAME_DAY_UNIQUE_SOURCE_VALUES": 0,
        "LATEST_DAY_SOURCE_CHANGE_FLAG": 0,
        "MAX_CANDIDATE_BULK_CHANGE_RATIO": 0,
        "MAX_CHANGED_ECGIS_FEATURE_DAY": 0,
    }
    for c, default in numeric_defaults.items():
        if c not in fm.columns:
            fm[c] = default
        fm[c] = safe_numeric(fm[c], default)

    date_cols = [
        "FIRST_OBSERVED_DATE",
        "LAST_OBSERVED_DATE",
        "SOURCE_FIRST_CHANGE_DATE",
        "SOURCE_LAST_CHANGE_DATE",
        "LATEST_SOURCE_CHANGE_DATE",
        "SOURCE_FIRST_CONFLICT_DATE",
        "SOURCE_LAST_CONFLICT_DATE",
        "LATEST_SOURCE_VALUE_FIRST_SEEN_DATE",
        "LATEST_SOURCE_VALUE_LAST_SEEN_DATE",
    ]
    for c in date_cols:
        if c in fm.columns:
            fm[c] = pd.to_datetime(fm[c], errors="coerce").dt.normalize()

    candidate_date = pd.to_datetime(analysis_info["candidate_date"]).normalize()
    requested_days = max(1, int(analysis_info.get("requested_days", 30)))

    # Default / invalid latest flags.
    fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("LATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(
        lambda r: value_is_default(r["FEATURE"], r.get("PREVIOUS_NONLATEST_SOURCE_VALUE", ""), rules), axis=1
    )
    fm["FIRST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("FIRST_SOURCE_VALUE", ""), rules), axis=1)
    fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] = fm.apply(lambda r: value_is_invalid(r["FEATURE"], r.get("LATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["FEATURE_CRITICALITY_WEIGHT"] = fm["FEATURE"].map(lambda f: get_feature_weight(f, rules))

    fm["SOURCE_CHANGED_DAYS_PERCENT"] = 100.0 * fm["SOURCE_CHANGE_DAYS_COUNT"] / max(1, requested_days)
    fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] = (
        candidate_date - pd.to_datetime(fm["SOURCE_LAST_CHANGE_DATE"], errors="coerce").dt.normalize()
    ).dt.days
    fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] = fm["DAYS_SINCE_LAST_SOURCE_CHANGE"].fillna(9999).clip(lower=0)

    fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] = (fm["SOURCE_SAME_DAY_CONFLICT_DAYS"] > 0).astype(int)
    fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"] = (fm["SOURCE_CHANGE_DAYS_COUNT"] >= int(persistent_days)).astype(int)

    # Stricter back-and-forth than V3: one A-B-A is not enough by default.
    fm["REAL_BACK_AND_FORTH_FLAG"] = (
        (fm["SOURCE_A_B_A_REVERT_COUNT"] >= int(min_aba_for_backforth))
        | (fm["SOURCE_REVERSE_TRANSITION_COUNT"] >= int(min_reverses_for_backforth))
        | ((fm["SOURCE_CHANGE_COUNT"] >= 4) & (fm["DISTINCT_SOURCE_VALUES_30D"] <= 3) & (fm["SOURCE_CHANGE_DAYS_COUNT"] >= 3))
    ).astype(int)

    fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] = (
        (fm["SOURCE_CHANGE_DAYS_COUNT"] >= int(high_frequency_days))
        & (fm["DISTINCT_SOURCE_VALUES_30D"] >= int(high_frequency_distinct_values))
        & (fm["MODE_SOURCE_VALUE_SHARE_PERCENT"] < 85)
    ).astype(int)

    fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] = (
        (fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] == 1)
        & (fm["PREVIOUS_NONLATEST_SOURCE_VALUE"].fillna("").astype(str) != "")
        & (fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] == 0)
        & (fm["LATEST_SOURCE_VALUE_DAYS"] >= int(default_min_days))
    ).astype(int)

    fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] = (
        (fm["MAX_CANDIDATE_BULK_CHANGE_RATIO"] >= float(bulk_change_ratio_threshold))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["REAL_BACK_AND_FORTH_FLAG"] == 0)
        & (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
    ).astype(int)

    fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] = (
        (fm["SOURCE_CHANGE_COUNT"] == 1)
        & (fm["DISTINCT_SOURCE_VALUES_30D"] <= 2)
        & (fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] >= int(stable_change_suppress_days))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
    ).astype(int)

    fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] = (
        (fm["SOURCE_CHANGE_COUNT"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
    ).astype(int)

    fm["HAS_CRITICAL_PROBLEM_FLAG"] = (
        (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1)
        | (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 1)
        | (fm["REAL_BACK_AND_FORTH_FLAG"] == 1)
        | (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 1)
        | (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 1)
    ).astype(int)

    # Absolute severity score. The goal is not to rank every change, but to isolate the non-normal candidate history.
    score = pd.Series(np.zeros(len(fm)), index=fm.index, dtype=float)
    score += 35.0 * fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"]
    score += 30.0 * fm["LATEST_SOURCE_INVALID_RANGE_FLAG"]
    score += 28.0 * fm["REAL_BACK_AND_FORTH_FLAG"]
    score += 28.0 * fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"]
    score += 20.0 * fm["SOURCE_SAME_DAY_CONFLICT_FLAG"]
    score += 14.0 * fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"]
    score += 8.0 * fm["LATEST_DAY_SOURCE_CHANGE_FLAG"]
    score += np.minimum(15.0, 1.5 * fm["SOURCE_CHANGE_DAYS_COUNT"])
    score += np.minimum(10.0, 0.75 * fm["SOURCE_CHANGE_COUNT"])
    score += np.minimum(8.0, 2.0 * np.maximum(fm["DISTINCT_SOURCE_VALUES_30D"] - 1, 0))
    score += np.where(fm["HAS_CRITICAL_PROBLEM_FLAG"] == 1, fm["FEATURE_CRITICALITY_WEIGHT"], 0.25 * fm["FEATURE_CRITICALITY_WEIGHT"])
    score += np.minimum(5.0, np.log1p(fm["RAW_ROWS_FOR_FEATURE"].clip(lower=0)))

    # Suppressors apply only if no critical problem is present.
    no_critical = fm["HAS_CRITICAL_PROBLEM_FLAG"] == 0
    score -= np.where(no_critical & (fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] == 1), 25.0, 0.0)
    score -= np.where(no_critical & (fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] == 1), 25.0, 0.0)
    score -= np.where(no_critical & (fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] == 1), 18.0, 0.0)
    fm["SOURCE_PROBLEM_SEVERITY_SCORE"] = score.clip(lower=0)
    fm["SOURCE_PROBLEM_SEVERITY_PERCENTILE"] = percentile_rank(fm["SOURCE_PROBLEM_SEVERITY_SCORE"])

    def severity_band(x: float) -> str:
        if x >= 80:
            return "CRITICAL"
        if x >= 60:
            return "HIGH"
        if x >= 40:
            return "MEDIUM"
        if x >= 20:
            return "LOW"
        return "SUPPRESSED_OR_INFORMATIONAL"

    fm["SEVERITY_BAND"] = fm["SOURCE_PROBLEM_SEVERITY_SCORE"].map(severity_band)

    def problem_class(r: pd.Series) -> str:
        # Critical/meaningful categories first.
        if int(r.get("LATEST_SOURCE_INVALID_RANGE_FLAG", 0)) == 1:
            return "INVALID_LATEST_SOURCE_VALUE"
        if int(r.get("FALLBACK_TO_DEFAULT_VALUE_FLAG", 0)) == 1:
            return "FALLBACK_TO_DEFAULT_VALUE"
        if int(r.get("REAL_BACK_AND_FORTH_FLAG", 0)) == 1:
            return "REAL_BACK_AND_FORTH_INSTABILITY"
        if int(r.get("HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", 0)) == 1:
            return "HIGH_FREQUENCY_DIFFERENT_VALUES"
        if int(r.get("SOURCE_SAME_DAY_CONFLICT_FLAG", 0)) == 1:
            return "SAME_DAY_SOURCE_CONFLICT"
        if int(r.get("PERSISTENT_SOURCE_INSTABILITY_FLAG", 0)) == 1:
            return "PERSISTENT_SOURCE_INSTABILITY"
        if int(r.get("LATEST_DAY_SOURCE_CHANGE_FLAG", 0)) == 1:
            return "LATEST_DAY_SOURCE_CHANGE"
        # Suppressed / hold categories.
        if int(r.get("NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG", 0)) == 1:
            return "SUPPRESSED_NORMAL_STABLE_SOURCE_CHANGE"
        if int(r.get("BULK_OR_REFRESH_SUPPRESSOR_FLAG", 0)) == 1:
            return "SUPPRESSED_BULK_OR_REFRESH_PATTERN"
        if int(r.get("LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG", 0)) == 1:
            return "DB_MISMATCH_CANDIDATE_STABLE_SOURCE_HISTORY"
        return "LOW_PRIORITY_SOURCE_HISTORY_SIGNAL"

    fm["PROBLEM_CLASS"] = fm.apply(problem_class, axis=1)

    fm["SUPPRESSION_REASON"] = ""
    fm.loc[fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] == 1, "SUPPRESSION_REASON"] = "NORMAL_STABLE_SOURCE_CHANGE"
    fm.loc[fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] == 1, "SUPPRESSION_REASON"] = "BULK_OR_REFRESH_PATTERN_AMONG_CANDIDATES"
    fm.loc[fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] == 1, "SUPPRESSION_REASON"] = "STABLE_SOURCE_HISTORY_AFTER_DB_MISMATCH_GATE"
    fm.loc[fm["HAS_CRITICAL_PROBLEM_FLAG"] == 1, "SUPPRESSION_REASON"] = ""

    fm["REPORT_FLAG"] = (
        (fm["SOURCE_PROBLEM_SEVERITY_SCORE"] >= float(min_report_score))
        & (fm["PROBLEM_CLASS"].str.startswith("SUPPRESSED") == False)
        & (fm["PROBLEM_CLASS"] != "DB_MISMATCH_CANDIDATE_STABLE_SOURCE_HISTORY")
    ).astype(int)

    fm["SOURCE_FEATURE_EVIDENCE_SUMMARY"] = fm.apply(
        lambda r: (
            f"{r['FEATURE']} latest source={short_value(r.get('LATEST_SOURCE_VALUE',''))}; "
            f"source changed on {int(r.get('SOURCE_CHANGE_DAYS_COUNT',0))}/{requested_days} days; "
            f"distinct source values={int(r.get('DISTINCT_SOURCE_VALUES_30D',0))}; "
            f"class={r['PROBLEM_CLASS']}; severity={float(r['SOURCE_PROBLEM_SEVERITY_SCORE']):.1f}."
        ),
        axis=1,
    )

    fm["RECOMMENDED_ACTION"] = fm["PROBLEM_CLASS"].map(recommended_action).fillna("Review source history and latest DB_MISMATCH context.")
    return fm.sort_values(["REPORT_FLAG", "SOURCE_PROBLEM_SEVERITY_SCORE"], ascending=[False, False]).reset_index(drop=True)


def recommended_action(problem_class: str) -> str:
    p = str(problem_class or "").upper()
    if "FALLBACK_TO_DEFAULT" in p:
        return "Investigate why the latest source value fell back to a known default; validate upstream feed/defaulting logic."
    if "INVALID_LATEST" in p:
        return "Validate latest source value against RAN parameter requirements; correct out-of-range value if confirmed."
    if "BACK_AND_FORTH" in p:
        return "Investigate repeated reversion/toggling in the source system; check competing loads or automation overwrites."
    if "HIGH_FREQUENCY" in p:
        return "Investigate high-frequency multi-value changes; check unstable source feed, repeated imports, or conflicting updates."
    if "SAME_DAY" in p:
        return "Investigate multiple same-day source values for the same ECGI/feature; check duplicate feed rows or inconsistent joins."
    if "PERSISTENT" in p:
        return "Review persistent source instability and determine whether it is planned network activity or unresolved data quality issue."
    if "LATEST_DAY" in p:
        return "Review latest-day source change in the context of the current DB_MISMATCH candidate."
    if "STABLE_SOURCE" in p:
        return "Source history is stable; if latest DB_MISMATCH remains important, next step is field-level source-vs-DB analysis."
    if "SUPPRESSED" in p:
        return "Suppressed as likely normal/stable or bulk-refresh behavior; keep for audit trace but do not prioritize."
    return "Manual review recommended."


def build_feature_metrics(
    candidates: pd.DataFrame,
    hist: pd.DataFrame,
    changes: pd.DataFrame,
    conflicts: pd.DataFrame,
    rules: Dict[str, Dict[str, Any]],
    analysis_info: Dict[str, Any],
    args: argparse.Namespace,
) -> pd.DataFrame:
    header("PHASE 1D/E/F - APPLY ABNORMAL RULES, SUPPRESSORS, AND ABSOLUTE SCORING")

    if hist.empty:
        raise RuntimeError("No source history metrics were produced for candidate ECGIs.")

    candidate_date = pd.to_datetime(analysis_info["candidate_date"]).normalize()
    change_stats = build_change_stats(changes, candidate_date, int(analysis_info.get("latest_db_mismatch_candidate_ecgis", 0) or 0))
    conflict_stats = build_conflict_stats(conflicts)

    fm = hist.copy()
    if not change_stats.empty:
        fm = fm.merge(change_stats, on=["ECGI", "FEATURE"], how="left")
    if not conflict_stats.empty:
        fm = fm.merge(conflict_stats, on=["ECGI", "FEATURE"], how="left")

    # Candidate latest mismatch support per ECGI.
    cand_cols = ["ECGI", "LATEST_DB_MISMATCH_RAW_ROWS", "LATEST_CANDIDATE_DATE"]
    cand_cols += [c for c in META_COLS if c in candidates.columns and c not in fm.columns]
    fm = fm.merge(candidates[[c for c in cand_cols if c in candidates.columns]], on="ECGI", how="left")
    fm["ECGI_LABEL"] = fm["ECGI"].map(excel_safe_ecgi)
    fm["ANALYSIS_DAYS"] = int(analysis_info.get("requested_days", args.days))
    fm["ANALYSIS_START_DATE"] = analysis_info["window_start_date"]
    fm["ANALYSIS_END_DATE"] = analysis_info["window_end_date"]

    fm = add_rule_flags_and_scores(
        feature_metrics=fm,
        rules=rules,
        analysis_info=analysis_info,
        high_frequency_days=args.high_frequency_days,
        high_frequency_distinct_values=args.high_frequency_distinct_values,
        persistent_days=args.persistent_days,
        min_reverses_for_backforth=args.min_reverses_for_backforth,
        min_aba_for_backforth=args.min_aba_for_backforth,
        default_min_days=args.default_min_days,
        stable_change_suppress_days=args.stable_change_suppress_days,
        bulk_change_ratio_threshold=args.bulk_change_ratio_threshold,
        min_report_score=args.min_report_score,
    )

    issue_counts = fm["PROBLEM_CLASS"].value_counts().to_dict()
    log(f"Feature metric rows scored: {len(fm):,}", indent=1)
    log(f"Problem-class counts: {issue_counts}", indent=1)
    log(f"Reportable feature incidents: {int(fm['REPORT_FLAG'].sum()):,}", indent=1)
    return fm


