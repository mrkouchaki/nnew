track2,routing:

SELECT
    TRUNC(CALL_DATE_UTC) AS call_date,
    MARKET,
    COUNTY,
    STATE,
    MME_NAME,
    TAC,
    USID,
    PSAP_ID,
    PSAP_NAME,
    FCC_PSAP_ID,
    ROUTE_PSAPID,
    ROUTE_PSAPNAME,
    ROUTE_FCC_PSAPID,
    COUNT(*) AS row_count,
    SUM(LSR_CALL_CNT) AS lsr_call_cnt,
    SUM(VOLTE_ATTEMPTS) AS volte_attempts,
    SUM(FAIL_LOCATE) AS fail_locate
FROM E911.E911_LTE_LSR_CSR_CD_MV
WHERE CALL_DATE_UTC >= TRUNC(SYSDATE) - 30
  AND (
        NVL(TO_CHAR(PSAP_ID), 'X') <> NVL(TO_CHAR(ROUTE_PSAPID), 'X')
        OR NVL(TO_CHAR(FCC_PSAP_ID), 'X') <> NVL(TO_CHAR(ROUTE_FCC_PSAPID), 'X')
      )
GROUP BY
    TRUNC(CALL_DATE_UTC),
    MARKET,
    COUNTY,
    STATE,
    MME_NAME,
    TAC,
    USID,
    PSAP_ID,
    PSAP_NAME,
    FCC_PSAP_ID,
    ROUTE_PSAPID,
    ROUTE_PSAPNAME,
    ROUTE_FCC_PSAPID
ORDER BY call_date DESC, fail_locate DESC, lsr_call_cnt DESC;



