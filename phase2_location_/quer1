daily kpi:

SELECT
    TRUNC(CALL_DATE_UTC) AS call_date,
    MARKET,
    MME_NAME,
    TAC,
    USID,
    SUM(VOLTE_ATTEMPTS) AS volte_attempts,
    SUM(LSR_CALL_CNT) AS lsr_call_cnt,
    SUM(P2_SUCCESS_COUNT) AS p2_success_count,
    SUM(FAIL_LOCATE) AS fail_locate,
    SUM(E2VALIDATED) AS e2validated,
    SUM(E2_CALLCOUNTS) AS e2_callcounts,
    SUM(DR_CNT) AS dr_cnt,
    SUM(DR_CALL_CNT) AS dr_call_cnt
FROM E911.E911_LTE_LSR_CSR_CD_MV
WHERE CALL_DATE_UTC >= TRUNC(SYSDATE) - 30
GROUP BY
    TRUNC(CALL_DATE_UTC),
    MARKET,
    MME_NAME,
    TAC,
    USID
ORDER BY call_date DESC;

calculated rate:

SELECT
    TRUNC(CALL_DATE_UTC) AS call_date,
    MARKET,
    MME_NAME,
    TAC,
    USID,

    SUM(VOLTE_ATTEMPTS) AS volte_attempts,
    SUM(LSR_CALL_CNT) AS lsr_call_cnt,
    SUM(P2_SUCCESS_COUNT) AS p2_success_count,
    SUM(FAIL_LOCATE) AS fail_locate,

    ROUND(SUM(P2_SUCCESS_COUNT) / NULLIF(SUM(VOLTE_ATTEMPTS), 0), 4) AS p2_success_rate,
    ROUND(SUM(FAIL_LOCATE) / NULLIF(SUM(LSR_CALL_CNT), 0), 4) AS fail_locate_rate,

    SUM(E2VALIDATED) AS e2validated,
    SUM(E2_CALLCOUNTS) AS e2_callcounts,
    ROUND(SUM(E2VALIDATED) / NULLIF(SUM(E2_CALLCOUNTS), 0), 4) AS e2_validation_rate,

    SUM(DR_CNT) AS dr_cnt,
    SUM(DR_CALL_CNT) AS dr_call_cnt,
    ROUND(SUM(DR_CNT) / NULLIF(SUM(DR_CALL_CNT), 0), 4) AS dr_rate
FROM E911.E911_LTE_LSR_CSR_CD_MV
WHERE CALL_DATE_UTC >= TRUNC(SYSDATE) - 30
GROUP BY
    TRUNC(CALL_DATE_UTC),
    MARKET,
    MME_NAME,
    TAC,
    USID
HAVING SUM(LSR_CALL_CNT) > 0
ORDER BY fail_locate_rate DESC, lsr_call_cnt DESC;


