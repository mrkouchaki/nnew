============================================================
-- E911 FAST EXPORT - SQLPLUS V4
-- Purpose:
--   Fast, quiet SQL*Plus export for ML datasets.
--
-- Important changes vs previous version:
--   1) Suppresses row printing to terminal during spool: SET TERMOUT OFF.
--   2) Removes raw 47M-detail export.
--   3) Exports compact aggregates that still preserve all needed issue counts.
--   4) Removes expensive/unnecessary COUNT DISTINCT fields from main KPI export.
--   5) Removes ORDER BY from large exports.
--   6) Uses known real columns only.
--
-- Run:
--   sqlplus username/password@connection @C:\Temp\e911_fast_export_sqlplus_v4.sql
--
-- Output:
--   C:\Temp\*_v4.csv
-- ============================================================

WHENEVER OSERROR EXIT FAILURE
WHENEVER SQLERROR EXIT SQL.SQLCODE

SET ECHO OFF
SET FEEDBACK OFF
SET VERIFY OFF
SET HEADING ON
SET PAGESIZE 0
SET LINESIZE 32767
SET LONG 1000000
SET LONGCHUNKSIZE 32767
SET TRIMSPOOL ON
SET TRIMOUT ON
SET TAB OFF
SET RECSEP OFF
SET FLUSH OFF
SET ARRAYSIZE 5000
SET SQLBLANKLINES ON
SET MARKUP CSV ON DELIMITER , QUOTE ON

ALTER SESSION SET NLS_DATE_FORMAT = 'YYYY-MM-DD HH24:MI:SS';

DEFINE OUT_DIR = C:\Temp
DEFINE START_DATE = 2026-05-24
DEFINE END_DATE   = 2026-06-23

PROMPT 0/6 run info
SET TERMOUT OFF
SPOOL &OUT_DIR\e911_export_run_info_v4.csv
SELECT SYSDATE AS export_time, DATE '&START_DATE' AS start_date, DATE '&END_DATE' AS end_date_exclusive FROM dual;
SPOOL OFF
SET TERMOUT ON

PROMPT 1/6 LSR useful columns
SET TERMOUT OFF
SPOOL &OUT_DIR\e911_lsr_useful_columns_v4.csv
SELECT table_name, column_id, column_name, data_type FROM all_tab_columns WHERE owner = 'E911' AND table_name = 'E911_LTE_LSR_CSR_CD' AND REGEXP_LIKE(UPPER(column_name), 'USID|TAC|PSAP|ROUTE|FAIL|RESULT|POS|LSR|P2|E2|DR|MME|MARKET|CALL') ORDER BY column_id;
SPOOL OFF
SET TERMOUT ON

PROMPT 2/6 CSSNG ECGI-to-USID bridge
SET TERMOUT OFF
SPOOL &OUT_DIR\e911_cssng_ecgi_usid_bridge_v4.csv
SELECT /*+ parallel(c 4) */ ECGI, USID, MARKET, MARKETCLUSTER, REGION, SITE_ADRESS, SITE_CITY, SITE_STATE, SITE_COUNTY, SITE_ZIP, PSAP_NAME, FCC_PSAP_ID, PSAP_ACTIVE, CID, BAND, CARRIERS, TYPE, SLT_GPS_LATITUDE, SLT_GPS_LONGITUDE, STRC_TOWERLATITUDE, STRC_TOWERLONGITUDE, ANTENNA_AMSL, ANTENNA_AGL, ANTENNA_HORIZONTAL_BEAMWIDTH, ANTENNA_COVERAGE_ANGLE, ANTENNA_RADIUS_CENTER, MORPHOLOGY_TYPE, STRUCTURE_HEIGHT, STRUCTURE_TYPE, IS_DAS_SECTOR, IS_OUTDOOR_DAS, DATE_LIVE_PH1, DATE_LIVE_PH2 FROM E911.CSSNG_DATA_ADDITION c WHERE ECGI IS NOT NULL AND USID IS NOT NULL;
SPOOL OFF
SET TERMOUT ON

PROMPT 3/6 Main LSR daily KPI aggregate by USID+TAC
SET TERMOUT OFF
SPOOL &OUT_DIR\e911_lsr_daily_usid_tac_kpi_v4.csv
SELECT /*+ parallel(t 4) */ TRUNC(CALL_DATE_UTC) AS call_date, MARKET, MARKET_CLUSTER, REGION, COUNTY, STATE, MME_VENDOR, MME_POOL_NAME, MME_NAME, TAC, USID, PSAP_ID, PSAP_NAME, FCC_PSAP_ID, ROUTE_ESZ, ROUTE_PSAPID, ROUTE_PSAPNAME, CALL_TYPE, SLR_ORIG_NODE, SUM(NVL(VOLTE_ATTEMPTS,0)) AS volte_attempts, SUM(NVL(LSR_CALL_CNT,0)) AS lsr_call_cnt, SUM(NVL(P2_SUCCESS_COUNT,0)) AS p2_success_count, SUM(NVL(FAIL_LOCATE,0)) AS fail_locate, ROUND(SUM(NVL(P2_SUCCESS_COUNT,0)) / NULLIF(SUM(NVL(VOLTE_ATTEMPTS,0)),0), 6) AS p2_success_rate, ROUND(SUM(NVL(FAIL_LOCATE,0)) / NULLIF(SUM(NVL(LSR_CALL_CNT,0)),0), 6) AS fail_locate_rate, SUM(NVL(E2VALIDATED,0)) AS e2validated, SUM(NVL(E2_CALLCOUNTS,0)) AS e2_callcounts, ROUND(SUM(NVL(E2VALIDATED,0)) / NULLIF(SUM(NVL(E2_CALLCOUNTS,0)),0), 6) AS e2_validation_rate, SUM(NVL(DR_CNT,0)) AS dr_cnt, SUM(NVL(DR_CALL_CNT,0)) AS dr_call_cnt, ROUND(SUM(NVL(DR_CNT,0)) / NULLIF(SUM(NVL(DR_CALL_CNT,0)),0), 6) AS dr_rate, COUNT(*) AS raw_row_count FROM E911.E911_LTE_LSR_CSR_CD t WHERE CALL_DATE_UTC >= DATE '&START_DATE' AND CALL_DATE_UTC < DATE '&END_DATE' GROUP BY TRUNC(CALL_DATE_UTC), MARKET, MARKET_CLUSTER, REGION, COUNTY, STATE, MME_VENDOR, MME_POOL_NAME, MME_NAME, TAC, USID, PSAP_ID, PSAP_NAME, FCC_PSAP_ID, ROUTE_ESZ, ROUTE_PSAPID, ROUTE_PSAPNAME, CALL_TYPE, SLR_ORIG_NODE HAVING SUM(NVL(LSR_CALL_CNT,0) + NVL(VOLTE_ATTEMPTS,0)) > 0;
SPOOL OFF
SET TERMOUT ON

PROMPT 4/6 Main issue counts by USID+TAC
SET TERMOUT OFF
SPOOL &OUT_DIR\e911_lsr_daily_usid_tac_issue_counts_v4.csv
SELECT /*+ parallel(t 4) */ TRUNC(CALL_DATE_UTC) AS call_date, MARKET, MARKET_CLUSTER, REGION, COUNTY, STATE, MME_NAME, TAC, USID, SUM(NVL(VOLTE_ATTEMPTS,0)) AS volte_attempts, SUM(NVL(LSR_CALL_CNT,0)) AS lsr_call_cnt, SUM(NVL(P2_SUCCESS_COUNT,0)) AS p2_success_count, SUM(NVL(FAIL_LOCATE,0)) AS fail_locate, SUM(CASE WHEN NVL(FAIL_LOCATE,0) > 0 THEN NVL(FAIL_LOCATE,0) ELSE 0 END) AS fail_locate_cnt, SUM(CASE WHEN NVL(VOLTE_ATTEMPTS,0) > 0 AND NVL(P2_SUCCESS_COUNT,0) = 0 THEN NVL(VOLTE_ATTEMPTS,0) ELSE 0 END) AS p2_zero_success_cnt, SUM(CASE WHEN UPPER(NVL(PL_RESULT_CODE,'X')) <> 'DIAMETER_SUCCESS(2001)' THEN CASE WHEN NVL(VOLTE_ATTEMPTS,0) > 0 THEN VOLTE_ATTEMPTS WHEN NVL(LSR_CALL_CNT,0) > 0 THEN LSR_CALL_CNT ELSE 1 END ELSE 0 END) AS pl_error_cnt, SUM(CASE WHEN UPPER(NVL(PL_RESULT_CODE,'X')) LIKE '%POSITIONING_FAILED%' THEN CASE WHEN NVL(VOLTE_ATTEMPTS,0) > 0 THEN VOLTE_ATTEMPTS WHEN NVL(LSR_CALL_CNT,0) > 0 THEN LSR_CALL_CNT ELSE 1 END ELSE 0 END) AS positioning_failed_cnt, SUM(CASE WHEN UPPER(NVL(POS_METHOD_USED,'X')) = 'FAILURE' THEN CASE WHEN NVL(VOLTE_ATTEMPTS,0) > 0 THEN VOLTE_ATTEMPTS WHEN NVL(LSR_CALL_CNT,0) > 0 THEN LSR_CALL_CNT ELSE 1 END ELSE 0 END) AS pos_method_failure_cnt, SUM(CASE WHEN NVL(TO_CHAR(PSAP_ID),'X') <> NVL(TO_CHAR(ROUTE_PSAPID),'X') THEN CASE WHEN NVL(LSR_CALL_CNT,0) > 0 THEN LSR_CALL_CNT WHEN NVL(VOLTE_ATTEMPTS,0) > 0 THEN VOLTE_ATTEMPTS ELSE 1 END ELSE 0 END) AS route_psap_mismatch_cnt, COUNT(*) AS raw_row_count FROM E911.E911_LTE_LSR_CSR_CD t WHERE CALL_DATE_UTC >= DATE '&START_DATE' AND CALL_DATE_UTC < DATE '&END_DATE' GROUP BY TRUNC(CALL_DATE_UTC), MARKET, MARKET_CLUSTER, REGION, COUNTY, STATE, MME_NAME, TAC, USID HAVING SUM(NVL(FAIL_LOCATE,0)) > 0 OR SUM(CASE WHEN NVL(VOLTE_ATTEMPTS,0) > 0 AND NVL(P2_SUCCESS_COUNT,0) = 0 THEN NVL(VOLTE_ATTEMPTS,0) ELSE 0 END) > 0 OR SUM(CASE WHEN UPPER(NVL(PL_RESULT_CODE,'X')) <> 'DIAMETER_SUCCESS(2001)' THEN 1 ELSE 0 END) > 0 OR SUM(CASE WHEN UPPER(NVL(POS_METHOD_USED,'X')) = 'FAILURE' THEN 1 ELSE 0 END) > 0 OR SUM(CASE WHEN NVL(TO_CHAR(PSAP_ID),'X') <> NVL(TO_CHAR(ROUTE_PSAPID),'X') THEN 1 ELSE 0 END) > 0;
SPOOL OFF
SET TERMOUT ON

PROMPT 5/6 Route instability by USID+TAC
SET TERMOUT OFF
SPOOL &OUT_DIR\e911_route_instability_usid_tac_v4.csv
SELECT /*+ parallel(t 4) */ MARKET, MARKET_CLUSTER, TAC, USID, COUNT(DISTINCT ROUTE_PSAPID) AS distinct_route_psapid, COUNT(DISTINCT ROUTE_PSAPNAME) AS distinct_route_psapname, COUNT(DISTINCT PSAP_ID) AS distinct_expected_psapid, COUNT(DISTINCT FCC_PSAP_ID) AS distinct_expected_fcc_psapid, SUM(NVL(LSR_CALL_CNT,0)) AS lsr_call_cnt, SUM(NVL(VOLTE_ATTEMPTS,0)) AS volte_attempts, SUM(NVL(FAIL_LOCATE,0)) AS fail_locate, COUNT(*) AS raw_row_count, MIN(CALL_DATE_UTC) AS first_seen, MAX(CALL_DATE_UTC) AS last_seen FROM E911.E911_LTE_LSR_CSR_CD t WHERE CALL_DATE_UTC >= DATE '&START_DATE' AND CALL_DATE_UTC < DATE '&END_DATE' GROUP BY MARKET, MARKET_CLUSTER, TAC, USID HAVING COUNT(DISTINCT ROUTE_PSAPID) > 1 OR COUNT(DISTINCT PSAP_ID) > 1 OR COUNT(DISTINCT FCC_PSAP_ID) > 1;
SPOOL OFF
SET TERMOUT ON

PROMPT 6/6 PSAP reference
SET TERMOUT OFF
SPOOL &OUT_DIR\e911_gmlc_psap_reference_v4.csv
SELECT GMLC_VENDOR, FCC_PSAP_ID, GMLC_PSAP_ID, PSAP_NAME FROM E911.E911_GMLC_PSAP;
SPOOL OFF
SET TERMOUT ON

SET MARKUP CSV OFF
PROMPT DONE. Check C:\Temp files ending with _v4.csv
EXIT
