def train_and_score(dataset: pd.DataFrame, train_pool: pd.DataFrame, rare_df: pd.DataFrame, out_dir: Path, args: argparse.Namespace) -> Dict[str, Any]:
    header("STEP 2 - TRAIN / EVALUATE / SCORE V6 PROBLEM-STATE MODEL")
    backend, ModelClass = get_backend(args.model)
    log(f"Selected backend: {backend}", indent=1)
    features, categorical_features, numeric_features = select_feature_columns(train_pool, include_rule_flags=args.include_rule_flags)
    log(f"Model feature count: {len(features):,}", indent=1)
    log(f"Categorical features: {categorical_features}", indent=1)
    log(f"Numeric feature count: {len(numeric_features):,}", indent=1)

    train_df, test_df = train_test_split_safe(train_pool, "FINAL_TRAINING_LABEL", args.test_size, args.random_state)
    train_model_df, valid_model_df = train_test_split_safe(train_df, "FINAL_TRAINING_LABEL", args.eval_size, args.random_state + 17)
    log(f"Train rows total: {len(train_df):,}", indent=1)
    log(f"Model-train rows: {len(train_model_df):,}", indent=1)
    log(f"Validation rows: {len(valid_model_df):,}", indent=1)
    log(f"Test rows: {len(test_df):,}", indent=1)

    model = fit_model(train_model_df, valid_model_df, "FINAL_TRAINING_LABEL", features, categorical_features, backend, ModelClass, args)
    pseudo_df = pd.DataFrame()
    if args.enable_pseudo_labeling:
        train_keys = set(zip(train_pool["ECGI"].astype(str), train_pool["FEATURE"].astype(str)))
        all_unlabeled = dataset[~dataset.apply(lambda r: (str(r["ECGI"]), str(r["FEATURE"])) in train_keys, axis=1)].copy()
        model, pseudo_df = pseudo_label_and_retrain(model, backend, train_model_df, valid_model_df, all_unlabeled, features, categorical_features, ModelClass, args)

    test_pred = predict_model(model, backend, test_df, features, categorical_features)
    test_metrics = evaluate_predictions(test_df["FINAL_TRAINING_LABEL"], test_pred, out_dir, "cesmlc_v6_ml")
    test_output = pd.concat([test_df.reset_index(drop=True), test_pred.reset_index(drop=True)], axis=1)
    test_output.to_csv(out_dir / "cesmlc_v6_ml_test_predictions.csv", index=False)
    log(f"Test metrics: {test_metrics}", indent=1)

    all_pred = predict_model(model, backend, dataset, features, categorical_features)
    scored = pd.concat([dataset.reset_index(drop=True), all_pred.reset_index(drop=True)], axis=1)
    scored = add_score_columns(scored)
    scored = scored.sort_values("ML_FINAL_PROBLEM_SCORE", ascending=False).reset_index(drop=True)
    scored.insert(0, "ML_PROBLEM_RANK", np.arange(1, len(scored) + 1))
    scored.to_csv(out_dir / "cesmlc_v6_ml_scores_all.csv", index=False)
    scored.head(args.top_n).to_csv(out_dir / "cesmlc_v6_ml_scores_top300.csv", index=False)

    feature_importance = get_feature_importance(model, backend, features)
    feature_importance.to_csv(out_dir / "cesmlc_v6_ml_feature_importance.csv", index=False)

    artifact = {
        "script_version": SCRIPT_VERSION,
        "backend": backend,
        "features": features,
        "categorical_features": categorical_features,
        "numeric_features": numeric_features,
        "include_rule_flags": bool(args.include_rule_flags),
        "model": model,
        "test_metrics": test_metrics,
        "problem_labels": sorted(PROBLEM_LABELS),
        "suppressor_labels": sorted(SUPPRESSOR_LABELS),
        "created_at": time.strftime("%Y-%m-%d %H:%M:%S"),
    }
    artifact_path = out_dir / "cesmlc_v6_problem_state_model_artifact.pkl"
    with open(artifact_path, "wb") as f:
        pickle.dump(artifact, f)
    log(f"Saved model artifact: {artifact_path}", indent=1)

    # Report tables.
    label_summary = train_pool.groupby(["FINAL_TRAINING_LABEL", "LABEL_SOURCE_FOR_MODEL"], as_index=False).agg(
        ROW_COUNT=("ECGI", "size"),
        UNIQUE_ECGI=("ECGI", "nunique"),
        AVG_WEIGHT=("TRAINING_WEIGHT", "mean"),
        AVG_CONFIDENCE=("SEED_LABEL_CONFIDENCE", "mean"),
    ).sort_values("ROW_COUNT", ascending=False)
    label_summary.to_csv(out_dir / "cesmlc_v6_ml_training_label_summary.csv", index=False)

    model_info = {
        "backend": backend,
        "features": features,
        "categorical_features": categorical_features,
        "numeric_features": numeric_features,
        "include_rule_flags": bool(args.include_rule_flags),
        "test_metrics": test_metrics,
        "artifact_path": str(artifact_path),
    }
    write_training_report(out_dir, dataset, train_pool, scored, model_info, rare_df, pseudo_df)
    return model_info


def score_mode(dataset_path: Path, artifact_path: Path, out_dir: Path, top_n: int) -> None:
    header("SCORE MODE - LOAD V6 MODEL ARTIFACT AND SCORE DATASET")
    dataset = read_csv_clean(dataset_path)
    with open(artifact_path, "rb") as f:
        artifact = pickle.load(f)
    model = artifact["model"]
    backend = artifact["backend"]
    features = artifact["features"]
    categorical_features = artifact["categorical_features"]
    pred = predict_model(model, backend, dataset, features, categorical_features)
    scored = pd.concat([dataset.reset_index(drop=True), pred.reset_index(drop=True)], axis=1)
    scored = add_score_columns(scored)
    scored = scored.sort_values("ML_FINAL_PROBLEM_SCORE", ascending=False).reset_index(drop=True)
    scored.insert(0, "ML_PROBLEM_RANK", np.arange(1, len(scored) + 1))
    out_dir.mkdir(parents=True, exist_ok=True)
    scored.to_csv(out_dir / "cesmlc_v6_scored_dataset_all.csv", index=False)
    scored.head(top_n).to_csv(out_dir / "cesmlc_v6_scored_dataset_top.csv", index=False)
    log(f"Scored rows: {len(scored):,}", indent=1)
    log(f"Output: {out_dir / 'cesmlc_v6_scored_dataset_top.csv'}", indent=1)


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="CESMLC V6 weak/semi-supervised problem-state model trainer.")
    p.add_argument("--mode", default="train", choices=["train", "score"], help="train or score")
    p.add_argument("--dataset", required=True, type=str, help="V6 seed-label dataset CSV or scoring dataset.")
    p.add_argument("--out-dir", required=True, type=str, help="Output folder.")
    p.add_argument("--manual-labels", default=None, type=str, help="Optional manual label CSV with ECGI, FEATURE, MANUAL_LABEL.")
    p.add_argument("--model-artifact", default=None, type=str, help="Existing artifact for --mode score.")

    p.add_argument("--model", default="auto", choices=["auto", "catboost", "lightgbm", "sklearn_rf", "tabnet"])
    p.add_argument("--test-size", default=0.25, type=float)
    p.add_argument("--eval-size", default=0.20, type=float)
    p.add_argument("--random-state", default=42, type=int)
    p.add_argument("--min-class-count", default=20, type=int, help="Drop seed labels with fewer rows unless --keep-rare-labels is used.")
    p.add_argument("--keep-rare-labels", action="store_true")
    p.add_argument("--include-hold-labels", action="store_true", help="Train on hold/needs-review labels. Default excludes them unless manual.")
    p.add_argument("--include-rule-flags", action="store_true", help="Include direct seed-rule indicator flags. Off by default to avoid memorizing seed rules.")

    p.add_argument("--iterations", default=1000, type=int)
    p.add_argument("--depth", default=6, type=int)
    p.add_argument("--learning-rate", default=0.04, type=float)
    p.add_argument("--num-leaves", default=63, type=int)
    p.add_argument("--early-stopping-rounds", default=80, type=int)
    p.add_argument("--train-verbose", default=25, type=int)

    p.add_argument("--rf-estimators", default=400, type=int)
    p.add_argument("--rf-max-depth", default=0, type=int)
    p.add_argument("--rf-min-samples-leaf", default=2, type=int)
    p.add_argument("--onehot-min-frequency", default=5, type=int)

    p.add_argument("--tabnet-epochs", default=120, type=int)
    p.add_argument("--tabnet-batch-size", default=2048, type=int)
    p.add_argument("--tabnet-lr", default=0.01, type=float)

    p.add_argument("--enable-pseudo-labeling", action="store_true")
    p.add_argument("--pseudo-label-min-confidence", default=0.92, type=float)
    p.add_argument("--pseudo-label-weight", default=0.35, type=float)
    p.add_argument("--pseudo-label-max-rows", default=100000, type=int)

    p.add_argument("--top-n", default=300, type=int)
    return p.parse_args()


def main() -> int:
    args = parse_args()
    out_dir = Path(args.out_dir).expanduser()
    out_dir.mkdir(parents=True, exist_ok=True)
    dataset_path = Path(args.dataset).expanduser()
    if not dataset_path.exists():
        raise FileNotFoundError(f"Dataset not found: {dataset_path}")

    if args.mode == "score":
        if not args.model_artifact:
            raise ValueError("--mode score requires --model-artifact")
        artifact_path = Path(args.model_artifact).expanduser()
        if not artifact_path.exists():
            raise FileNotFoundError(f"Model artifact not found: {artifact_path}")
        score_mode(dataset_path, artifact_path, out_dir, args.top_n)
        return 0

    header("CESMLC V6 PROBLEM-STATE WEAK/SEMI-SUPERVISED ML TRAINER")
    log(f"Dataset: {dataset_path}")
    log(f"Output: {out_dir}")
    log(f"Model choice: {args.model}")
    log(f"Direct seed-rule flags included: {bool(args.include_rule_flags)}")
    log(f"Pseudo-labeling enabled: {bool(args.enable_pseudo_labeling)}")

    manual_path = Path(args.manual_labels).expanduser() if args.manual_labels else None
    dataset, train_pool, rare_df = load_and_prepare_dataset(
        dataset_path=dataset_path,
        manual_labels_path=manual_path,
        min_class_count=args.min_class_count,
        keep_rare_labels=args.keep_rare_labels,
        exclude_hold_labels=not args.include_hold_labels,
    )
    dataset.to_csv(out_dir / "cesmlc_v6_ml_input_dataset_with_final_labels.csv", index=False)
    train_pool.to_csv(out_dir / "cesmlc_v6_ml_training_pool.csv", index=False)
    rare_df.to_csv(out_dir / "cesmlc_v6_ml_rare_labels.csv", index=False)

    model_info = train_and_score(dataset, train_pool, rare_df, out_dir, args)
    config = vars(args).copy()
    config["script_version"] = SCRIPT_VERSION
    config["model_info"] = {k: v for k, v in model_info.items() if k not in {"features", "categorical_features", "numeric_features"}}
    (out_dir / "cesmlc_v6_ml_run_config.json").write_text(json.dumps(config, indent=2, default=str), encoding="utf-8")

    header("DONE")
    log(f"Total runtime: {elapsed_text()}")
    log(f"Open first: {out_dir / 'cesmlc_v6_ml_training_report.md'}")
    log(f"Open second: {out_dir / 'cesmlc_v6_ml_scores_top300.csv'}")
    log(f"Open third: {out_dir / 'cesmlc_v6_ml_feature_importance.csv'}")
    log(f"Deployable artifact: {out_dir / 'cesmlc_v6_problem_state_model_artifact.pkl'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())