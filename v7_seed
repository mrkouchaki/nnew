RUN_START_TIME = time.time()


def elapsed_text() -> str:
    seconds = int(time.time() - RUN_START_TIME)
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def log(message: str, indent: int = 0) -> None:
    prefix = "  " * max(0, int(indent))
    print(f"[{time.strftime('%H:%M:%S')} | +{elapsed_text()}] {prefix}{message}", flush=True)


def header(title: str) -> None:
    print("\n" + "=" * 100, flush=True)
    log(title)
    print("=" * 100, flush=True)


def clean_col_name(c: object) -> str:
    return str(c).strip().strip('"').upper()


def normalize_key_value(x: object) -> str:
    if pd.isna(x):
        return ""
    s = str(x).strip().strip('"')
    if s.upper() in NULL_STRINGS:
        return ""
    s = re.sub(r"\.0$", "", s)
    s = re.sub(r"\s+", "", s)
    return s.upper()


def normalize_value_text(x: object) -> str:
    if pd.isna(x):
        return ""
    s = str(x).strip().strip('"')
    if s.upper() in NULL_STRINGS:
        return ""
    try:
        f = float(s)
        if math.isfinite(f):
            if abs(f - round(f)) < 1e-12:
                return str(int(round(f)))
            return f"{f:.10f}".rstrip("0").rstrip(".").upper()
    except Exception:
        pass
    s = re.sub(r"\s+", "", s)
    return s.upper()


def excel_safe_ecgi(ecgi: object) -> str:
    s = normalize_key_value(ecgi)
    return f"ECGI_{s}" if s else ""


def short_value(v: object, max_len: int = 80) -> str:
    if pd.isna(v):
        return "<missing>"
    s = str(v)
    return s if len(s) <= max_len else s[: max_len - 3] + "..."


def transition_text(prev_value: object, current_value: object) -> str:
    return f"{short_value(prev_value)} -> {short_value(current_value)}"


def date_text(d: object) -> str:
    dt = pd.to_datetime(d, errors="coerce")
    if pd.isna(dt):
        return ""
    return str(dt.date())


def safe_numeric(series: Any, default: float = 0.0) -> pd.Series:
    if not isinstance(series, pd.Series):
        series = pd.Series(series)
    return pd.to_numeric(series, errors="coerce").replace([np.inf, -np.inf], np.nan).fillna(default)


def percentile_rank(series: pd.Series) -> pd.Series:
    s = safe_numeric(series)
    if len(s) == 0:
        return s
    if s.nunique(dropna=False) <= 1:
        return pd.Series(np.ones(len(s)) * 50.0, index=s.index)
    return s.rank(method="average", pct=True) * 100.0


def first_existing(cols: Iterable[str], candidates: Iterable[str]) -> Optional[str]:
