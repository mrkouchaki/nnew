        "latlon_decimals": int(getattr(args, "latlon_decimals", 5)),
        "enable_db_push_check": bool(getattr(args, "enable_db_push_check", False)),
        "server_id_filter": analysis_info.get("server_id_filter", ""),
    }


def manifest_hash(manifest: Dict[str, Any]) -> str:
    raw = json.dumps(manifest, sort_keys=True, default=str).encode("utf-8")
    return hashlib.sha256(raw).hexdigest()[:16]


def default_history_cache_dir(out_dir: Path, args: argparse.Namespace) -> Path:
    raw = getattr(args, "history_cache_dir", None)
    return Path(raw).expanduser() if raw else out_dir / "history_cache"


def save_history_cache(cache_dir: Path, manifest: Dict[str, Any], candidates: pd.DataFrame, hist: pd.DataFrame, changes: pd.DataFrame, conflicts: pd.DataFrame) -> None:
    cache_dir.mkdir(parents=True, exist_ok=True)
    mh = manifest_hash(manifest)
    payload = {
        "manifest": manifest,
        "manifest_hash": mh,
        "created_at": time.strftime("%Y-%m-%d %H:%M:%S"),
        "rows": {
            "candidates": int(len(candidates)),
            "hist": int(len(hist)),
            "changes": int(len(changes)),
            "conflicts": int(len(conflicts)),
        },
    }
    (cache_dir / "history_cache_manifest.json").write_text(json.dumps(payload, indent=2, default=str), encoding="utf-8")
    candidates.to_pickle(cache_dir / "candidate_ecgis.pkl")
    hist.to_pickle(cache_dir / "source_feature_history_metrics.pkl")
    changes.to_pickle(cache_dir / "source_change_events.pkl")
    conflicts.to_pickle(cache_dir / "source_same_day_conflicts.pkl")
    log(f"Saved persistent Phase 1C history cache: {cache_dir} (hash={mh})", indent=1)


def load_history_cache_if_valid(cache_dir: Path, expected_manifest: Dict[str, Any], force_rebuild: bool = False) -> Optional[Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]]:
    if force_rebuild:
        return None
    manifest_path = cache_dir / "history_cache_manifest.json"
    files = [
        cache_dir / "candidate_ecgis.pkl",
        cache_dir / "source_feature_history_metrics.pkl",
        cache_dir / "source_change_events.pkl",
        cache_dir / "source_same_day_conflicts.pkl",
    ]
    if not manifest_path.exists() or not all(p.exists() for p in files):
        return None
    try:
        payload = json.loads(manifest_path.read_text(encoding="utf-8"))
    except Exception:
        return None
    expected_hash = manifest_hash(expected_manifest)
    if payload.get("manifest_hash") != expected_hash:
        log(f"History cache exists but does not match this run. cache_hash={payload.get('manifest_hash')} expected={expected_hash}", indent=1)
        return None
    try:
        candidates = pd.read_pickle(files[0])
        hist = pd.read_pickle(files[1])
        changes = pd.read_pickle(files[2])
        conflicts = pd.read_pickle(files[3])
    except Exception as exc:
        log(f"Could not load history cache; rebuilding. Error: {exc}", indent=1)
        return None
    log(f"Loaded persistent Phase 1C history cache: {cache_dir} (hash={expected_hash})", indent=1)
    log(f"Cached rows: candidates={len(candidates):,}, hist={len(hist):,}, changes={len(changes):,}, conflicts={len(conflicts):,}", indent=1)
    return candidates, hist, changes, conflicts


def add_isolation_forest_scores(dataset: pd.DataFrame, args: argparse.Namespace) -> pd.DataFrame:
    """Optional unsupervised outlier score on engineered problem-state features.

    This does not create labels. It adds a small ranking signal so V7 can push unusual feature histories upward
    without turning the system back into a generic change counter.
    """
    fm = dataset.copy()
    fm["UNSUPERVISED_ISOF_SCORE"] = np.nan
    fm["UNSUPERVISED_ISOF_PERCENTILE"] = np.nan
    fm["UNSUPERVISED_ISOF_TOP_FLAG"] = 0
    if not getattr(args, "enable_isolation_forest", False):
        return fm
    try:
        from sklearn.ensemble import IsolationForest
        from sklearn.impute import SimpleImputer
        from sklearn.pipeline import Pipeline
        from sklearn.preprocessing import RobustScaler
    except Exception as exc:
        log(f"IsolationForest skipped because sklearn components are unavailable: {exc}", indent=1)
        return fm

    exclude_patterns = ["LABEL", "VALUE", "DATE", "SUMMARY", "ACTION", "REASON", "SOURCE_FILE", "SOURCE_NAME", "REFERENCE_COLUMN", "ECGI", "CELLNAME"]
    numeric_cols = []
    for c in fm.columns:
        if any(pat in c for pat in exclude_patterns):
            continue
        if pd.api.types.is_numeric_dtype(fm[c]):
            numeric_cols.append(c)
        else:
            maybe = pd.to_numeric(fm[c], errors="coerce")
            if maybe.notna().mean() > 0.90:
                fm[c] = maybe
                numeric_cols.append(c)
    numeric_cols = sorted(set(numeric_cols))
    if len(numeric_cols) < 5 or len(fm) < 50:
        log("IsolationForest skipped: not enough numeric features/rows.", indent=1)
        return fm

    sample_n = int(getattr(args, "isolation_fit_sample", 300000))
    fit_df = fm[numeric_cols]
    if len(fit_df) > sample_n > 0:
        fit_df = fit_df.sample(n=sample_n, random_state=int(getattr(args, "random_state", 42)))
    log(f"Fitting IsolationForest on {len(fit_df):,} sampled rows and {len(numeric_cols):,} numeric features", indent=1)
    pipe = Pipeline([
        ("imputer", SimpleImputer(strategy="median")),
        ("scaler", RobustScaler()),
        ("model", IsolationForest(
            n_estimators=int(getattr(args, "isolation_n_estimators", 200)),
            contamination="auto",
            random_state=int(getattr(args, "random_state", 42)),
            n_jobs=-1,
        )),
    ])
    pipe.fit(fit_df[numeric_cols].replace([np.inf, -np.inf], np.nan))
    raw = -pipe.named_steps["model"].score_samples(
        pipe.named_steps["scaler"].transform(
            pipe.named_steps["imputer"].transform(fm[numeric_cols].replace([np.inf, -np.inf], np.nan))
        )
    )
    fm["UNSUPERVISED_ISOF_SCORE"] = raw
    fm["UNSUPERVISED_ISOF_PERCENTILE"] = percentile_rank(pd.Series(raw, index=fm.index))
    fm["UNSUPERVISED_ISOF_TOP_FLAG"] = (fm["UNSUPERVISED_ISOF_PERCENTILE"] >= float(getattr(args, "isolation_top_percentile", 98.0))).astype(int)
    # Small bump only. Rules still dominate.
    fm["SEED_RULE_SCORE_BASE"] = safe_numeric(fm.get("SEED_RULE_SCORE", 0))
    bump = float(getattr(args, "isolation_score_weight", 0.10)) * (fm["UNSUPERVISED_ISOF_PERCENTILE"].fillna(0) / 100.0) * 20.0
    fm["SEED_RULE_SCORE"] = (fm["SEED_RULE_SCORE_BASE"] + bump).clip(lower=0)
    fm["SEED_RULE_PERCENTILE"] = percentile_rank(fm["SEED_RULE_SCORE"])
    log(f"IsolationForest scoring added. Top-flag rows: {int(fm['UNSUPERVISED_ISOF_TOP_FLAG'].sum()):,}", indent=1)
    return fm

def build_training_dataset(candidates: pd.DataFrame, hist: pd.DataFrame, changes: pd.DataFrame, conflicts: pd.DataFrame, rules: Dict[str, Dict[str, Any]], analysis_info: Dict[str, Any], args: argparse.Namespace) -> pd.DataFrame:
    header("PHASE 1D/E/F - CREATE SEED-LABELED MODEL DATASET")
    if hist.empty:
        raise RuntimeError("No source history metrics were produced for candidate ECGIs.")
    candidate_date = pd.to_datetime(analysis_info["candidate_date"]).normalize()
    change_stats = build_change_stats(changes, candidate_date, int(analysis_info.get("latest_db_mismatch_candidate_ecgis", 0) or 0))
    conflict_stats = build_conflict_stats(conflicts)

    fm = hist.copy()
    if not change_stats.empty:
        fm = fm.merge(change_stats, on=["ECGI", "FEATURE"], how="left")
    if not conflict_stats.empty:
        fm = fm.merge(conflict_stats, on=["ECGI", "FEATURE"], how="left")

    cand_cols = ["ECGI", "LATEST_DB_MISMATCH_RAW_ROWS", "LATEST_CANDIDATE_DATE"]
    for m in META_COLS + CANDIDATE_CONTEXT_COLS:
        mm = clean_col_name(m)
        if mm in candidates.columns and mm not in fm.columns and mm not in cand_cols:
            cand_cols.append(mm)
    fm = fm.merge(candidates[[c for c in cand_cols if c in candidates.columns]], on="ECGI", how="left")
    fm["ECGI_LABEL"] = fm["ECGI"].map(excel_safe_ecgi)
    fm["ANALYSIS_DAYS"] = int(analysis_info.get("requested_days", args.days))
    fm["ANALYSIS_START_DATE"] = analysis_info["window_start_date"]
    fm["ANALYSIS_END_DATE"] = analysis_info["window_end_date"]

    fm = add_seed_labels(fm, rules, analysis_info, args)
    fm = attach_reference_compatibility(fm, rules, args)
    fm = add_isolation_forest_scores(fm, args)
    log(f"Feature rows with seed labels: {len(fm):,}", indent=1)
    log(f"Seed-label distribution: {fm['SEED_LABEL'].value_counts().to_dict()}", indent=1)
    log(f"Rows marked trainable: {int(fm['TRAIN_FOR_MODEL_FLAG'].sum()):,}", indent=1)
    return fm

def build_ecgi_summary(dataset: pd.DataFrame, min_report_score: float) -> pd.DataFrame:
    header("PHASE 1G - BUILD ECGI INCIDENT SUMMARY")
    if dataset.empty:
        return pd.DataFrame()
    reportable = dataset[(dataset["IS_REPORTABLE_PROBLEM"] == 1) & (dataset["SEED_RULE_SCORE"] >= float(min_report_score))].copy()
    if reportable.empty:
        log("No reportable ECGI incidents after suppressors and severity threshold.", indent=1)
        return pd.DataFrame()
    reportable = reportable.sort_values(["ECGI", "SEED_RULE_SCORE"], ascending=[True, False])
    top = reportable.groupby("ECGI", as_index=False).head(1).copy()
    top = top.rename(columns={
        "FEATURE": "MAIN_PROBLEM_FEATURE",
        "SEED_LABEL": "PRIMARY_PROBLEM_CLASS",
        "SOURCE_FEATURE_EVIDENCE_SUMMARY": "MAIN_EVIDENCE_SUMMARY",
        "SEED_RULE_SCORE": "MAIN_FEATURE_SEVERITY_SCORE",
        "SOURCE_CHANGE_DAYS_COUNT": "MAIN_FEATURE_CHANGED_DAYS_COUNT",
        "SOURCE_CHANGED_DAYS_PERCENT": "MAIN_FEATURE_CHANGED_DAYS_PERCENT",
        "SOURCE_FIRST_CHANGE_DATE": "MAIN_FEATURE_FIRST_CHANGE_DATE",
        "SOURCE_LAST_CHANGE_DATE": "MAIN_FEATURE_LAST_CHANGE_DATE",
        "SOURCE_LATEST_CHANGE": "MAIN_FEATURE_LATEST_CHANGE",
    })
    agg = reportable.groupby("ECGI", as_index=False).agg(
        REPORTABLE_FEATURE_INCIDENT_COUNT=("FEATURE", "size"),
        SOURCE_CHANGED_FEATURE_COUNT=("FEATURE", "nunique"),
        TOTAL_SOURCE_CHANGE_DAYS_ACROSS_FEATURES=("SOURCE_CHANGE_DAYS_COUNT", "sum"),
        TOTAL_SOURCE_CHANGE_EVENTS=("SOURCE_CHANGE_COUNT", "sum"),
        MAX_SOURCE_CHANGED_DAYS_SINGLE_FEATURE=("SOURCE_CHANGE_DAYS_COUNT", "max"),
        AUDIT_PUSH_NOT_APPLIED_FEATURE_COUNT=("AUDIT_PUSH_NOT_APPLIED_FLAG", "sum"),
        FALLBACK_TO_DEFAULT_FEATURE_COUNT=("FALLBACK_TO_DEFAULT_VALUE_FLAG", "sum"),
        INVALID_LATEST_SOURCE_VALUE_FEATURE_COUNT=("LATEST_SOURCE_INVALID_RANGE_FLAG", "sum"),
        REAL_BACK_AND_FORTH_FEATURE_COUNT=("REAL_BACK_AND_FORTH_FLAG", "sum"),
        HIGH_FREQUENCY_DIFFERENT_VALUES_FEATURE_COUNT=("HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", "sum"),
        SAME_DAY_CONFLICT_FEATURE_COUNT=("SOURCE_SAME_DAY_CONFLICT_FLAG", "sum"),
        PERSISTENT_SOURCE_INSTABILITY_FEATURE_COUNT=("PERSISTENT_SOURCE_INSTABILITY_FLAG", "sum"),
        SOURCE_RULE_SCORE_FROM_FEATURES=("SEED_RULE_SCORE", "sum"),
        MAX_FEATURE_SEVERITY_SCORE=("SEED_RULE_SCORE", "max"),
    )
    top_feats = (
        reportable.sort_values(["ECGI", "SEED_RULE_SCORE"], ascending=[True, False])
        .groupby("ECGI")
        .head(8)
        .groupby("ECGI")
        .apply(lambda d: "; ".join(f"{r.FEATURE}:{r.SEED_LABEL}:{float(r.SEED_RULE_SCORE):.1f}" for r in d.itertuples()))
        .rename("TOP_FEATURE_INCIDENTS")
        .reset_index()
    )
    keep_cols = [
        "ECGI", "ECGI_LABEL", "REGION", "MARKETCLUSTER", "MARKET", "SUBMARKET", "SERVER_ID",
        "ANALYSIS_DAYS", "ANALYSIS_START_DATE", "ANALYSIS_END_DATE", "LATEST_DB_MISMATCH_RAW_ROWS",
        "LATEST_CANDIDATE_DATE", "PRIMARY_PROBLEM_CLASS", "MAIN_PROBLEM_FEATURE", "MAIN_FEATURE_SEVERITY_SCORE",
        "MAIN_FEATURE_CHANGED_DAYS_COUNT", "MAIN_FEATURE_CHANGED_DAYS_PERCENT", "MAIN_FEATURE_FIRST_CHANGE_DATE",
        "MAIN_FEATURE_LAST_CHANGE_DATE", "MAIN_FEATURE_LATEST_CHANGE", "MAIN_EVIDENCE_SUMMARY", "LATEST_SOURCE_VALUE",
        "PREVIOUS_NONLATEST_SOURCE_VALUE", "FIRST_SOURCE_VALUE", "LATEST_DB_VALUE", "SEVERITY_BAND", "RECOMMENDED_ACTION",
    ]
    top_reduced = top[[c for c in keep_cols if c in top.columns]].copy()
    ecgi = agg.merge(top_reduced, on="ECGI", how="left").merge(top_feats, on="ECGI", how="left")
    ecgi["SOURCE_RULE_SCORE"] = (
        ecgi["SOURCE_RULE_SCORE_FROM_FEATURES"]
        + 12.0 * np.maximum(ecgi["SOURCE_CHANGED_FEATURE_COUNT"] - 1, 0)
        + 20.0 * (ecgi["FALLBACK_TO_DEFAULT_FEATURE_COUNT"] > 0).astype(int)
        + 20.0 * (ecgi["AUDIT_PUSH_NOT_APPLIED_FEATURE_COUNT"] > 0).astype(int)
        + 15.0 * (ecgi["REAL_BACK_AND_FORTH_FEATURE_COUNT"] > 0).astype(int)
        + 15.0 * (ecgi["HIGH_FREQUENCY_DIFFERENT_VALUES_FEATURE_COUNT"] > 0).astype(int)
    )
    ecgi["SOURCE_RULE_PERCENTILE"] = percentile_rank(ecgi["SOURCE_RULE_SCORE"])
    ecgi["PLAIN_ENGLISH_SUMMARY"] = ecgi.apply(
        lambda r: (
            f"{r.get('ECGI_LABEL','')} on server {r.get('SERVER_ID','')} is a latest-day DB_MISMATCH candidate. "
            f"V6 seed labeling found {int(r.get('REPORTABLE_FEATURE_INCIDENT_COUNT',0))} reportable feature incident(s). "
            f"Primary class: {r.get('PRIMARY_PROBLEM_CLASS','')}; main feature: {r.get('MAIN_PROBLEM_FEATURE','')}; "
            f"score={float(r.get('SOURCE_RULE_SCORE',0)):.1f}."
        ),
        axis=1,
    )
    ecgi = ecgi.sort_values("SOURCE_RULE_SCORE", ascending=False).reset_index(drop=True)
    ecgi.insert(0, "INCIDENT_RANK", np.arange(1, len(ecgi) + 1))
    log(f"Reportable ECGI incidents: {len(ecgi):,}", indent=1)
    return ecgi


def build_issue_summary(dataset: pd.DataFrame) -> pd.DataFrame:
    if dataset.empty:
        return pd.DataFrame()
    rows = []
    for label, d in dataset.groupby("SEED_LABEL"):
        rows.append({
            "SEED_LABEL": label,
            "ROW_COUNT": int(len(d)),
            "UNIQUE_ECGI": int(d["ECGI"].nunique()),
            "UNIQUE_ECGI_FEATURE": int(len(d[["ECGI", "FEATURE"]].drop_duplicates())),
            "TRAIN_FOR_MODEL_ROWS": int(d["TRAIN_FOR_MODEL_FLAG"].sum()) if "TRAIN_FOR_MODEL_FLAG" in d.columns else 0,
            "AVG_SEED_CONFIDENCE": float(pd.to_numeric(d["SEED_LABEL_CONFIDENCE"], errors="coerce").mean()) if "SEED_LABEL_CONFIDENCE" in d.columns else np.nan,
            "AVG_SEED_RULE_SCORE": float(pd.to_numeric(d["SEED_RULE_SCORE"], errors="coerce").mean()) if "SEED_RULE_SCORE" in d.columns else np.nan,
            "MAX_SEED_RULE_SCORE": float(pd.to_numeric(d["SEED_RULE_SCORE"], errors="coerce").max()) if "SEED_RULE_SCORE" in d.columns else np.nan,
        })
    return pd.DataFrame(rows).sort_values(["TRAIN_FOR_MODEL_ROWS", "ROW_COUNT"], ascending=False).reset_index(drop=True)


def build_manual_review_template(dataset: pd.DataFrame, top_n: int, random_n: int, random_state: int) -> pd.DataFrame:
    if dataset.empty:
        return pd.DataFrame()
    cols = [
        "ECGI", "ECGI_LABEL", "FEATURE", "SEED_LABEL", "SEED_LABEL_CONFIDENCE", "SEED_RULE_SCORE", "SEVERITY_BAND",
        "SERVER_ID", "REGION", "MARKET", "LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "LATEST_DB_VALUE",
        "DATA_SOURCE_COMPATIBILITY", "DATA_SOURCE_MATCH_STATUS", "REFERENCE_SOURCE_NAME", "REFERENCE_COLUMN", "REFERENCE_VALUE",
        "FALLBACK_DURATION_CLUSTER", "FALLBACK_SOURCE_DATA_CLUSTER", "SITE_WIDE_LONG_TERM_DEFAULT_FALLBACK_SUSPECT_FLAG",
        "UNSUPERVISED_ISOF_PERCENTILE", "UNSUPERVISED_ISOF_TOP_FLAG",
        "SOURCE_CHANGE_DAYS_COUNT", "SOURCE_CHANGE_COUNT", "DISTINCT_SOURCE_VALUES_30D", "SOURCE_A_B_A_REVERT_COUNT",
        "SOURCE_REVERSE_TRANSITION_COUNT", "SOURCE_SAME_DAY_CONFLICT_DAYS", "MAX_CANDIDATE_BULK_CHANGE_RATIO",
        "SOURCE_FEATURE_EVIDENCE_SUMMARY", "RECOMMENDED_ACTION", "MANUAL_LABEL", "MANUAL_LABEL_NOTES",
    ]
    top = dataset.sort_values("SEED_RULE_SCORE", ascending=False).head(top_n).copy()
    pool = dataset[~dataset.index.isin(top.index)].copy()
    if len(pool) > 0 and random_n > 0:
        sample = pool.sample(n=min(random_n, len(pool)), random_state=random_state)
        out = pd.concat([top, sample], ignore_index=True)
    else:
        out = top
    return out[[c for c in cols if c in out.columns]].copy()


