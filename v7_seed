            lines.append(
                f"- **{fr.get('ECGI_LABEL','')} / {fr.get('FEATURE','')}** | "
                f"{fr.get('SEED_LABEL','')} | score={float(fr.get('SEED_RULE_SCORE',0)):.1f} | "
                f"latest={short_value(fr.get('LATEST_SOURCE_VALUE',''))} | previous={short_value(fr.get('PREVIOUS_NONLATEST_SOURCE_VALUE',''))} | "
                f"duration={fr.get('FALLBACK_DURATION_CLUSTER','')} | source={fr.get('FALLBACK_SOURCE_DATA_CLUSTER','')} | "
                f"compatibility={fr.get('DATA_SOURCE_COMPATIBILITY','')} | ref={fr.get('REFERENCE_SOURCE_NAME','')}.{fr.get('REFERENCE_COLUMN','')}={short_value(fr.get('REFERENCE_VALUE',''))}"
            )
        lines.append("")

    if ecgi_summary.empty:
        lines.append("No reportable ECGI incidents passed the configured severity/suppressor rules.")
        (out_dir / "cesmlc_v7_top_manual_review_report.md").write_text("\n".join(lines), encoding="utf-8")
        # Also keep previous filename for compatibility.
        (out_dir / "cesmlc_v6_top_manual_review_report.md").write_text("\n".join(lines), encoding="utf-8")
        return

    lines.append("## Top ECGI incidents")
    lines.append("")
    for _, r in ecgi_summary.head(top_n).iterrows():
        ecgi = r.get("ECGI", "")
        lines.append(f"### Rank {int(r.get('INCIDENT_RANK', 0))}: {r.get('ECGI_LABEL', '')}")
        lines.append(f"- **Server / market**: {r.get('SERVER_ID','')} / {r.get('MARKET','')}")
        lines.append(f"- **Primary class**: {r.get('PRIMARY_PROBLEM_CLASS','')}")
        lines.append(f"- **Main feature**: {r.get('MAIN_PROBLEM_FEATURE','')}")
        lines.append(f"- **Score**: {float(r.get('SOURCE_RULE_SCORE',0)):.1f}")
        lines.append(f"- **Evidence**: {r.get('MAIN_EVIDENCE_SUMMARY','')}")
        lines.append(f"- **Recommended action**: {r.get('RECOMMENDED_ACTION','')}")
        sub = dataset[(dataset["ECGI"] == ecgi) & (dataset["IS_REPORTABLE_PROBLEM"] == 1)].sort_values("SEED_RULE_SCORE", ascending=False).head(6)
        if not sub.empty:
            lines.append("- **Top feature incidents:**")
            for _, fr in sub.iterrows():
                extra = ""
                if fr.get("SEED_LABEL", "") in fallback_labels:
                    extra = f" | duration={fr.get('FALLBACK_DURATION_CLUSTER','')} | compatibility={fr.get('DATA_SOURCE_COMPATIBILITY','')}"
                lines.append(
                    f"  - {fr.get('FEATURE','')}: {fr.get('SEED_LABEL','')} | "
                    f"score={float(fr.get('SEED_RULE_SCORE',0)):.1f} | "
                    f"latest={short_value(fr.get('LATEST_SOURCE_VALUE',''))} | "
                    f"changes={int(fr.get('SOURCE_CHANGE_DAYS_COUNT',0))} days | "
                    f"distinct={int(fr.get('DISTINCT_SOURCE_VALUES_30D',0))}{extra}"
                )
        lines.append("")
    text = "\n".join(lines)
    (out_dir / "cesmlc_v7_top_manual_review_report.md").write_text(text, encoding="utf-8")
    (out_dir / "cesmlc_v6_top_manual_review_report.md").write_text(text, encoding="utf-8")

def write_outputs(out_dir: Path, analysis_info: Dict[str, Any], args: argparse.Namespace, candidates: pd.DataFrame, dataset: pd.DataFrame, ecgi_summary: pd.DataFrame, issue_summary: pd.DataFrame, changes: pd.DataFrame, conflicts: pd.DataFrame) -> None:
    header("PHASE 1G - WRITE V6 SEED DATASET OUTPUTS")
    out_dir.mkdir(parents=True, exist_ok=True)
    log(f"Writing output files to: {out_dir}", indent=1)

    write_readme(out_dir, analysis_info, args)
    pd.DataFrame([analysis_info]).to_csv(out_dir / "cesmlc_v6_processing_report.csv", index=False)
    candidates.to_csv(out_dir / "cesmlc_v6_candidate_ecgis_latest_db_mismatch.csv", index=False)
    issue_summary.to_csv(out_dir / "cesmlc_v6_seed_label_summary.csv", index=False)
    if "DATA_SOURCE_COMPATIBILITY" in dataset.columns:
        compat_summary = dataset.groupby(["SEED_LABEL", "DATA_SOURCE_COMPATIBILITY"], dropna=False).agg(
            ROW_COUNT=("ECGI", "size"),
            UNIQUE_ECGI=("ECGI", "nunique"),
            AVG_SEED_RULE_SCORE=("SEED_RULE_SCORE", "mean"),
        ).reset_index().sort_values(["SEED_LABEL", "ROW_COUNT"], ascending=[True, False])
        compat_summary.to_csv(out_dir / "cesmlc_v6_data_source_compatibility_summary.csv", index=False)
        checked = dataset[dataset["DATA_SOURCE_COMPATIBILITY"].astype(str).ne("NOT_CHECKED")].copy()
        checked.to_csv(out_dir / "cesmlc_v6_data_source_checked_feature_rows.csv", index=False)

    fallback_labels = {"FLUCTUATING_FALLBACK_TO_DEFAULT", "LONG_TERM_FALLBACK_TO_DEFAULT", "FALLBACK_TO_DEFAULT_VALUE"}
    fallback_cols = [
        "ECGI", "ECGI_LABEL", "FEATURE", "SEED_LABEL", "SEED_RULE_SCORE", "SEVERITY_BAND", "SERVER_ID", "MARKET",
        "LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "LATEST_SOURCE_VALUE_DAYS", "SOURCE_CHANGE_DAYS_COUNT",
        "FALLBACK_DURATION_CLUSTER", "FALLBACK_SOURCE_DATA_CLUSTER", "SITE_WIDE_LONG_TERM_DEFAULT_FALLBACK_SUSPECT_FLAG",
        "DATA_SOURCE_COMPATIBILITY", "DATA_SOURCE_MATCH_STATUS", "REFERENCE_SOURCE_NAME", "REFERENCE_COLUMN", "REFERENCE_VALUE",
        "UNSUPERVISED_ISOF_PERCENTILE", "SOURCE_FEATURE_EVIDENCE_SUMMARY", "RECOMMENDED_ACTION"
    ]
    fallback_review = dataset[dataset["SEED_LABEL"].isin(fallback_labels)].sort_values("SEED_RULE_SCORE", ascending=False).copy()
    fallback_review[[c for c in fallback_cols if c in fallback_review.columns]].to_csv(out_dir / "cesmlc_v7_fallback_review_all.csv", index=False)
    fallback_review[[c for c in fallback_cols if c in fallback_review.columns]].head(args.top_n_features).to_csv(out_dir / "cesmlc_v7_fallback_review_top.csv", index=False)


    dataset.to_csv(out_dir / "cesmlc_v6_problem_state_training_dataset.csv", index=False)
    dataset.to_csv(out_dir / "cesmlc_v6_feature_seed_labels_all.csv", index=False)
    dataset[dataset["TRAIN_FOR_MODEL_FLAG"] == 1].to_csv(out_dir / "cesmlc_v6_model_ready_training_dataset.csv", index=False)
    dataset[(dataset["IS_REPORTABLE_PROBLEM"] == 1) & (dataset["SEED_RULE_SCORE"] >= float(args.min_report_score))].sort_values("SEED_RULE_SCORE", ascending=False).to_csv(out_dir / "cesmlc_v6_feature_incidents_all.csv", index=False)
    dataset[(dataset["IS_REPORTABLE_PROBLEM"] == 1) & (dataset["SEED_RULE_SCORE"] >= float(args.min_report_score))].sort_values("SEED_RULE_SCORE", ascending=False).head(args.top_n_features).to_csv(out_dir / "cesmlc_v6_feature_incidents_top.csv", index=False)
    dataset[dataset["IS_REPORTABLE_PROBLEM"] == 0].sort_values("SEED_RULE_SCORE", ascending=False).to_csv(out_dir / "cesmlc_v6_suppressed_or_hold_feature_rows.csv", index=False)
    dataset[dataset["DB_PUSH_CHECK_CANDIDATE_FLAG"] == 1].sort_values("SEED_RULE_SCORE", ascending=False).to_csv(out_dir / "cesmlc_v6_db_push_check_candidates.csv", index=False)

    if not ecgi_summary.empty:
        ecgi_summary.to_csv(out_dir / "cesmlc_v6_ecgi_incident_summary_all.csv", index=False)
        ecgi_summary.head(args.top_n).to_csv(out_dir / "cesmlc_v6_ecgi_incident_summary_top.csv", index=False)
    else:
        pd.DataFrame().to_csv(out_dir / "cesmlc_v6_ecgi_incident_summary_all.csv", index=False)
        pd.DataFrame().to_csv(out_dir / "cesmlc_v6_ecgi_incident_summary_top.csv", index=False)

    manual_template = build_manual_review_template(dataset, args.manual_review_top_n, args.manual_review_random_n, args.random_state)
    manual_template.to_csv(out_dir / "cesmlc_v6_manual_review_label_template.csv", index=False)
    write_manual_markdown(out_dir, ecgi_summary, dataset, args.manual_report_top_n)

    # Evidence event outputs for top feature incidents.
    top_pairs = dataset[(dataset["IS_REPORTABLE_PROBLEM"] == 1)].sort_values("SEED_RULE_SCORE", ascending=False)[["ECGI", "FEATURE", "SEED_LABEL", "SEED_RULE_SCORE"]].head(args.evidence_top_n)
    if not changes.empty and not top_pairs.empty:
        ev = changes.merge(top_pairs, on=["ECGI", "FEATURE"], how="inner")
        ev["ECGI_LABEL"] = ev["ECGI"].map(excel_safe_ecgi)
        ev.to_csv(out_dir / "cesmlc_v6_source_change_events_top.csv", index=False)
    else:
        pd.DataFrame().to_csv(out_dir / "cesmlc_v6_source_change_events_top.csv", index=False)
    if not conflicts.empty and not top_pairs.empty:
        ce = conflicts.merge(top_pairs, on=["ECGI", "FEATURE"], how="inner")
        ce["ECGI_LABEL"] = ce["ECGI"].map(excel_safe_ecgi)
        ce.to_csv(out_dir / "cesmlc_v6_same_day_conflicts_top.csv", index=False)
    else:
        pd.DataFrame().to_csv(out_dir / "cesmlc_v6_same_day_conflicts_top.csv", index=False)

    # Funnel summary.
    funnel_rows = [
        ("latest_day_raw_rows", analysis_info.get("latest_raw_rows", 0)),
        ("latest_day_db_mismatch_yes_rows", analysis_info.get("latest_db_mismatch_yes_rows", 0)),
        ("latest_day_candidate_ecgis", analysis_info.get("latest_db_mismatch_candidate_ecgis", 0)),
        ("candidate_ecgi_feature_rows", len(dataset)),
        ("train_for_model_rows", int(dataset["TRAIN_FOR_MODEL_FLAG"].sum()) if not dataset.empty else 0),
        ("reportable_problem_feature_rows", int(dataset["IS_REPORTABLE_PROBLEM"].sum()) if not dataset.empty else 0),
        ("suppressed_or_hold_feature_rows", int((dataset["IS_REPORTABLE_PROBLEM"] == 0).sum()) if not dataset.empty else 0),
        ("reportable_ecgi_incidents", len(ecgi_summary)),
    ]
    pd.DataFrame(funnel_rows, columns=["FUNNEL_STEP", "ROW_COUNT"]).to_csv(out_dir / "cesmlc_v6_candidate_funnel_summary.csv", index=False)

    log(f"All candidate ECGI-feature rows: {len(dataset):,}", indent=1)
    log(f"Model-ready training rows: {int(dataset['TRAIN_FOR_MODEL_FLAG'].sum()):,}", indent=1)
    log(f"Reportable problem feature rows: {int(dataset['IS_REPORTABLE_PROBLEM'].sum()):,}", indent=1)
    log(f"Reportable ECGI incidents: {len(ecgi_summary):,}", indent=1)


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="CESMLC V6 seed-label dataset builder for problem-state ML.")
    p.add_argument("--input", required=True, type=str, help="Raw CESMLC CSV input.")
    p.add_argument("--days", default=30, type=int, help="Analysis window length ending at --end-date or max LOAD_DATE.")
    p.add_argument("--end-date", default=None, type=str, help="Optional candidate/latest date YYYY-MM-DD. Default: max parsed LOAD_DATE.")
    p.add_argument("--out-dir", default=None, type=str, help="Output folder.")
    p.add_argument("--server-id", default=None, type=str, help="Optional SERVER_ID filter for latest-day candidate extraction.")
    p.add_argument("--include-features", default=",".join(DEFAULT_FEATURES), type=str, help="Comma-separated source/current feature columns to analyze.")
    p.add_argument("--exclude-features", default=None, type=str, help="Comma-separated features to exclude.")
    p.add_argument("--defaults-json", default=None, type=str, help="Optional JSON overriding default values, valid ranges, and criticality weights.")

    # Optional RAN source-of-truth/reference CSVs. These are not trusted as DB history; they are used
    # after source-history anomaly detection to explain whether an anomalous latest value agrees with
    # external source data and to split default fallback into source-exists/source-missing clusters.
    p.add_argument("--reference-source-dir", default=None, type=str, help="Folder containing atoll_master_4g.csv, ericsson_5g_master_data.csv, cssng_data_addition.csv, and/or atoll_cells5g.csv.")
    p.add_argument("--atoll-master-4g", default=None, type=str, help="Optional path to atoll_master_4g.csv.")
    p.add_argument("--ericsson-5g-master-data", default=None, type=str, help="Optional path to ericsson_5g_master_data.csv.")
    p.add_argument("--cssng-data-addition", default=None, type=str, help="Optional path to cssng_data_addition.csv.")
    p.add_argument("--atoll-cells5g", default=None, type=str, help="Optional path to atoll_cells5g.csv.")
    p.add_argument("--reference-mapping-json", default=None, type=str, help="Optional JSON mapping CESMLC feature names to reference-source column candidates.")
    p.add_argument("--disable-reference-compatibility", action="store_true", help="Skip RAN reference-source compatibility even if files are provided.")
    p.add_argument("--reference-numeric-tolerance", default=0.00005, type=float, help="Default numeric tolerance for reference matching when feature-specific tolerance is not set.")
    p.add_argument("--long-term-default-days", default=7, type=int, help="Default fallback duration threshold for long-term fallback clusters.")
    p.add_argument("--sitewide-default-feature-threshold", default=4, type=int, help="If this many features are default fallback for an ECGI, flag site-wide long-term fallback suspicion.")
    p.add_argument("--sitewide-default-ratio-threshold", default=0.50, type=float, help="If this ratio of analyzed features are default fallback for an ECGI, flag site-wide long-term fallback suspicion.")

    p.add_argument("--enable-db-push-check", action="store_true", help="Use FEATURE_DB columns only for narrow AUDIT_PUSH_NOT_APPLIED seed/check.")
    p.add_argument("--push-source-stable-days", default=2, type=int, help="Source latest value stability days for push-not-applied seed.")
    p.add_argument("--push-mismatch-days", default=2, type=int, help="Minimum same-feature source-vs-DB mismatch days for push-not-applied seed.")

    p.add_argument("--latlon-decimals", default=5, type=int, help="Coordinate rounding precision. Default 5.")
    p.add_argument("--feature-batch-size", default=1, type=int, help="Number of features per DuckDB batch. Default 1 for memory safety.")
    p.add_argument("--threads", default=1, type=int, help="DuckDB thread count. Default 1 for memory safety.")
    p.add_argument("--memory-limit", default="6GB", type=str, help="DuckDB memory limit, e.g. 6GB, 8GB, 16GB.")
    p.add_argument("--duckdb-file", default=None, type=str, help="Optional DuckDB database file. Default: output/temp/cesmlc_v6.duckdb")
    p.add_argument("--duckdb-temp-dir", default=None, type=str, help="DuckDB spill/temp directory. Default: output/temp/duckdb_spill")
    p.add_argument("--keep-duckdb", action="store_true", help="Keep temporary DuckDB files.")
    p.add_argument("--reuse-history-cache", action="store_true", help="Reuse saved Phase 1C source-history cache when run settings match. Skips the expensive 30-day feature history scan.")
    p.add_argument("--force-rebuild-history-cache", action="store_true", help="Ignore any existing Phase 1C history cache and rebuild it.")
    p.add_argument("--history-cache-dir", default=None, type=str, help="Persistent cache folder for Phase 1C history tables. Default: <out-dir>/history_cache.")

    p.add_argument("--enable-isolation-forest", action="store_true", help="Add optional unsupervised IsolationForest outlier score on engineered feature-history metrics.")
    p.add_argument("--isolation-fit-sample", default=300000, type=int, help="Max rows sampled to fit IsolationForest. Scoring still applies to all rows.")
    p.add_argument("--isolation-n-estimators", default=200, type=int, help="IsolationForest tree count.")
    p.add_argument("--isolation-top-percentile", default=98.0, type=float, help="Percentile threshold for UNSUPERVISED_ISOF_TOP_FLAG.")
    p.add_argument("--isolation-score-weight", default=0.10, type=float, help="Small score bump weight from IsolationForest percentile. Default 0.10 keeps rules dominant.")

    p.add_argument("--high-frequency-days", default=5, type=int, help="Changed days threshold for high-frequency different-values seed.")
    p.add_argument("--high-frequency-distinct-values", default=3, type=int, help="Distinct values threshold for high-frequency different-values seed.")
    p.add_argument("--high-frequency-max-mode-share", default=85.0, type=float, help="Mode-share percent ceiling for high-frequency different-values seed.")
    p.add_argument("--persistent-days", default=10, type=int, help="Changed days threshold for persistent source instability seed.")
    p.add_argument("--min-reverses-for-backforth", default=2, type=int, help="Reverse transition threshold for real back-and-forth.")
    p.add_argument("--min-aba-for-backforth", default=2, type=int, help="A-B-A revert threshold for real back-and-forth.")
    p.add_argument("--default-min-days", default=2, type=int, help="Latest default value must persist this many observed days for fallback seed.")
    p.add_argument("--stable-change-suppress-days", default=5, type=int, help="Suppress one-time changes older than this many days.")
    p.add_argument("--bulk-change-ratio-threshold", default=0.25, type=float, help="Suppress likely bulk/refresh when candidate-population feature/day change ratio exceeds this.")
    p.add_argument("--coordinated-feature-threshold", default=4, type=int, help="Suppress likely coordinated multi-field change when this many fields changed same ECGI/date and stabilized.")
    p.add_argument("--min-report-score", default=35.0, type=float, help="Minimum absolute feature seed-rule score to report as incident.")
    p.add_argument("--min-seed-confidence-for-training", default=0.65, type=float, help="Minimum seed-label confidence for initial ML training rows.")

    p.add_argument("--top-n", default=300, type=int, help="Top N ECGI incidents output.")
    p.add_argument("--top-n-features", default=2000, type=int, help="Top N feature incidents output.")
    p.add_argument("--evidence-top-n", default=2000, type=int, help="Top ECGI-feature pairs for event evidence outputs.")
    p.add_argument("--manual-report-top-n", default=50, type=int, help="Top ECGIs in manual markdown report.")
    p.add_argument("--manual-review-top-n", default=500, type=int, help="Top rows included in manual-review label template.")
    p.add_argument("--manual-review-random-n", default=500, type=int, help="Random additional rows included in manual-review label template.")
    p.add_argument("--random-state", default=42, type=int)
    return p.parse_args()


def main() -> int:
    args = parse_args()
    input_path = Path(args.input).expanduser()
    if not input_path.exists():
        raise FileNotFoundError(f"Input file not found: {input_path}")

    out_dir = Path(args.out_dir).expanduser() if args.out_dir else input_path.parent / "cesmlc_v6_seed_label_outputs"
    out_dir.mkdir(parents=True, exist_ok=True)
    temp_dir = out_dir / "temp"
    temp_dir.mkdir(parents=True, exist_ok=True)
    duckdb_path = Path(args.duckdb_file).expanduser() if args.duckdb_file else temp_dir / "cesmlc_v6.duckdb"
    duckdb_temp_dir = Path(args.duckdb_temp_dir).expanduser() if args.duckdb_temp_dir else temp_dir / "duckdb_spill"

    header("CESMLC V6 PROBLEM-STATE SEED-LABEL DATASET BUILDER")
    log(f"Input: {input_path}")
    log(f"Output: {out_dir}")
    log("Candidate gate: latest-day DB_MISMATCH='YES'")
    log("Main evidence: 30-day source/current history for candidate ECGIs only")
    log(f"Narrow DB push check enabled: {bool(args.enable_db_push_check)}")
    log(f"Run settings: days={args.days}, feature_batch_size={args.feature_batch_size}, threads={args.threads}, memory_limit={args.memory_limit}, latlon_decimals={args.latlon_decimals}")

    header_cols, colmap = read_header(input_path)
    date_col = first_existing(header_cols, DATE_CANDIDATES)
    if not date_col:
        raise ValueError(f"No date column found. Tried {DATE_CANDIDATES}. Found: {header_cols}")
    features = detect_features(header_cols, args.include_features, args.exclude_features)
    if not features:
        raise ValueError("No source features selected. Use --include-features with comma-separated column names.")
    missing = [f for f in features if f not in colmap]
    if missing:
        raise ValueError(f"Selected features not found in CSV header: {missing}")

    log(f"Date column: {date_col}")
    log(f"DB_MISMATCH column present: {'DB_MISMATCH' in colmap}")
    log(f"Source features ({len(features)}): {', '.join(features)}")

    rules = load_feature_rules(args.defaults_json)
    con = open_duckdb(duckdb_path, args.threads, args.memory_limit, duckdb_temp_dir=duckdb_temp_dir)
    try:
        analysis_info = create_latest_db_mismatch_candidates(
            con=con,
            input_path=input_path,
            colmap=colmap,
            date_col_clean=date_col,
            days=args.days,
            end_date=args.end_date,
            server_id_filter=args.server_id,
        )
        analysis_info.update({
            "feature_count": int(len(features)),
            "features": ",".join(features),
            "latlon_decimals": int(args.latlon_decimals),
            "enable_db_push_check": bool(args.enable_db_push_check),
            "min_report_score": float(args.min_report_score),
            "min_seed_confidence_for_training": float(args.min_seed_confidence_for_training),
            "reference_compatibility_disabled": bool(args.disable_reference_compatibility),
            "reference_source_dir": args.reference_source_dir or "",
            "long_term_default_days": int(args.long_term_default_days),
            "sitewide_default_feature_threshold": int(args.sitewide_default_feature_threshold),
            "sitewide_default_ratio_threshold": float(args.sitewide_default_ratio_threshold),
            "reuse_history_cache": bool(args.reuse_history_cache),
            "enable_isolation_forest": bool(args.enable_isolation_forest),
        })

        cache_dir = default_history_cache_dir(out_dir, args)
        cache_manifest = cache_manifest_for_run(input_path, features, analysis_info, args)
        cached_tables = None
        if args.reuse_history_cache:
            cached_tables = load_history_cache_if_valid(cache_dir, cache_manifest, force_rebuild=args.force_rebuild_history_cache)
        if cached_tables is not None:
            candidates, hist, changes, conflicts = cached_tables
        else:
            if args.reuse_history_cache:
                log("No valid reusable Phase 1C history cache was found; rebuilding history tables.", indent=1)
            create_candidate_source_history_batched(
                con=con,
                input_path=input_path,
                colmap=colmap,
                date_col_clean=date_col,
                features=features,
                analysis_info=analysis_info,
                latlon_decimals=args.latlon_decimals,
                feature_batch_size=args.feature_batch_size,
                enable_db_push_check=args.enable_db_push_check,
            )
            candidates, hist, changes, conflicts = load_compact_tables(con)
            save_history_cache(cache_dir, cache_manifest, candidates, hist, changes, conflicts)

        dataset = build_training_dataset(candidates, hist, changes, conflicts, rules, analysis_info, args)
        ecgi_summary = build_ecgi_summary(dataset, args.min_report_score)
        issue_summary = build_issue_summary(dataset)

        analysis_info.update({
            "feature_history_metric_rows": int(len(hist)),
            "source_change_event_rows": int(len(changes)),
            "same_day_conflict_rows": int(len(conflicts)),
            "candidate_ecgi_feature_rows": int(len(dataset)),
            "model_ready_training_rows": int(dataset["TRAIN_FOR_MODEL_FLAG"].sum()) if not dataset.empty else 0,
            "reportable_problem_feature_rows": int(dataset["IS_REPORTABLE_PROBLEM"].sum()) if not dataset.empty else 0,
            "reportable_ecgi_incidents": int(len(ecgi_summary)) if not ecgi_summary.empty else 0,
            "suppressed_or_hold_feature_rows": int((dataset["IS_REPORTABLE_PROBLEM"] == 0).sum()) if not dataset.empty else 0,
        })

        write_outputs(out_dir, analysis_info, args, candidates, dataset, ecgi_summary, issue_summary, changes, conflicts)

    finally:
        log("Closing DuckDB connection", indent=1)
        try:
            con.close()
        except Exception:
            pass
        if not args.keep_duckdb:
            log("Removing temporary DuckDB files because --keep-duckdb was not used", indent=1)
            shutil.rmtree(temp_dir, ignore_errors=True)
        else:
            log(f"Keeping temporary DuckDB files in: {temp_dir}", indent=1)

    header("DONE")
    log(f"Total runtime: {elapsed_text()}")
