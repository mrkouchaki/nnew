def _existing_path(x: Optional[str]) -> Optional[Path]:
    if not x:
        return None
    p = Path(x).expanduser()
    return p if p.exists() else None


def resolve_reference_source_paths(args: argparse.Namespace) -> Dict[str, Path]:
    """Resolve optional RAN reference CSVs. Missing paths are allowed; the run continues."""
    paths: Dict[str, Path] = {}
    explicit = {
        "ATOLL_MASTER_4G": getattr(args, "atoll_master_4g", None),
        "ERICSSON_5G_MASTER_DATA": getattr(args, "ericsson_5g_master_data", None),
        "CSSNG_DATA_ADDITION": getattr(args, "cssng_data_addition", None),
        "ATOLL_CELLS5G": getattr(args, "atoll_cells5g", None),
    }
    for name, raw in explicit.items():
        p = _existing_path(raw)
        if p:
            paths[name] = p

    source_dir = _existing_path(getattr(args, "reference_source_dir", None))
    if source_dir:
        candidates = {
            "ATOLL_MASTER_4G": ["atoll_master_4g.csv", "ATOLL_MASTER_4G.csv"],
            "ERICSSON_5G_MASTER_DATA": ["ericsson_5g_master_data.csv", "ERICSSON_5G_MASTER_DATA.csv"],
            "CSSNG_DATA_ADDITION": ["cssng_data_addition.csv", "CSSNG_DATA_ADDITION.csv"],
            "ATOLL_CELLS5G": ["atoll_cells5g.csv", "atoll_cells5g.cs", "ATOLL_CELLS5G.csv"],
        }
        for name, names in candidates.items():
            if name in paths:
                continue
            for fname in names:
                p = source_dir / fname
                if p.exists():
                    paths[name] = p
                    break
    return paths


def load_reference_mapping(mapping_json: Optional[str]) -> Dict[str, List[str]]:
    mapping = {clean_col_name(k): [clean_col_name(x) for x in v] for k, v in DEFAULT_REFERENCE_FEATURE_COLUMN_CANDIDATES.items()}
    if mapping_json:
        p = Path(mapping_json).expanduser()
        if not p.exists():
            raise FileNotFoundError(f"--reference-mapping-json file not found: {p}")
        raw = json.loads(p.read_text(encoding="utf-8"))
        for feat, spec in raw.items():
            f = clean_col_name(feat)
            if isinstance(spec, dict):
                cols = spec.get("columns", []) or spec.get("reference_columns", []) or []
            else:
                cols = spec or []
            merged = list(mapping.get(f, [])) + [clean_col_name(x) for x in cols]
            mapping[f] = sorted(set([x for x in merged if x]))
    return mapping


def _find_first_col(cols: Iterable[str], candidates: Iterable[str]) -> Optional[str]:
    cset = set(clean_col_name(c) for c in cols)
    for c in candidates:
        cc = clean_col_name(c)
        if cc in cset:
            return cc
    return None


def _numeric_or_none(x: object) -> Optional[float]:
    s = normalize_value_text(x)
    if not s:
        return None
    try:
        v = float(s)
        return v if math.isfinite(v) else None
    except Exception:
        return None


def values_match_for_feature(feature: str, a: object, b: object, rules: Dict[str, Dict[str, Any]], default_tol: float) -> Tuple[int, float]:
    """Return (match_flag, absolute_numeric_delta_or_nan)."""
    an = normalize_value_text(a)
    bn = normalize_value_text(b)
    if not an or not bn:
        return 0, np.nan
    af = _numeric_or_none(an)
    bf = _numeric_or_none(bn)
    if af is not None and bf is not None:
        cfg = rules.get(clean_col_name(feature), {})
        tol = float(cfg.get("numeric_tolerance", default_tol))
        return int(abs(af - bf) <= tol), float(abs(af - bf))
    return int(an == bn), np.nan


def build_reference_long(reference_paths: Dict[str, Path], feature_mapping: Dict[str, List[str]]) -> pd.DataFrame:
    rows = []
    source_priority = {name: i for i, name in enumerate(["CSSNG_DATA_ADDITION", "ATOLL_MASTER_4G", "ERICSSON_5G_MASTER_DATA", "ATOLL_CELLS5G"], start=1)}
    for source_name, path in reference_paths.items():
        try:
            log(f"Loading RAN reference source {source_name}: {path}", indent=1)
            ref = pd.read_csv(path, low_memory=False)
        except Exception as exc:
            log(f"Warning: could not read reference source {source_name}: {exc}", indent=1)
            continue
        ref.columns = [clean_col_name(c) for c in ref.columns]
        if ref.empty:
            continue
        ref_cols = set(ref.columns)
        key_cols = []
        for key_type, aliases in REFERENCE_KEY_ALIASES.items():
            key_col = _find_first_col(ref_cols, aliases)
            if key_col:
                key_cols.append((key_type, key_col))
        if not key_cols:
            log(f"Reference source {source_name} skipped: no usable key column found.", indent=2)
            continue
        for feature, candidates in feature_mapping.items():
            value_cols = [c for c in candidates if c in ref_cols]
            if not value_cols:
                continue
            for value_col in value_cols:
                use_cols = sorted(set([value_col] + [kc for _, kc in key_cols]))
                small = ref[use_cols].copy()
                small["__REFERENCE_VALUE"] = small[value_col].map(normalize_value_text)
                for key_type, key_col in key_cols:
                    part = small[[key_col, "__REFERENCE_VALUE"]].copy()
                    part["REFERENCE_KEY_VALUE"] = part[key_col].map(normalize_key_value)
                    part = part[part["REFERENCE_KEY_VALUE"] != ""]
                    if part.empty:
                        continue
                    part["REFERENCE_KEY_TYPE"] = key_type
                    part["FEATURE"] = feature
                    part["REFERENCE_SOURCE_NAME"] = source_name
                    part["REFERENCE_SOURCE_FILE"] = str(path)
                    part["REFERENCE_COLUMN"] = value_col
                    part["REFERENCE_VALUE"] = part["__REFERENCE_VALUE"]
                    part["REFERENCE_VALUE_PRESENT_FLAG"] = (part["REFERENCE_VALUE"] != "").astype(int)
                    part["SOURCE_PRIORITY"] = source_priority.get(source_name, 99)
                    rows.append(part[[
                        "REFERENCE_KEY_TYPE", "REFERENCE_KEY_VALUE", "FEATURE", "REFERENCE_SOURCE_NAME", "REFERENCE_SOURCE_FILE",
                        "REFERENCE_COLUMN", "REFERENCE_VALUE", "REFERENCE_VALUE_PRESENT_FLAG", "SOURCE_PRIORITY"
                    ]])
    if not rows:
        return pd.DataFrame(columns=[
            "REFERENCE_KEY_TYPE", "REFERENCE_KEY_VALUE", "FEATURE", "REFERENCE_SOURCE_NAME", "REFERENCE_SOURCE_FILE",
            "REFERENCE_COLUMN", "REFERENCE_VALUE", "REFERENCE_VALUE_PRESENT_FLAG", "SOURCE_PRIORITY"
        ])
    out = pd.concat(rows, ignore_index=True)
    out = out.sort_values(["REFERENCE_KEY_TYPE", "REFERENCE_KEY_VALUE", "FEATURE", "REFERENCE_VALUE_PRESENT_FLAG", "SOURCE_PRIORITY"], ascending=[True, True, True, False, True])
    out = out.drop_duplicates(["REFERENCE_KEY_TYPE", "REFERENCE_KEY_VALUE", "FEATURE"], keep="first").reset_index(drop=True)
    log(f"Reference lookup rows built: {len(out):,}", indent=1)
    return out



def attach_reference_compatibility(dataset: pd.DataFrame, rules: Dict[str, Dict[str, Any]], args: argparse.Namespace) -> pd.DataFrame:
    """Attach external RAN source compatibility and refine fallback-to-default into two readable clusters.

    V6.2 had four fallback labels (short/long x source-exists/source-missing). That was too noisy for
    operations. V7 keeps source-exists/source-missing as columns, but the actual SEED_LABEL only uses:
      - FLUCTUATING_FALLBACK_TO_DEFAULT
      - LONG_TERM_FALLBACK_TO_DEFAULT

    DATA_SOURCE_COMPATIBILITY remains a support signal for fallback, high-frequency, and back-and-forth findings.
    """
    fm = dataset.copy()
    defaults = {
        "REFERENCE_LOOKUP_ENABLED_FLAG": 0,
        "REFERENCE_ROW_FOUND_FLAG": 0,
        "REFERENCE_VALUE_PRESENT_FLAG": 0,
        "REFERENCE_VALUE_IS_DEFAULT_FLAG": 0,
        "DATA_SOURCE_COMPATIBLE_FLAG": np.nan,
        "DATA_SOURCE_MATCH_DELTA": np.nan,
        "REFERENCE_SOURCE_NAME": "",
        "REFERENCE_SOURCE_FILE": "",
        "REFERENCE_COLUMN": "",
        "REFERENCE_VALUE": "",
        "REFERENCE_KEY_TYPE": "",
        "REFERENCE_KEY_VALUE": "",
        "DATA_SOURCE_COMPATIBILITY": "NOT_CHECKED",
        "DATA_SOURCE_MATCH_STATUS": "NOT_CHECKED",
        "SOURCE_EXISTS_SERVER_REPORTED_DEFAULT_FLAG": 0,
        "SOURCE_MISSING_SERVER_REPORTED_DEFAULT_FLAG": 0,
        "LONG_TERM_DEFAULT_FALLBACK_FLAG": 0,
        "FLUCTUATING_DEFAULT_FALLBACK_FLAG": 0,
        "SHORT_TERM_DEFAULT_FALLBACK_FLAG": 0,  # backward-compatible alias
        "SITE_WIDE_LONG_TERM_DEFAULT_FALLBACK_SUSPECT_FLAG": 0,
        "ECGI_DEFAULT_FALLBACK_FEATURE_COUNT": 0,
        "ECGI_DEFAULT_FALLBACK_FEATURE_RATIO": 0.0,
        "FALLBACK_DURATION_CLUSTER": "",
        "FALLBACK_SOURCE_DATA_CLUSTER": "",
    }
    for c, v in defaults.items():
        if c not in fm.columns:
            fm[c] = v

    # Optional reference matching. If missing/disabled, fallback is still split into two clusters using duration.
    reference_paths = {}
    if not getattr(args, "disable_reference_compatibility", False):
        reference_paths = resolve_reference_source_paths(args)

    if reference_paths:
        mapping = load_reference_mapping(getattr(args, "reference_mapping_json", None))
        ref_long = build_reference_long(reference_paths, mapping)
        if ref_long.empty:
            log("Reference CSVs were loaded but no usable reference lookup rows were built.", indent=1)
            fm["DATA_SOURCE_COMPATIBILITY"] = "UNKNOWN_NO_REFERENCE_LOOKUP"
            fm["DATA_SOURCE_MATCH_STATUS"] = "UNKNOWN_NO_REFERENCE_LOOKUP"
        else:
            fm["REFERENCE_LOOKUP_ENABLED_FLAG"] = 1
            fm["__ROW_ID"] = np.arange(len(fm))
            matched_ids = set()
            for key_type, aliases in REFERENCE_KEY_ALIASES.items():
                dataset_key_col = _find_first_col(fm.columns, aliases)
                if not dataset_key_col:
                    continue
                remaining = fm[~fm["__ROW_ID"].isin(matched_ids)][["__ROW_ID", "FEATURE", dataset_key_col]].copy()
                if remaining.empty:
                    continue
                remaining["REFERENCE_KEY_TYPE"] = key_type
                remaining["REFERENCE_KEY_VALUE"] = remaining[dataset_key_col].map(normalize_key_value)
                remaining = remaining[remaining["REFERENCE_KEY_VALUE"] != ""]
                if remaining.empty:
                    continue
                merged = remaining.merge(ref_long, on=["REFERENCE_KEY_TYPE", "REFERENCE_KEY_VALUE", "FEATURE"], how="left")
                merged = merged[merged["REFERENCE_SOURCE_NAME"].notna()].copy()
                if merged.empty:
                    continue
                merged = merged.drop_duplicates("__ROW_ID", keep="first")
                idx = merged["__ROW_ID"].astype(int).values
                for col in ["REFERENCE_SOURCE_NAME", "REFERENCE_SOURCE_FILE", "REFERENCE_COLUMN", "REFERENCE_VALUE", "REFERENCE_KEY_TYPE", "REFERENCE_KEY_VALUE", "REFERENCE_VALUE_PRESENT_FLAG"]:
                    fm.loc[idx, col] = merged[col].values
                fm.loc[idx, "REFERENCE_ROW_FOUND_FLAG"] = 1
                matched_ids.update(idx.tolist())
                log(f"Reference matches via {key_type}/{dataset_key_col}: {len(idx):,}", indent=2)

            found = fm["REFERENCE_ROW_FOUND_FLAG"] == 1
            present = found & (safe_numeric(fm["REFERENCE_VALUE_PRESENT_FLAG"]) == 1)
            fm.loc[~found, "DATA_SOURCE_COMPATIBILITY"] = "UNKNOWN_NO_REFERENCE_ROW"
            fm.loc[~found, "DATA_SOURCE_MATCH_STATUS"] = "UNKNOWN_NO_REFERENCE_ROW"
            fm.loc[found & ~present, "DATA_SOURCE_COMPATIBILITY"] = "UNKNOWN_SOURCE_VALUE_MISSING"
            fm.loc[found & ~present, "DATA_SOURCE_MATCH_STATUS"] = "REFERENCE_ROW_FOUND_BUT_VALUE_MISSING"

            match_flags = []
            deltas = []
            present_idx = fm.index[present].tolist()
            for i in present_idx:
                m, d = values_match_for_feature(
                    fm.at[i, "FEATURE"],
                    fm.at[i, "LATEST_SOURCE_VALUE"],
                    fm.at[i, "REFERENCE_VALUE"],
                    rules,
                    float(getattr(args, "reference_numeric_tolerance", 0.00005)),
                )
                match_flags.append(m)
                deltas.append(d)
                fm.at[i, "REFERENCE_VALUE_IS_DEFAULT_FLAG"] = value_is_default(fm.at[i, "FEATURE"], fm.at[i, "REFERENCE_VALUE"], rules)
            if present_idx:
                fm.loc[present_idx, "DATA_SOURCE_COMPATIBLE_FLAG"] = match_flags
                fm.loc[present_idx, "DATA_SOURCE_MATCH_DELTA"] = deltas
                fm.loc[present & (fm["DATA_SOURCE_COMPATIBLE_FLAG"] == 1), "DATA_SOURCE_COMPATIBILITY"] = "YES"
                fm.loc[present & (fm["DATA_SOURCE_COMPATIBLE_FLAG"] == 1), "DATA_SOURCE_MATCH_STATUS"] = "MATCH"
                fm.loc[present & (fm["DATA_SOURCE_COMPATIBLE_FLAG"] == 0), "DATA_SOURCE_COMPATIBILITY"] = "NO"
                fm.loc[present & (fm["DATA_SOURCE_COMPATIBLE_FLAG"] == 0), "DATA_SOURCE_MATCH_STATUS"] = "MISMATCH"

            if "__ROW_ID" in fm.columns:
                fm = fm.drop(columns=["__ROW_ID"])
    else:
        if getattr(args, "disable_reference_compatibility", False):
            log("Reference compatibility step disabled by --disable-reference-compatibility.", indent=1)
        else:
            log("No RAN reference CSVs were provided/found; fallback duration split will still run, DATA_SOURCE_COMPATIBILITY remains NOT_CHECKED.", indent=1)

    # Always split fallback into only two label clusters.
    fallback = safe_numeric(fm.get("FALLBACK_TO_DEFAULT_VALUE_FLAG", 0)).astype(int) == 1
    source_exists = (safe_numeric(fm.get("REFERENCE_VALUE_PRESENT_FLAG", 0)).astype(int) == 1)
    fm.loc[fallback & source_exists, "SOURCE_EXISTS_SERVER_REPORTED_DEFAULT_FLAG"] = 1
    fm.loc[fallback & ~source_exists, "SOURCE_MISSING_SERVER_REPORTED_DEFAULT_FLAG"] = 1

    candidate_date = pd.NaT
    if "LATEST_CANDIDATE_DATE" in fm.columns and len(fm):
        candidate_date = pd.to_datetime(fm["LATEST_CANDIDATE_DATE"].dropna().iloc[0], errors="coerce") if fm["LATEST_CANDIDATE_DATE"].notna().any() else pd.NaT
    latest_first = pd.to_datetime(fm.get("LATEST_SOURCE_VALUE_FIRST_SEEN_DATE", pd.Series(pd.NaT, index=fm.index)), errors="coerce")
    if pd.notna(candidate_date):
        latest_days_by_calendar = (candidate_date.normalize() - latest_first.dt.normalize()).dt.days + 1
    else:
        latest_days_by_calendar = pd.Series(np.nan, index=fm.index)
    latest_days_by_calendar = latest_days_by_calendar.fillna(0).clip(lower=0)
    latest_value_days = safe_numeric(fm.get("LATEST_SOURCE_VALUE_DAYS", pd.Series(0, index=fm.index)))
    default_duration = np.maximum(latest_value_days, latest_days_by_calendar)

    long_term = fallback & (default_duration >= int(getattr(args, "long_term_default_days", 7)))

    ecgi_stats = fm.groupby("ECGI", as_index=False).agg(
        ECGI_ANALYZED_FEATURE_ROWS=("FEATURE", "size"),
        ECGI_DEFAULT_FALLBACK_FEATURE_COUNT=("FALLBACK_TO_DEFAULT_VALUE_FLAG", "sum"),
    )
    ecgi_stats["ECGI_DEFAULT_FALLBACK_FEATURE_RATIO"] = ecgi_stats["ECGI_DEFAULT_FALLBACK_FEATURE_COUNT"] / np.maximum(ecgi_stats["ECGI_ANALYZED_FEATURE_ROWS"], 1)
    fm = fm.merge(ecgi_stats[["ECGI", "ECGI_DEFAULT_FALLBACK_FEATURE_COUNT", "ECGI_DEFAULT_FALLBACK_FEATURE_RATIO"]], on="ECGI", how="left", suffixes=("", "_NEW"))
    for c in ["ECGI_DEFAULT_FALLBACK_FEATURE_COUNT", "ECGI_DEFAULT_FALLBACK_FEATURE_RATIO"]:
        if f"{c}_NEW" in fm.columns:
            fm[c] = fm[f"{c}_NEW"].fillna(fm[c])
            fm = fm.drop(columns=[f"{c}_NEW"])

    sitewide = fallback & (
        (safe_numeric(fm["ECGI_DEFAULT_FALLBACK_FEATURE_COUNT"]) >= int(getattr(args, "sitewide_default_feature_threshold", 4)))
        | (safe_numeric(fm["ECGI_DEFAULT_FALLBACK_FEATURE_RATIO"]) >= float(getattr(args, "sitewide_default_ratio_threshold", 0.50)))
    )
    long_term = long_term | sitewide

    fm.loc[long_term, "LONG_TERM_DEFAULT_FALLBACK_FLAG"] = 1
    fm.loc[fallback & ~long_term, "FLUCTUATING_DEFAULT_FALLBACK_FLAG"] = 1
    fm.loc[fallback & ~long_term, "SHORT_TERM_DEFAULT_FALLBACK_FLAG"] = 1  # backward-compatible alias
    fm.loc[sitewide, "SITE_WIDE_LONG_TERM_DEFAULT_FALLBACK_SUSPECT_FLAG"] = 1
    fm.loc[fallback & long_term, "FALLBACK_DURATION_CLUSTER"] = "LONG_TERM_OR_SITE_WIDE"
    fm.loc[fallback & ~long_term, "FALLBACK_DURATION_CLUSTER"] = "FLUCTUATING_OR_SHORT_TERM"
    fm.loc[fallback & source_exists, "FALLBACK_SOURCE_DATA_CLUSTER"] = "SOURCE_EXISTS"
    fm.loc[fallback & ~source_exists, "FALLBACK_SOURCE_DATA_CLUSTER"] = "SOURCE_MISSING_OR_NOT_CHECKED"

    if fallback.any():
        fm.loc[fallback & long_term, "SEED_LABEL"] = "LONG_TERM_FALLBACK_TO_DEFAULT"
        fm.loc[fallback & ~long_term, "SEED_LABEL"] = "FLUCTUATING_FALLBACK_TO_DEFAULT"
        fm["SEED_RULE_SCORE"] = safe_numeric(fm["SEED_RULE_SCORE"])
        fm.loc[fallback & source_exists, "SEED_RULE_SCORE"] += 5.0
        fm.loc[fallback & (fm["DATA_SOURCE_COMPATIBILITY"] == "NO"), "SEED_RULE_SCORE"] += 6.0
        fm.loc[fallback & sitewide, "SEED_RULE_SCORE"] += 15.0
        fm["SEED_RULE_PERCENTILE"] = percentile_rank(fm["SEED_RULE_SCORE"])

    conf_weight = fm["SEED_LABEL"].map(label_confidence_and_weight)
    fm["SEED_LABEL_CONFIDENCE"] = [cw[0] for cw in conf_weight]
    fm["TRAINING_WEIGHT"] = [cw[1] for cw in conf_weight]
    fm["IS_REPORTABLE_PROBLEM"] = fm["SEED_LABEL"].isin(PROBLEM_LABELS).astype(int)
    fm["IS_SUPPRESSED_NORMAL"] = fm["SEED_LABEL"].isin(SUPPRESSOR_LABELS).astype(int)
    fm["NEEDS_MANUAL_REVIEW"] = fm["SEED_LABEL"].isin(HOLD_LABELS).astype(int)
    fm["TRAIN_FOR_MODEL_FLAG"] = (
        (safe_numeric(fm["SEED_LABEL_CONFIDENCE"]) >= float(getattr(args, "min_seed_confidence_for_training", 0.65)))
        & (safe_numeric(fm["TRAINING_WEIGHT"]) > 0)
        & (~fm["SEED_LABEL"].isin(HOLD_LABELS))
    ).astype(int)
    fm["FINAL_TRAINING_LABEL"] = fm["SEED_LABEL"]
    fm["RECOMMENDED_ACTION"] = fm["SEED_LABEL"].map(recommended_action).fillna("Manual review recommended.")
    fm["SOURCE_FEATURE_EVIDENCE_SUMMARY"] = fm.apply(
        lambda r: (
            f"{r['FEATURE']} latest source={short_value(r.get('LATEST_SOURCE_VALUE',''))}; "
            f"source changed on {int(r.get('SOURCE_CHANGE_DAYS_COUNT',0))}/{int(r.get('ANALYSIS_DAYS',0) or 0)} days; "
            f"distinct source values={int(r.get('DISTINCT_SOURCE_VALUES_30D',0))}; "
            f"seed_label={r['SEED_LABEL']}; fallback_duration={r.get('FALLBACK_DURATION_CLUSTER','')}; "
            f"data_source_compatibility={r.get('DATA_SOURCE_COMPATIBILITY','')}; "
            f"reference={r.get('REFERENCE_SOURCE_NAME','')}.{r.get('REFERENCE_COLUMN','')}={short_value(r.get('REFERENCE_VALUE',''))}; "
            f"score={float(r.get('SEED_RULE_SCORE',0)):.1f}."
        ),
        axis=1,
    )
    log(
        f"Reference/fallback refinement complete. Fallback labels: {fm.loc[fallback, 'SEED_LABEL'].value_counts().to_dict() if fallback.any() else {}}; "
        f"reference rows={int(safe_numeric(fm['REFERENCE_ROW_FOUND_FLAG']).sum()):,}; compatible YES={int((fm['DATA_SOURCE_COMPATIBILITY'] == 'YES').sum()):,}; compatible NO={int((fm['DATA_SOURCE_COMPATIBILITY'] == 'NO').sum()):,}",
        indent=1,
    )
    return fm


