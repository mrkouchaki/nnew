def is_id_like_col(col: str) -> bool:
    c = clean_col_name(col)
    return c in ID_LIKE_EXACT or c.endswith("_ID") or c.endswith("ID") or "CELLID" in c


def is_numeric_config_col(col: str) -> bool:
    c = clean_col_name(col)
    if is_id_like_col(c):
        return False
    return any(term in c for term in NUMERIC_CONFIG_TERMS)


def quote_ident(name: str) -> str:
    return '"' + str(name).replace('"', '""') + '"'


def sql_string(value: str) -> str:
    return "'" + str(value).replace("'", "''") + "'"


def sql_path(path: Path) -> str:
    return sql_string(str(path).replace("\\", "/"))


def chunks_list(items: List[str], size: int) -> List[List[str]]:
    size = max(1, int(size))
    return [items[i : i + size] for i in range(0, len(items), size)]


def import_duckdb():
    try:
        import duckdb  # type: ignore
        return duckdb
    except Exception as exc:
        raise RuntimeError(
            "DuckDB is required for V6 large CSV processing. Install once with:\n"
            "  python -m pip install duckdb\n"
            f"Original import error: {exc}"
        ) from exc


def open_duckdb(temp_db_path: Optional[Path], threads: int, memory_limit: Optional[str], duckdb_temp_dir: Optional[Path] = None):
    log("Opening DuckDB connection")
    duckdb = import_duckdb()
    if temp_db_path:
        temp_db_path.parent.mkdir(parents=True, exist_ok=True)
        log(f"DuckDB database file: {temp_db_path}", indent=1)
        con = duckdb.connect(str(temp_db_path))
    else:
        log("DuckDB database: in-memory", indent=1)
        con = duckdb.connect()
    try:
        con.execute("SET preserve_insertion_order=false")
    except Exception:
        pass
    if duckdb_temp_dir:
        duckdb_temp_dir.mkdir(parents=True, exist_ok=True)
        log(f"DuckDB spill/temp directory: {duckdb_temp_dir}", indent=1)
        try:
            con.execute(f"SET temp_directory={sql_string(str(duckdb_temp_dir))}")
        except Exception as exc:
            log(f"Warning: could not set DuckDB temp_directory: {exc}", indent=1)
    if threads and threads > 0:
        con.execute(f"PRAGMA threads={int(threads)}")
    if memory_limit:
        con.execute(f"PRAGMA memory_limit={sql_string(memory_limit)}")
    log(f"DuckDB settings: threads={threads}, memory_limit={memory_limit or 'default'}", indent=1)
    return con


def base_norm_expr(sql_expr: str) -> str:
    cleaned = f"UPPER(REGEXP_REPLACE(TRIM(CAST({sql_expr} AS VARCHAR)), '\\\\.0$', ''))"
    null_list = ", ".join(sql_string(x) for x in sorted(NULL_STRINGS))
    return f"CASE WHEN {sql_expr} IS NULL THEN NULL WHEN {cleaned} IN ({null_list}) THEN NULL ELSE {cleaned} END"


def compact_norm_expr(sql_expr: str) -> str:
    base = base_norm_expr(sql_expr)
    return f"CASE WHEN {base} IS NULL THEN NULL ELSE REGEXP_REPLACE({base}, '\\s+', '') END"


def feature_norm_expr(original_col: str, feature: str, latlon_decimals: int) -> str:
    q = quote_ident(original_col)
    base = compact_norm_expr(q)
    if is_numeric_config_col(feature):
        decimals = latlon_decimals if any(t in feature for t in ["LAT", "LON", "LONG"]) else 4
        return (
            f"CASE WHEN {base} IS NULL THEN NULL "
            f"WHEN TRY_CAST({base} AS DOUBLE) IS NOT NULL "
            f"THEN CAST(ROUND(TRY_CAST({base} AS DOUBLE), {int(decimals)}) AS VARCHAR) "
            f"ELSE {base} END"
        )
    return base


def date_parse_expr(original_col: str) -> str:
    q = quote_ident(original_col)
    trimmed = f"TRIM(CAST({q} AS VARCHAR))"
    return (
        "CAST(COALESCE("
        f"TRY_STRPTIME({trimmed}, '%Y-%m-%d %H:%M:%S'),"
        f"TRY_STRPTIME({trimmed}, '%Y-%m-%d'),"
        f"TRY_STRPTIME({trimmed}, '%m/%d/%Y %H:%M:%S'),"
        f"TRY_STRPTIME({trimmed}, '%m/%d/%Y'),"
        f"TRY_STRPTIME({trimmed}, '%d-%b-%y'),"
        f"TRY_STRPTIME({trimmed}, '%d-%b-%Y')"
        ") AS DATE)"
    )


def ecgi_expr_from_columns(colmap: Dict[str, str]) -> str:
    if "ECGI" in colmap:
        return compact_norm_expr(quote_ident(colmap["ECGI"]))
    required = ["MCC", "MNC", "CID"]
    if all(c in colmap for c in required):
        return (
            f"COALESCE({compact_norm_expr(quote_ident(colmap['MCC']))}, '') || '-' || "
            f"COALESCE({compact_norm_expr(quote_ident(colmap['MNC']))}, '') || '-' || "
            f"COALESCE({compact_norm_expr(quote_ident(colmap['CID']))}, '')"
        )
    raise ValueError("Input has no ECGI column and cannot build ECGI from MCC/MNC/CID.")


def read_header(input_path: Path) -> Tuple[List[str], Dict[str, str]]:
    log(f"Reading CSV header: {input_path}")
    header_df = pd.read_csv(input_path, nrows=0)
    original_cols = list(header_df.columns)
    log(f"Header columns detected: {len(original_cols):,}", indent=1)
    colmap = {clean_col_name(c): c for c in original_cols}
    return [clean_col_name(c) for c in original_cols], colmap


def detect_features(header_cols_clean: List[str], include_features: Optional[str], exclude_features: Optional[str]) -> List[str]:
    cols = set(header_cols_clean)
    if include_features:
        wanted = [clean_col_name(x) for x in include_features.split(",") if x.strip()]
    else:
        wanted = [f for f in DEFAULT_FEATURES if f in cols]
        skip = set(DATE_CANDIDATES + META_COLS + ["ECGI", "USID", "ON_AIR", "LAST_DB_MISMATCH", "DB_MISMATCH", "DELTA", "DELTA_STATUS_COLOR"])
        for c in header_cols_clean:
            if c.endswith("_DB") or c in wanted or c in skip:
                continue
            if is_numeric_config_col(c) or "NEIGHBOR" in c or c in {"CELLNAME", "CELLTYPE", "GEOTYPE"}:
                wanted.append(c)
    exclude = {clean_col_name(x) for x in exclude_features.split(",") if x.strip()} if exclude_features else set()
    return [f for f in wanted if f in cols and not f.endswith("_DB") and f not in exclude]


def load_feature_rules(defaults_json: Optional[str]) -> Dict[str, Dict[str, Any]]:
    rules = json.loads(json.dumps(BUILTIN_FEATURE_RULES))
    if defaults_json:
        p = Path(defaults_json).expanduser()
        if not p.exists():
            raise FileNotFoundError(f"--defaults-json file not found: {p}")
        extra = json.loads(p.read_text(encoding="utf-8"))
        for k, v in extra.items():
            fk = clean_col_name(k)
            current = rules.get(fk, {})
            current.update(v or {})
            rules[fk] = current
    for _, cfg in rules.items():
        vals = cfg.get("default_values", []) or []
        cfg["default_values_norm"] = sorted({normalize_value_text(x) for x in vals if normalize_value_text(x)})
    return rules


def get_feature_weight(feature: str, rules: Dict[str, Dict[str, Any]]) -> float:
    return float(rules.get(clean_col_name(feature), {}).get("criticality_weight", 5.0))


def value_is_default(feature: str, value: object, rules: Dict[str, Dict[str, Any]]) -> int:
    f = clean_col_name(feature)
    v = normalize_value_text(value)
    defaults = set(rules.get(f, {}).get("default_values_norm", []))
    return int(bool(v and v in defaults))


def value_is_invalid(feature: str, value: object, rules: Dict[str, Dict[str, Any]]) -> int:
    f = clean_col_name(feature)
    cfg = rules.get(f, {})
    if "valid_min" not in cfg and "valid_max" not in cfg:
        return 0
    v = normalize_value_text(value)
    if not v:
        return 0
    try:
        x = float(v)
    except Exception:
        return 0
    if "valid_min" in cfg and x < float(cfg["valid_min"]):
        return 1
    if "valid_max" in cfg and x > float(cfg["valid_max"]):
        return 1
    return 0


def create_latest_db_mismatch_candidates(con, input_path: Path, colmap: Dict[str, str], date_col_clean: str, days: int, end_date: Optional[str], server_id_filter: Optional[str]) -> Dict[str, Any]:
    header("PHASE 1A - LATEST-DAY DB_MISMATCH CANDIDATE EXTRACTION")
    if "DB_MISMATCH" not in colmap:
        raise ValueError("DB_MISMATCH column is required for V6 candidate gating.")

    file_sql = sql_path(input_path)
    date_expr = date_parse_expr(colmap[date_col_clean])
    ecgi_expr = ecgi_expr_from_columns(colmap)
    db_mismatch_expr = compact_norm_expr(quote_ident(colmap["DB_MISMATCH"]))

    meta_selects = []
    for m in META_COLS:
        if m in colmap:
            meta_selects.append(f"{compact_norm_expr(quote_ident(colmap[m]))} AS {quote_ident(m)}")
        else:
            meta_selects.append(f"NULL AS {quote_ident(m)}")

    # Keep lightweight latest-row context columns for reference-source matching.
    # These are not used as target labels; they help match Atoll/Ericsson/CSSNG rows when ECGI is absent.
    context_selects = []
    context_cols = []
    for c in CANDIDATE_CONTEXT_COLS:
        cc = clean_col_name(c)
        if cc in colmap and cc not in set(META_COLS + ["ECGI", "DB_MISMATCH"]):
            if cc not in context_cols:
                context_cols.append(cc)
                context_selects.append(f"{compact_norm_expr(quote_ident(colmap[cc]))} AS {quote_ident(cc)}")

    raw_select_parts = [
        f"{date_expr} AS LOAD_DATE",
        f"{ecgi_expr} AS ECGI",
        *meta_selects,
        *context_selects,
        f"{db_mismatch_expr} AS DB_MISMATCH",
    ]
    raw_select_sql = ",\n            ".join(raw_select_parts)

    stats_sql = f"""
    WITH raw AS (
        SELECT {date_expr} AS LOAD_DATE
        FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
    )
    SELECT MIN(LOAD_DATE) AS MIN_LOAD_DATE,
           MAX(LOAD_DATE) AS MAX_LOAD_DATE,
           COUNT(DISTINCT LOAD_DATE) AS DISTINCT_LOAD_DAYS
    FROM raw
    WHERE LOAD_DATE IS NOT NULL
    """
    stats = con.execute(stats_sql).fetchdf()
    if stats.empty or pd.isna(stats.loc[0, "MAX_LOAD_DATE"]):
        raise RuntimeError("Could not parse valid LOAD_DATE values from input CSV.")

    raw_min_date = pd.to_datetime(stats.loc[0, "MIN_LOAD_DATE"]).normalize()
    raw_max_date = pd.to_datetime(stats.loc[0, "MAX_LOAD_DATE"]).normalize()
    max_date = pd.to_datetime(end_date).normalize() if end_date else raw_max_date
    min_date = max_date - pd.Timedelta(days=int(days) - 1)

    log(f"Detected raw date range: {raw_min_date.date()} to {raw_max_date.date()}; distinct load days={int(stats.loc[0, 'DISTINCT_LOAD_DAYS'])}", indent=1)
    log(f"Analysis window selected: {min_date.date()} to {max_date.date()} ({days} requested days)", indent=1)
    log(f"Latest candidate date: {max_date.date()}", indent=1)
    if context_cols:
        log(f"Latest candidate context columns retained for reference matching: {', '.join(context_cols)}", indent=1)

    server_filter_sql = ""
    if server_id_filter:
        server_filter_sql = f"AND SERVER_ID = {sql_string(server_id_filter.strip().upper())}"

    final_context_selects = [f"ANY_VALUE({quote_ident(c)}) AS {quote_ident(c)}" for c in context_cols]
    final_select_parts = [
        "ECGI",
        "ANY_VALUE(REGION) AS REGION",
        "ANY_VALUE(MARKETCLUSTER) AS MARKETCLUSTER",
        "ANY_VALUE(MARKET) AS MARKET",
        "ANY_VALUE(SUBMARKET) AS SUBMARKET",
        "ANY_VALUE(SERVER_ID) AS SERVER_ID",
        *final_context_selects,
        "COUNT(*) AS LATEST_DB_MISMATCH_RAW_ROWS",
        f"DATE {sql_string(str(max_date.date()))} AS LATEST_CANDIDATE_DATE",
    ]
    final_select_sql = ",\n        ".join(final_select_parts)

    con.execute("DROP TABLE IF EXISTS candidate_ecgis")
    candidate_sql = f"""
    CREATE TABLE candidate_ecgis AS
    WITH raw AS (
        SELECT
            {raw_select_sql}
        FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
    ), latest_mismatch_rows AS (
        SELECT *
        FROM raw
        WHERE LOAD_DATE = DATE {sql_string(str(max_date.date()))}
          AND DB_MISMATCH = 'YES'
          AND ECGI IS NOT NULL AND ECGI <> ''
          {server_filter_sql}
    )
    SELECT
        {final_select_sql}
    FROM latest_mismatch_rows
    GROUP BY ECGI
    """
    con.execute(candidate_sql)

    raw_latest_stats_sql = f"""
    WITH raw AS (
        SELECT
            {date_expr} AS LOAD_DATE,
            {ecgi_expr} AS ECGI,
            {', '.join(meta_selects)},
            {db_mismatch_expr} AS DB_MISMATCH
        FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
    )
    SELECT
        COUNT(*) AS LATEST_RAW_ROWS,
        SUM(CASE WHEN DB_MISMATCH = 'YES' THEN 1 ELSE 0 END) AS LATEST_DB_MISMATCH_YES_ROWS,
        COUNT(DISTINCT ECGI) FILTER (WHERE DB_MISMATCH = 'YES') AS LATEST_DB_MISMATCH_YES_ECGIS
    FROM raw
    WHERE LOAD_DATE = DATE {sql_string(str(max_date.date()))}
      {server_filter_sql}
    """
    raw_latest_stats = con.execute(raw_latest_stats_sql).fetchdf().iloc[0].to_dict()
    candidate_count = int(con.execute("SELECT COUNT(*) FROM candidate_ecgis").fetchone()[0] or 0)
    log(f"Latest-day raw rows scanned: {int(raw_latest_stats.get('LATEST_RAW_ROWS') or 0):,}", indent=1)
    log(f"Latest-day DB_MISMATCH='YES' raw rows: {int(raw_latest_stats.get('LATEST_DB_MISMATCH_YES_ROWS') or 0):,}", indent=1)
    log(f"Distinct candidate ECGIs: {candidate_count:,}", indent=1)

    if candidate_count == 0:
        raise RuntimeError(f"No candidate ECGIs found for LOAD_DATE={max_date.date()} with DB_MISMATCH='YES'.")

    return {
        "script_version": SCRIPT_VERSION,
        "input_file": str(input_path),
        "requested_days": int(days),
        "window_start_date": str(min_date.date()),
        "window_end_date": str(max_date.date()),
        "candidate_date": str(max_date.date()),
        "raw_min_load_date": str(raw_min_date.date()),
        "raw_max_load_date": str(raw_max_date.date()),
        "raw_distinct_load_days": int(stats.loc[0, "DISTINCT_LOAD_DAYS"]),
        "server_id_filter": server_id_filter or "",
        "latest_raw_rows": int(raw_latest_stats.get("LATEST_RAW_ROWS") or 0),
        "latest_db_mismatch_yes_rows": int(raw_latest_stats.get("LATEST_DB_MISMATCH_YES_ROWS") or 0),
        "latest_db_mismatch_candidate_ecgis": candidate_count,
        "candidate_context_columns": ",".join(context_cols),
        "ranking_mode": "latest-day DB_MISMATCH ECGI gate + source-history seed labels + optional RAN reference-source compatibility",
    }

def create_event_tables(con) -> None:
    con.execute("DROP TABLE IF EXISTS source_change_events")
    con.execute(
        """
        CREATE TABLE source_change_events (
            ECGI VARCHAR,
            FEATURE VARCHAR,
            LOAD_DATE DATE,
            PREVIOUS_LOAD_DATE DATE,
            PREVIOUS_SOURCE_VALUE VARCHAR,
            CURRENT_SOURCE_VALUE VARCHAR,
            RAW_ROWS_PER_ECGI_DATE BIGINT,
            SOURCE_VALUES_UNIQUE_COUNT BIGINT,
            REGION VARCHAR,
            MARKETCLUSTER VARCHAR,
            MARKET VARCHAR,
            SUBMARKET VARCHAR,
            SERVER_ID VARCHAR,
            A_B_A_REVERT_FLAG INTEGER
        )
        """
    )
    con.execute("DROP TABLE IF EXISTS source_same_day_conflicts")
    con.execute(
        """
        CREATE TABLE source_same_day_conflicts (
            ECGI VARCHAR,
            FEATURE VARCHAR,
            LOAD_DATE DATE,
            REPRESENTATIVE_SOURCE_VALUE VARCHAR,
            SOURCE_VALUES_UNIQUE_COUNT BIGINT,
            RAW_ROWS_PER_ECGI_DATE BIGINT,
            REGION VARCHAR,
            MARKETCLUSTER VARCHAR,
            MARKET VARCHAR,
            SUBMARKET VARCHAR,
            SERVER_ID VARCHAR
        )
        """
    )
    con.execute("DROP TABLE IF EXISTS source_feature_history_metrics")
    con.execute(
        """
        CREATE TABLE source_feature_history_metrics (
            ECGI VARCHAR,
            FEATURE VARCHAR,
            REGION VARCHAR,
            MARKETCLUSTER VARCHAR,
            MARKET VARCHAR,
            SUBMARKET VARCHAR,
            SERVER_ID VARCHAR,
            OBSERVED_DAYS_FOR_FEATURE BIGINT,
            FIRST_OBSERVED_DATE DATE,
            LAST_OBSERVED_DATE DATE,
            FIRST_SOURCE_VALUE VARCHAR,
            LATEST_SOURCE_VALUE VARCHAR,
            PREVIOUS_NONLATEST_SOURCE_VALUE VARCHAR,
            DISTINCT_SOURCE_VALUES_30D BIGINT,
            MODE_SOURCE_VALUE VARCHAR,
            MODE_SOURCE_VALUE_DAYS BIGINT,
            MODE_SOURCE_VALUE_SHARE_PERCENT DOUBLE,
            LATEST_SOURCE_VALUE_DAYS BIGINT,
            LATEST_SOURCE_VALUE_FIRST_SEEN_DATE DATE,
            LATEST_SOURCE_VALUE_LAST_SEEN_DATE DATE,
            RAW_ROWS_FOR_FEATURE BIGINT,
            DB_CHECK_AVAILABLE_FLAG INTEGER,
            FIRST_DB_VALUE VARCHAR,
            LATEST_DB_VALUE VARCHAR,
            PREVIOUS_NONLATEST_DB_VALUE VARCHAR,
            DISTINCT_DB_VALUES_30D BIGINT,
            LATEST_DB_VALUE_DAYS BIGINT,
            DB_VALUE_PRESENT_DAYS BIGINT,
            SOURCE_DB_MISMATCH_DAYS BIGINT,
            LATEST_SOURCE_DB_MISMATCH_FLAG INTEGER
        )
        """
    )


def insert_history_metrics_for_feature(con, feature: str, has_db_value: bool) -> None:
    val = quote_ident(feature + "__VALUE")
    db_val = quote_ident(feature + "__DB_VALUE") if has_db_value else "CAST(NULL AS VARCHAR)"
    fsql = sql_string(feature)

    insert_sql = f"""
    INSERT INTO source_feature_history_metrics
    WITH daily AS (
        SELECT
            ECGI,
            LOAD_DATE,
            {val} AS SOURCE_VALUE,
            {db_val} AS DB_VALUE,
            RAW_ROWS_PER_ECGI_DATE,
            REGION,
            MARKETCLUSTER,
            MARKET,
            SUBMARKET,
            SERVER_ID
        FROM feature_daily_batch
        WHERE {val} IS NOT NULL
    ), agg AS (
        SELECT
            ECGI,
            ANY_VALUE(REGION) AS REGION,
            ANY_VALUE(MARKETCLUSTER) AS MARKETCLUSTER,
            ANY_VALUE(MARKET) AS MARKET,
            ANY_VALUE(SUBMARKET) AS SUBMARKET,
            ANY_VALUE(SERVER_ID) AS SERVER_ID,
            COUNT(*) AS OBSERVED_DAYS_FOR_FEATURE,
            MIN(LOAD_DATE) AS FIRST_OBSERVED_DATE,
            MAX(LOAD_DATE) AS LAST_OBSERVED_DATE,
            COUNT(DISTINCT SOURCE_VALUE) AS DISTINCT_SOURCE_VALUES_30D,
            SUM(RAW_ROWS_PER_ECGI_DATE) AS RAW_ROWS_FOR_FEATURE,
            COUNT(*) FILTER (WHERE DB_VALUE IS NOT NULL) AS DB_VALUE_PRESENT_DAYS,
            COUNT(DISTINCT DB_VALUE) FILTER (WHERE DB_VALUE IS NOT NULL) AS DISTINCT_DB_VALUES_30D,
            SUM(CASE WHEN SOURCE_VALUE IS NOT NULL AND DB_VALUE IS NOT NULL AND SOURCE_VALUE <> DB_VALUE THEN 1 ELSE 0 END) AS SOURCE_DB_MISMATCH_DAYS
        FROM daily
        GROUP BY ECGI
    ), first_value AS (
        SELECT ECGI, SOURCE_VALUE AS FIRST_SOURCE_VALUE, DB_VALUE AS FIRST_DB_VALUE
        FROM (
            SELECT ECGI, SOURCE_VALUE, DB_VALUE, LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY ECGI ORDER BY LOAD_DATE ASC, SOURCE_VALUE ASC) AS rn
            FROM daily
        ) x
        WHERE rn = 1
    ), latest_value AS (
        SELECT ECGI, SOURCE_VALUE AS LATEST_SOURCE_VALUE, DB_VALUE AS LATEST_DB_VALUE
        FROM (
            SELECT ECGI, SOURCE_VALUE, DB_VALUE, LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY ECGI ORDER BY LOAD_DATE DESC, SOURCE_VALUE ASC) AS rn
            FROM daily
        ) x
        WHERE rn = 1
    ), previous_nonlatest AS (
        SELECT ECGI, SOURCE_VALUE AS PREVIOUS_NONLATEST_SOURCE_VALUE
        FROM (
            SELECT d.ECGI, d.SOURCE_VALUE, d.LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY d.ECGI ORDER BY d.LOAD_DATE DESC, d.SOURCE_VALUE ASC) AS rn
            FROM daily d
            JOIN latest_value l ON d.ECGI = l.ECGI
            WHERE d.SOURCE_VALUE <> l.LATEST_SOURCE_VALUE
        ) x
        WHERE rn = 1
    ), previous_nonlatest_db AS (
        SELECT ECGI, DB_VALUE AS PREVIOUS_NONLATEST_DB_VALUE
        FROM (
            SELECT d.ECGI, d.DB_VALUE, d.LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY d.ECGI ORDER BY d.LOAD_DATE DESC, d.DB_VALUE ASC) AS rn
            FROM daily d
            JOIN latest_value l ON d.ECGI = l.ECGI
            WHERE d.DB_VALUE IS NOT NULL AND l.LATEST_DB_VALUE IS NOT NULL AND d.DB_VALUE <> l.LATEST_DB_VALUE
        ) x
        WHERE rn = 1
    ), source_value_counts AS (
        SELECT
            ECGI,
            SOURCE_VALUE,
            COUNT(*) AS VALUE_DAYS,
            MIN(LOAD_DATE) AS VALUE_FIRST_SEEN_DATE,
            MAX(LOAD_DATE) AS VALUE_LAST_SEEN_DATE
        FROM daily
        GROUP BY ECGI, SOURCE_VALUE
    ), mode_value AS (
        SELECT ECGI,
               SOURCE_VALUE AS MODE_SOURCE_VALUE,
               VALUE_DAYS AS MODE_SOURCE_VALUE_DAYS
        FROM (
            SELECT ECGI, SOURCE_VALUE, VALUE_DAYS,
                   ROW_NUMBER() OVER (PARTITION BY ECGI ORDER BY VALUE_DAYS DESC, SOURCE_VALUE ASC) AS rn
            FROM source_value_counts
        ) x
        WHERE rn = 1
    ), latest_counts AS (
        SELECT
            v.ECGI,
            v.VALUE_DAYS AS LATEST_SOURCE_VALUE_DAYS,
            v.VALUE_FIRST_SEEN_DATE AS LATEST_SOURCE_VALUE_FIRST_SEEN_DATE,
            v.VALUE_LAST_SEEN_DATE AS LATEST_SOURCE_VALUE_LAST_SEEN_DATE
        FROM source_value_counts v
        JOIN latest_value l ON v.ECGI = l.ECGI AND v.SOURCE_VALUE = l.LATEST_SOURCE_VALUE
    ), db_value_counts AS (
        SELECT ECGI, DB_VALUE, COUNT(*) AS DB_VALUE_DAYS
        FROM daily
        WHERE DB_VALUE IS NOT NULL
        GROUP BY ECGI, DB_VALUE
    ), latest_db_counts AS (
        SELECT v.ECGI, v.DB_VALUE_DAYS AS LATEST_DB_VALUE_DAYS
        FROM db_value_counts v
        JOIN latest_value l ON v.ECGI = l.ECGI AND v.DB_VALUE = l.LATEST_DB_VALUE
    )
    SELECT
        a.ECGI,
        {fsql} AS FEATURE,
        a.REGION,
        a.MARKETCLUSTER,
        a.MARKET,
        a.SUBMARKET,
        a.SERVER_ID,
        a.OBSERVED_DAYS_FOR_FEATURE,
        a.FIRST_OBSERVED_DATE,
        a.LAST_OBSERVED_DATE,
        f.FIRST_SOURCE_VALUE,
        l.LATEST_SOURCE_VALUE,
        p.PREVIOUS_NONLATEST_SOURCE_VALUE,
        a.DISTINCT_SOURCE_VALUES_30D,
        m.MODE_SOURCE_VALUE,
        m.MODE_SOURCE_VALUE_DAYS,
        100.0 * COALESCE(m.MODE_SOURCE_VALUE_DAYS, 0) / NULLIF(a.OBSERVED_DAYS_FOR_FEATURE, 0) AS MODE_SOURCE_VALUE_SHARE_PERCENT,
        lc.LATEST_SOURCE_VALUE_DAYS,
        lc.LATEST_SOURCE_VALUE_FIRST_SEEN_DATE,
        lc.LATEST_SOURCE_VALUE_LAST_SEEN_DATE,
        a.RAW_ROWS_FOR_FEATURE,
        CASE WHEN {1 if has_db_value else 0} = 1 AND COALESCE(a.DB_VALUE_PRESENT_DAYS, 0) > 0 THEN 1 ELSE 0 END AS DB_CHECK_AVAILABLE_FLAG,
        f.FIRST_DB_VALUE,
        l.LATEST_DB_VALUE,
        pdb.PREVIOUS_NONLATEST_DB_VALUE,
        COALESCE(a.DISTINCT_DB_VALUES_30D, 0) AS DISTINCT_DB_VALUES_30D,
        COALESCE(ldc.LATEST_DB_VALUE_DAYS, 0) AS LATEST_DB_VALUE_DAYS,
        COALESCE(a.DB_VALUE_PRESENT_DAYS, 0) AS DB_VALUE_PRESENT_DAYS,
        COALESCE(a.SOURCE_DB_MISMATCH_DAYS, 0) AS SOURCE_DB_MISMATCH_DAYS,
        CASE WHEN l.LATEST_SOURCE_VALUE IS NOT NULL AND l.LATEST_DB_VALUE IS NOT NULL AND l.LATEST_SOURCE_VALUE <> l.LATEST_DB_VALUE THEN 1 ELSE 0 END AS LATEST_SOURCE_DB_MISMATCH_FLAG
    FROM agg a
    LEFT JOIN first_value f ON a.ECGI = f.ECGI
    LEFT JOIN latest_value l ON a.ECGI = l.ECGI
    LEFT JOIN previous_nonlatest p ON a.ECGI = p.ECGI
    LEFT JOIN previous_nonlatest_db pdb ON a.ECGI = pdb.ECGI
    LEFT JOIN mode_value m ON a.ECGI = m.ECGI
    LEFT JOIN latest_counts lc ON a.ECGI = lc.ECGI
    LEFT JOIN latest_db_counts ldc ON a.ECGI = ldc.ECGI
    """
    con.execute(insert_sql)


def create_candidate_source_history_batched(con, input_path: Path, colmap: Dict[str, str], date_col_clean: str, features: List[str], analysis_info: Dict[str, Any], latlon_decimals: int, feature_batch_size: int, enable_db_push_check: bool) -> None:
    header("PHASE 1C - BUILD 30-DAY SOURCE HISTORY FOR CANDIDATE ECGIS")
    log("Only latest-day DB_MISMATCH candidate ECGIs are pulled into the 30-day history scan.", indent=1)
    if enable_db_push_check:
        log("Narrow FEATURE_DB history is enabled ONLY for AUDIT_PUSH_NOT_APPLIED seed/check logic.", indent=1)
    else:
        log("FEATURE_DB columns are not used. Stable-source rows will be marked for optional DB push check.", indent=1)

    file_sql = sql_path(input_path)
    date_expr = date_parse_expr(colmap[date_col_clean])
    ecgi_sql = ecgi_expr_from_columns(colmap)
    min_date_sql = analysis_info["window_start_date"]
    max_date_sql = analysis_info["window_end_date"]

    create_event_tables(con)

    meta_selects = []
    for m in META_COLS:
        if m in colmap:
            meta_selects.append(f"{compact_norm_expr(quote_ident(colmap[m]))} AS {quote_ident(m)}")
        else:
            meta_selects.append(f"NULL AS {quote_ident(m)}")

    batches = chunks_list(features, feature_batch_size)
    log(f"Processing {len(features)} feature(s) in {len(batches)} batch(es); feature_batch_size={feature_batch_size}", indent=1)

    total_daily_rows = 0
    db_cols_available = []
    for batch_no, batch in enumerate(batches, start=1):
        log(f"Feature batch {batch_no}/{len(batches)}: {', '.join(batch)}", indent=1)
        batch_start = time.time()

        feature_selects = []
        for f in batch:
            feature_selects.append(f"{feature_norm_expr(colmap[f], f, latlon_decimals)} AS {quote_ident(f)}")
            db_clean = f"{f}_DB"
            if enable_db_push_check and db_clean in colmap:
                feature_selects.append(f"{feature_norm_expr(colmap[db_clean], f, latlon_decimals)} AS {quote_ident(f + '_DB')}" )
                db_cols_available.append(f)
        raw_cte_select = ",\n                ".join([f"{date_expr} AS LOAD_DATE", f"{ecgi_sql} AS ECGI", *meta_selects, *feature_selects])

        agg_parts = [
            "ANY_VALUE(REGION) AS REGION",
            "ANY_VALUE(MARKETCLUSTER) AS MARKETCLUSTER",
            "ANY_VALUE(MARKET) AS MARKET",
            "ANY_VALUE(SUBMARKET) AS SUBMARKET",
            "ANY_VALUE(SERVER_ID) AS SERVER_ID",
            "COUNT(*) AS RAW_ROWS_PER_ECGI_DATE",
        ]
        for f in batch:
            fq = quote_ident(f)
            agg_parts.append(f"MIN({fq}) FILTER (WHERE {fq} IS NOT NULL) AS {quote_ident(f + '__VALUE')}")
            agg_parts.append(f"COUNT(DISTINCT {fq}) FILTER (WHERE {fq} IS NOT NULL) AS {quote_ident(f + '__UNIQUE_COUNT')}")
            db_clean = f"{f}_DB"
            if enable_db_push_check and db_clean in colmap:
                dbq = quote_ident(db_clean)
                agg_parts.append(f"MIN({dbq}) FILTER (WHERE {dbq} IS NOT NULL) AS {quote_ident(f + '__DB_VALUE')}")
                agg_parts.append(f"COUNT(DISTINCT {dbq}) FILTER (WHERE {dbq} IS NOT NULL) AS {quote_ident(f + '__DB_UNIQUE_COUNT')}")
            else:
                agg_parts.append(f"CAST(NULL AS VARCHAR) AS {quote_ident(f + '__DB_VALUE')}")
                agg_parts.append(f"CAST(0 AS BIGINT) AS {quote_ident(f + '__DB_UNIQUE_COUNT')}")
        agg_sql = ",\n            ".join(agg_parts)

        con.execute("DROP TABLE IF EXISTS feature_daily_batch")
        create_batch_sql = f"""
        CREATE TEMPORARY TABLE feature_daily_batch AS
        WITH raw AS (
            SELECT
                {raw_cte_select}
            FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
        ), filtered AS (
            SELECT r.*
            FROM raw r
            JOIN candidate_ecgis c ON r.ECGI = c.ECGI
            WHERE r.LOAD_DATE BETWEEN DATE {sql_string(min_date_sql)} AND DATE {sql_string(max_date_sql)}
              AND r.ECGI IS NOT NULL AND r.ECGI <> ''
        )
        SELECT
            LOAD_DATE,
            ECGI,
            {agg_sql}
        FROM filtered
        GROUP BY LOAD_DATE, ECGI
        """
        con.execute(create_batch_sql)
        daily_rows = int(con.execute("SELECT COUNT(*) FROM feature_daily_batch").fetchone()[0] or 0)
        total_daily_rows += daily_rows
        log(f"Candidate ECGI/day rows in batch: {daily_rows:,}", indent=2)

        for f in batch:
            log(f"Extracting source history metrics/events for {f}", indent=2)
            val = quote_ident(f + "__VALUE")
            uniq = quote_ident(f + "__UNIQUE_COUNT")
            fsql = sql_string(f)
            has_db_value = bool(enable_db_push_check and f"{f}_DB" in colmap)
            insert_history_metrics_for_feature(con, f, has_db_value=has_db_value)

            change_sql = f"""
            INSERT INTO source_change_events
            SELECT
                ECGI,
                {fsql} AS FEATURE,
                LOAD_DATE,
                PREVIOUS_LOAD_DATE,
                PREVIOUS_SOURCE_VALUE,
                CURRENT_SOURCE_VALUE,
                RAW_ROWS_PER_ECGI_DATE,
                SOURCE_VALUES_UNIQUE_COUNT,
                REGION,
                MARKETCLUSTER,
                MARKET,
                SUBMARKET,
                SERVER_ID,
                CASE
                    WHEN TWO_OBS_BACK_SOURCE_VALUE IS NOT NULL
                     AND CURRENT_SOURCE_VALUE = TWO_OBS_BACK_SOURCE_VALUE
                     AND CURRENT_SOURCE_VALUE <> PREVIOUS_SOURCE_VALUE
                    THEN 1 ELSE 0
                END AS A_B_A_REVERT_FLAG
            FROM (
                SELECT
                    ECGI,
                    LOAD_DATE,
                    LAG(LOAD_DATE) OVER (PARTITION BY ECGI ORDER BY LOAD_DATE) AS PREVIOUS_LOAD_DATE,
                    LAG({val}) OVER (PARTITION BY ECGI ORDER BY LOAD_DATE) AS PREVIOUS_SOURCE_VALUE,
                    LAG({val}, 2) OVER (PARTITION BY ECGI ORDER BY LOAD_DATE) AS TWO_OBS_BACK_SOURCE_VALUE,
                    {val} AS CURRENT_SOURCE_VALUE,
                    RAW_ROWS_PER_ECGI_DATE,
                    {uniq} AS SOURCE_VALUES_UNIQUE_COUNT,
                    REGION,
                    MARKETCLUSTER,
                    MARKET,
                    SUBMARKET,
                    SERVER_ID
                FROM feature_daily_batch
                WHERE {val} IS NOT NULL
            ) x
            WHERE PREVIOUS_SOURCE_VALUE IS NOT NULL
              AND CURRENT_SOURCE_VALUE <> PREVIOUS_SOURCE_VALUE
            """
            con.execute(change_sql)

            conflict_sql = f"""
            INSERT INTO source_same_day_conflicts
            SELECT
                ECGI,
                {fsql} AS FEATURE,
                LOAD_DATE,
                {val} AS REPRESENTATIVE_SOURCE_VALUE,
                {uniq} AS SOURCE_VALUES_UNIQUE_COUNT,
                RAW_ROWS_PER_ECGI_DATE,
                REGION,
                MARKETCLUSTER,
                MARKET,
                SUBMARKET,
                SERVER_ID
            FROM feature_daily_batch
            WHERE COALESCE({uniq}, 0) > 1
            """
            con.execute(conflict_sql)

        changes_count = int(con.execute("SELECT COUNT(*) FROM source_change_events").fetchone()[0] or 0)
        conflicts_count = int(con.execute("SELECT COUNT(*) FROM source_same_day_conflicts").fetchone()[0] or 0)
        hist_count = int(con.execute("SELECT COUNT(*) FROM source_feature_history_metrics").fetchone()[0] or 0)
        con.execute("DROP TABLE IF EXISTS feature_daily_batch")
        log(f"Batch complete in {time.time() - batch_start:.1f}s; cumulative changes={changes_count:,}; conflicts={conflicts_count:,}; feature-history rows={hist_count:,}", indent=1)

    log(f"Total candidate ECGI/day rows processed across batches: {total_daily_rows:,}", indent=1)
    if enable_db_push_check:
        log(f"FEATURE_DB columns available for narrow push check: {len(set(db_cols_available)):,} ({', '.join(sorted(set(db_cols_available)))})", indent=1)


def load_compact_tables(con) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    header("PHASE 1D - LOAD COMPACT HISTORY TABLES FOR SEED LABELING")
    candidates = con.execute("SELECT * FROM candidate_ecgis").fetchdf()
    hist = con.execute("SELECT * FROM source_feature_history_metrics").fetchdf()
    changes = con.execute("SELECT * FROM source_change_events").fetchdf()
    conflicts = con.execute("SELECT * FROM source_same_day_conflicts").fetchdf()

    for df in [candidates, hist, changes, conflicts]:
        df.columns = [clean_col_name(c) for c in df.columns]
        for c in [
            "LOAD_DATE", "PREVIOUS_LOAD_DATE", "FIRST_OBSERVED_DATE", "LAST_OBSERVED_DATE",
            "LATEST_SOURCE_VALUE_FIRST_SEEN_DATE", "LATEST_SOURCE_VALUE_LAST_SEEN_DATE",
            "LATEST_CANDIDATE_DATE",
        ]:
            if c in df.columns:
                df[c] = pd.to_datetime(df[c], errors="coerce").dt.normalize()
        if "ECGI" in df.columns:
            df["ECGI"] = df["ECGI"].map(normalize_key_value)
        if "FEATURE" in df.columns:
            df["FEATURE"] = df["FEATURE"].map(clean_col_name)

    value_cols = [
        "FIRST_SOURCE_VALUE", "LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "MODE_SOURCE_VALUE",
        "FIRST_DB_VALUE", "LATEST_DB_VALUE", "PREVIOUS_NONLATEST_DB_VALUE",
        "PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE", "REPRESENTATIVE_SOURCE_VALUE",
    ]
    for c in value_cols:
        for df in [hist, changes, conflicts]:
            if c in df.columns:
                df[c] = df[c].map(normalize_value_text)

    log(f"Candidate ECGIs: {len(candidates):,}", indent=1)
    log(f"Feature-history metric rows: {len(hist):,}", indent=1)
    log(f"Source-change event rows: {len(changes):,}", indent=1)
    log(f"Same-day conflict rows: {len(conflicts):,}", indent=1)
    return candidates, hist, changes, conflicts


def compute_reverse_transition_flags(changes: pd.DataFrame) -> pd.DataFrame:
    if changes.empty:
        changes["REVERSE_TRANSITION_FLAG"] = pd.Series(dtype=int)
        return changes
    changes = changes.sort_values(["ECGI", "FEATURE", "LOAD_DATE", "PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE"]).reset_index(drop=True)
    flags: List[int] = []
    seen: Dict[Tuple[str, str], set] = {}
    for _, row in changes.iterrows():
        key = (str(row["ECGI"]), str(row["FEATURE"]))
        prev = normalize_value_text(row.get("PREVIOUS_SOURCE_VALUE", ""))
        cur = normalize_value_text(row.get("CURRENT_SOURCE_VALUE", ""))
        flags.append(1 if (cur, prev) in seen.get(key, set()) else 0)
        seen.setdefault(key, set()).add((prev, cur))
    changes["REVERSE_TRANSITION_FLAG"] = flags
    return changes


def build_change_stats(changes: pd.DataFrame, candidate_date: pd.Timestamp, total_candidate_ecgis: int) -> pd.DataFrame:
    if changes.empty:
        return pd.DataFrame(columns=["ECGI", "FEATURE"])
    changes = compute_reverse_transition_flags(changes)
    changes["TRANSITION_EDGE"] = changes["PREVIOUS_SOURCE_VALUE"].astype(str) + "->" + changes["CURRENT_SOURCE_VALUE"].astype(str)

    stats = changes.groupby(["ECGI", "FEATURE"], dropna=False).agg(
        SOURCE_CHANGE_COUNT=("LOAD_DATE", "size"),
        SOURCE_CHANGE_DAYS_COUNT=("LOAD_DATE", "nunique"),
        SOURCE_FIRST_CHANGE_DATE=("LOAD_DATE", "min"),
        SOURCE_LAST_CHANGE_DATE=("LOAD_DATE", "max"),
        SOURCE_A_B_A_REVERT_COUNT=("A_B_A_REVERT_FLAG", "sum"),
        SOURCE_REVERSE_TRANSITION_COUNT=("REVERSE_TRANSITION_FLAG", "sum"),
        RAW_ROWS_SUPPORTING_SOURCE_CHANGES=("RAW_ROWS_PER_ECGI_DATE", "sum"),
        DISTINCT_PREVIOUS_SOURCE_VALUES_COUNT=("PREVIOUS_SOURCE_VALUE", pd.Series.nunique),
        DISTINCT_CURRENT_SOURCE_VALUES_COUNT=("CURRENT_SOURCE_VALUE", pd.Series.nunique),
        UNIQUE_TRANSITION_EDGE_COUNT=("TRANSITION_EDGE", pd.Series.nunique),
    ).reset_index()

    edge_repeat = changes.groupby(["ECGI", "FEATURE", "TRANSITION_EDGE"], as_index=False).size()
    max_repeat = edge_repeat.groupby(["ECGI", "FEATURE"], as_index=False).agg(MAX_REPEATED_TRANSITION_EDGE_COUNT=("size", "max"))
    stats = stats.merge(max_repeat, on=["ECGI", "FEATURE"], how="left")

    latest = changes.sort_values(["ECGI", "FEATURE", "LOAD_DATE"]).groupby(["ECGI", "FEATURE"], as_index=False).tail(1)
    latest = latest[["ECGI", "FEATURE", "PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE", "LOAD_DATE"]].rename(
        columns={"PREVIOUS_SOURCE_VALUE": "LATEST_PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE": "LATEST_CURRENT_SOURCE_VALUE", "LOAD_DATE": "LATEST_SOURCE_CHANGE_DATE"}
    )
    stats = stats.merge(latest, on=["ECGI", "FEATURE"], how="left")

    bulk = changes.groupby(["FEATURE", "LOAD_DATE"], as_index=False).agg(CHANGED_ECGIS_FEATURE_DAY=("ECGI", "nunique"))
    if not bulk.empty:
        denom = max(1, int(total_candidate_ecgis))
        bulk["CANDIDATE_BULK_CHANGE_RATIO"] = bulk["CHANGED_ECGIS_FEATURE_DAY"] / denom
        merge_bulk = changes[["ECGI", "FEATURE", "LOAD_DATE"]].merge(bulk, on=["FEATURE", "LOAD_DATE"], how="left")
        bulk_per_feature = merge_bulk.groupby(["ECGI", "FEATURE"], as_index=False).agg(
            MAX_CANDIDATE_BULK_CHANGE_RATIO=("CANDIDATE_BULK_CHANGE_RATIO", "max"),
            MAX_CHANGED_ECGIS_FEATURE_DAY=("CHANGED_ECGIS_FEATURE_DAY", "max"),
        )
        stats = stats.merge(bulk_per_feature, on=["ECGI", "FEATURE"], how="left")

    same_date_feature_count = changes.groupby(["ECGI", "LOAD_DATE"], as_index=False).agg(MULTI_FIELD_SAME_DAY_CHANGE_COUNT=("FEATURE", "nunique"))
    latest_date = latest[["ECGI", "FEATURE", "LATEST_SOURCE_CHANGE_DATE"]].rename(columns={"LATEST_SOURCE_CHANGE_DATE": "LOAD_DATE"})
    coordinated = latest_date.merge(same_date_feature_count, on=["ECGI", "LOAD_DATE"], how="left")
    stats = stats.merge(coordinated[["ECGI", "FEATURE", "MULTI_FIELD_SAME_DAY_CHANGE_COUNT"]], on=["ECGI", "FEATURE"], how="left")

    stats["LATEST_DAY_SOURCE_CHANGE_FLAG"] = (pd.to_datetime(stats["SOURCE_LAST_CHANGE_DATE"], errors="coerce").dt.normalize() == candidate_date).astype(int)
    stats["SOURCE_LATEST_CHANGE"] = stats.apply(lambda r: transition_text(r.get("LATEST_PREVIOUS_SOURCE_VALUE", ""), r.get("LATEST_CURRENT_SOURCE_VALUE", "")), axis=1)
    return stats


def build_conflict_stats(conflicts: pd.DataFrame) -> pd.DataFrame:
    if conflicts.empty:
        return pd.DataFrame(columns=["ECGI", "FEATURE"])
    return conflicts.groupby(["ECGI", "FEATURE"], dropna=False).agg(
        SOURCE_SAME_DAY_CONFLICT_ROWS=("LOAD_DATE", "size"),
        SOURCE_SAME_DAY_CONFLICT_DAYS=("LOAD_DATE", "nunique"),
        SOURCE_FIRST_CONFLICT_DATE=("LOAD_DATE", "min"),
        SOURCE_LAST_CONFLICT_DATE=("LOAD_DATE", "max"),
        MAX_SAME_DAY_UNIQUE_SOURCE_VALUES=("SOURCE_VALUES_UNIQUE_COUNT", "max"),
    ).reset_index()


def label_confidence_and_weight(label: str) -> Tuple[float, float]:
    x = str(label)
    mapping = {
        "AUDIT_PUSH_NOT_APPLIED": (0.90, 1.00),
        "INVALID_LATEST_SOURCE_VALUE": (0.95, 1.00),
        "FALLBACK_TO_DEFAULT_VALUE": (0.80, 0.80),
        "FLUCTUATING_FALLBACK_TO_DEFAULT": (0.88, 0.88),
        "LONG_TERM_FALLBACK_TO_DEFAULT": (0.94, 1.00),
        "REAL_BACK_AND_FORTH_INSTABILITY": (0.88, 0.90),
        "HIGH_FREQUENCY_DIFFERENT_VALUES": (0.86, 0.88),
        "SAME_DAY_SOURCE_CONFLICT": (0.92, 0.95),
        "PERSISTENT_SOURCE_INSTABILITY": (0.68, 0.65),
        "LATEST_DAY_SOURCE_CHANGE": (0.55, 0.50),
        "SUPPRESSED_NORMAL_STABLE_SOURCE_CHANGE": (0.90, 0.75),
        "SUPPRESSED_BULK_OR_REFRESH_PATTERN": (0.86, 0.70),
        "SUPPRESSED_COORDINATED_MULTI_FIELD_CHANGE": (0.78, 0.65),
        "DB_PUSH_CHECK_CANDIDATE_STABLE_SOURCE": (0.35, 0.00),
        "LOW_INFORMATION_STABLE_SOURCE_HISTORY": (0.45, 0.00),
        "LOW_PRIORITY_SOURCE_HISTORY_SIGNAL": (0.45, 0.25),
    }
    return mapping.get(x, (0.50, 0.30))


def add_seed_labels(feature_metrics: pd.DataFrame, rules: Dict[str, Dict[str, Any]], analysis_info: Dict[str, Any], args: argparse.Namespace) -> pd.DataFrame:
    if feature_metrics.empty:
        return feature_metrics
    fm = feature_metrics.copy()
    numeric_defaults = {
        "OBSERVED_DAYS_FOR_FEATURE": 0,
        "DISTINCT_SOURCE_VALUES_30D": 0,
        "MODE_SOURCE_VALUE_DAYS": 0,
        "MODE_SOURCE_VALUE_SHARE_PERCENT": 0,
        "LATEST_SOURCE_VALUE_DAYS": 0,
        "RAW_ROWS_FOR_FEATURE": 0,
        "DB_CHECK_AVAILABLE_FLAG": 0,
        "DISTINCT_DB_VALUES_30D": 0,
        "LATEST_DB_VALUE_DAYS": 0,
        "DB_VALUE_PRESENT_DAYS": 0,
        "SOURCE_DB_MISMATCH_DAYS": 0,
        "LATEST_SOURCE_DB_MISMATCH_FLAG": 0,
        "SOURCE_CHANGE_COUNT": 0,
        "SOURCE_CHANGE_DAYS_COUNT": 0,
        "SOURCE_A_B_A_REVERT_COUNT": 0,
        "SOURCE_REVERSE_TRANSITION_COUNT": 0,
        "RAW_ROWS_SUPPORTING_SOURCE_CHANGES": 0,
        "DISTINCT_PREVIOUS_SOURCE_VALUES_COUNT": 0,
        "DISTINCT_CURRENT_SOURCE_VALUES_COUNT": 0,
        "UNIQUE_TRANSITION_EDGE_COUNT": 0,
        "MAX_REPEATED_TRANSITION_EDGE_COUNT": 0,
        "SOURCE_SAME_DAY_CONFLICT_ROWS": 0,
        "SOURCE_SAME_DAY_CONFLICT_DAYS": 0,
        "MAX_SAME_DAY_UNIQUE_SOURCE_VALUES": 0,
        "LATEST_DAY_SOURCE_CHANGE_FLAG": 0,
        "MAX_CANDIDATE_BULK_CHANGE_RATIO": 0,
        "MAX_CHANGED_ECGIS_FEATURE_DAY": 0,
        "MULTI_FIELD_SAME_DAY_CHANGE_COUNT": 0,
    }
    for c, default in numeric_defaults.items():
        if c not in fm.columns:
            fm[c] = default
        fm[c] = safe_numeric(fm[c], default)

    date_cols = [
        "FIRST_OBSERVED_DATE", "LAST_OBSERVED_DATE", "SOURCE_FIRST_CHANGE_DATE", "SOURCE_LAST_CHANGE_DATE",
        "LATEST_SOURCE_CHANGE_DATE", "SOURCE_FIRST_CONFLICT_DATE", "SOURCE_LAST_CONFLICT_DATE",
        "LATEST_SOURCE_VALUE_FIRST_SEEN_DATE", "LATEST_SOURCE_VALUE_LAST_SEEN_DATE",
    ]
    # Important: if there were no source-change events in the candidate population,
    # build_change_stats() returns no SOURCE_* date columns. Those rows are still valid
    # stable-source / DB-push-check candidates, so create missing date columns as NaT
    # instead of failing with KeyError.
    for c in date_cols:
        if c not in fm.columns:
            fm[c] = pd.NaT
        fm[c] = pd.to_datetime(fm[c], errors="coerce").dt.normalize()

    # Text/event columns that only exist when source-change rows exist.
    if "SOURCE_LATEST_CHANGE" not in fm.columns:
        fm["SOURCE_LATEST_CHANGE"] = ""
    if "LATEST_PREVIOUS_SOURCE_VALUE" not in fm.columns:
        fm["LATEST_PREVIOUS_SOURCE_VALUE"] = ""
    if "LATEST_CURRENT_SOURCE_VALUE" not in fm.columns:
        fm["LATEST_CURRENT_SOURCE_VALUE"] = ""

    candidate_date = pd.to_datetime(analysis_info["candidate_date"]).normalize()
    requested_days = max(1, int(analysis_info.get("requested_days", 30)))

    fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("LATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("PREVIOUS_NONLATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["FIRST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("FIRST_SOURCE_VALUE", ""), rules), axis=1)
    fm["LATEST_DB_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("LATEST_DB_VALUE", ""), rules), axis=1)
    fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] = fm.apply(lambda r: value_is_invalid(r["FEATURE"], r.get("LATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["FEATURE_CRITICALITY_WEIGHT"] = fm["FEATURE"].map(lambda f: get_feature_weight(f, rules))

    fm["SOURCE_CHANGED_DAYS_PERCENT"] = 100.0 * fm["SOURCE_CHANGE_DAYS_COUNT"] / requested_days
    fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] = (candidate_date - pd.to_datetime(fm["SOURCE_LAST_CHANGE_DATE"], errors="coerce").dt.normalize()).dt.days
    fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] = fm["DAYS_SINCE_LAST_SOURCE_CHANGE"].fillna(9999).clip(lower=0)

    fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] = (fm["SOURCE_SAME_DAY_CONFLICT_DAYS"] > 0).astype(int)
    fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"] = (fm["SOURCE_CHANGE_DAYS_COUNT"] >= int(args.persistent_days)).astype(int)

    fm["REAL_BACK_AND_FORTH_FLAG"] = (
        (fm["SOURCE_A_B_A_REVERT_COUNT"] >= int(args.min_aba_for_backforth))
        | (fm["SOURCE_REVERSE_TRANSITION_COUNT"] >= int(args.min_reverses_for_backforth))
        | ((fm["SOURCE_CHANGE_COUNT"] >= 4) & (fm["DISTINCT_SOURCE_VALUES_30D"] <= 3) & (fm["SOURCE_CHANGE_DAYS_COUNT"] >= 3))
    ).astype(int)

    fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] = (
        (fm["SOURCE_CHANGE_DAYS_COUNT"] >= int(args.high_frequency_days))
        & (fm["DISTINCT_SOURCE_VALUES_30D"] >= int(args.high_frequency_distinct_values))
        & (fm["MODE_SOURCE_VALUE_SHARE_PERCENT"] < float(args.high_frequency_max_mode_share))
    ).astype(int)

    # Latest default fallback: current/latest value is a known default after a prior non-default value.
    fm["LATEST_FALLBACK_TO_DEFAULT_VALUE_FLAG"] = (
        (fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] == 1)
        & (fm["PREVIOUS_NONLATEST_SOURCE_VALUE"].fillna("").astype(str) != "")
        & (fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] == 0)
        & (fm["LATEST_SOURCE_VALUE_DAYS"] >= int(args.default_min_days))
    ).astype(int)

    # Historical/fluctuating fallback: value fell to default during the window but later recovered to non-default.
    # This catches the feedback case where fallback happened for a few days and returned before the latest date.
    fm["HISTORICAL_DEFAULT_FALLBACK_EPISODE_FLAG"] = (
        (fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] == 0)
        & (fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] == 1)
        & (fm["SOURCE_CHANGE_COUNT"] >= 2)
    ).astype(int)

    fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] = (
        (fm["LATEST_FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1)
        | (fm["HISTORICAL_DEFAULT_FALLBACK_EPISODE_FLAG"] == 1)
    ).astype(int)

    fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] = 0
    if args.enable_db_push_check:
        fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] = (
            (fm["DB_CHECK_AVAILABLE_FLAG"] == 1)
            & (fm["LATEST_SOURCE_DB_MISMATCH_FLAG"] == 1)
            & (fm["LATEST_SOURCE_VALUE_DAYS"] >= int(args.push_source_stable_days))
            & (fm["SOURCE_DB_MISMATCH_DAYS"] >= int(args.push_mismatch_days))
            & (
                (fm["LATEST_DB_IS_DEFAULT_FLAG"] == 1)
                | (
                    fm["PREVIOUS_NONLATEST_SOURCE_VALUE"].fillna("").astype(str).ne("")
                    & fm["LATEST_DB_VALUE"].fillna("").astype(str).eq(fm["PREVIOUS_NONLATEST_SOURCE_VALUE"].fillna("").astype(str))
                )
                | (fm["DISTINCT_DB_VALUES_30D"] <= 1)
            )
        ).astype(int)

    fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] = (
        (fm["MAX_CANDIDATE_BULK_CHANGE_RATIO"] >= float(args.bulk_change_ratio_threshold))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["REAL_BACK_AND_FORTH_FLAG"] == 0)
        & (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)

    fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] = (
        (fm["SOURCE_CHANGE_COUNT"] == 1)
        & (fm["DISTINCT_SOURCE_VALUES_30D"] <= 2)
        & (fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] >= int(args.stable_change_suppress_days))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)

    fm["COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG"] = (
        (fm["MULTI_FIELD_SAME_DAY_CHANGE_COUNT"] >= int(args.coordinated_feature_threshold))
        & (fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] >= int(args.stable_change_suppress_days))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["REAL_BACK_AND_FORTH_FLAG"] == 0)
        & (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)

    fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] = (
        (fm["SOURCE_CHANGE_COUNT"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)

    fm["DB_PUSH_CHECK_CANDIDATE_FLAG"] = (
        (fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] == 1)
        | ((fm["SOURCE_CHANGE_COUNT"] <= 1) & (fm["LATEST_SOURCE_VALUE_DAYS"] >= int(args.push_source_stable_days)))
    ).astype(int)

    fm["HAS_PROBLEM_SEED_FLAG"] = (
        (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 1)
        | (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1)
        | (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 1)
        | (fm["REAL_BACK_AND_FORTH_FLAG"] == 1)
        | (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 1)
        | (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 1)
        | (fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"] == 1)
        | (fm["LATEST_DAY_SOURCE_CHANGE_FLAG"] == 1)
    ).astype(int)

    score = pd.Series(np.zeros(len(fm)), index=fm.index, dtype=float)
    score += 45.0 * fm["AUDIT_PUSH_NOT_APPLIED_FLAG"]
    score += 35.0 * fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"]
    score += 32.0 * fm["LATEST_SOURCE_INVALID_RANGE_FLAG"]
    score += 30.0 * fm["REAL_BACK_AND_FORTH_FLAG"]
    score += 30.0 * fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"]
    score += 22.0 * fm["SOURCE_SAME_DAY_CONFLICT_FLAG"]
    score += 12.0 * fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"]
    score += 6.0 * fm["LATEST_DAY_SOURCE_CHANGE_FLAG"]
    score += np.minimum(14.0, 1.4 * fm["SOURCE_CHANGE_DAYS_COUNT"])
    score += np.minimum(10.0, 0.7 * fm["SOURCE_CHANGE_COUNT"])
    score += np.minimum(8.0, 2.0 * np.maximum(fm["DISTINCT_SOURCE_VALUES_30D"] - 1, 0))
    score += np.where(fm["HAS_PROBLEM_SEED_FLAG"] == 1, fm["FEATURE_CRITICALITY_WEIGHT"], 0.2 * fm["FEATURE_CRITICALITY_WEIGHT"])
    score += np.minimum(5.0, np.log1p(fm["RAW_ROWS_FOR_FEATURE"].clip(lower=0)))
    no_problem = fm["HAS_PROBLEM_SEED_FLAG"] == 0
    score -= np.where(no_problem & (fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] == 1), 25.0, 0.0)
    score -= np.where(no_problem & (fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] == 1), 25.0, 0.0)
    score -= np.where(no_problem & (fm["COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG"] == 1), 18.0, 0.0)
    score -= np.where(no_problem & (fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] == 1), 15.0, 0.0)
    fm["SEED_RULE_SCORE"] = score.clip(lower=0)
    fm["SEED_RULE_PERCENTILE"] = percentile_rank(fm["SEED_RULE_SCORE"])

    def seed_label(r: pd.Series) -> str:
        if int(r.get("AUDIT_PUSH_NOT_APPLIED_FLAG", 0)) == 1:
            return "AUDIT_PUSH_NOT_APPLIED"
        if int(r.get("LATEST_SOURCE_INVALID_RANGE_FLAG", 0)) == 1:
            return "INVALID_LATEST_SOURCE_VALUE"
        if int(r.get("FALLBACK_TO_DEFAULT_VALUE_FLAG", 0)) == 1:
            return "FALLBACK_TO_DEFAULT_VALUE"
        if int(r.get("REAL_BACK_AND_FORTH_FLAG", 0)) == 1:
            return "REAL_BACK_AND_FORTH_INSTABILITY"
        if int(r.get("HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", 0)) == 1:
            return "HIGH_FREQUENCY_DIFFERENT_VALUES"
        if int(r.get("SOURCE_SAME_DAY_CONFLICT_FLAG", 0)) == 1:
            return "SAME_DAY_SOURCE_CONFLICT"
        if int(r.get("PERSISTENT_SOURCE_INSTABILITY_FLAG", 0)) == 1:
            return "PERSISTENT_SOURCE_INSTABILITY"
        if int(r.get("LATEST_DAY_SOURCE_CHANGE_FLAG", 0)) == 1:
            return "LATEST_DAY_SOURCE_CHANGE"
        if int(r.get("NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG", 0)) == 1:
            return "SUPPRESSED_NORMAL_STABLE_SOURCE_CHANGE"
        if int(r.get("BULK_OR_REFRESH_SUPPRESSOR_FLAG", 0)) == 1:
            return "SUPPRESSED_BULK_OR_REFRESH_PATTERN"
        if int(r.get("COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG", 0)) == 1:
            return "SUPPRESSED_COORDINATED_MULTI_FIELD_CHANGE"
        if int(r.get("DB_PUSH_CHECK_CANDIDATE_FLAG", 0)) == 1:
            return "DB_PUSH_CHECK_CANDIDATE_STABLE_SOURCE"
        if int(r.get("LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG", 0)) == 1:
            return "LOW_INFORMATION_STABLE_SOURCE_HISTORY"
        return "LOW_PRIORITY_SOURCE_HISTORY_SIGNAL"

    fm["SEED_LABEL"] = fm.apply(seed_label, axis=1)
    conf_weight = fm["SEED_LABEL"].map(label_confidence_and_weight)
    fm["SEED_LABEL_CONFIDENCE"] = [cw[0] for cw in conf_weight]
    fm["TRAINING_WEIGHT"] = [cw[1] for cw in conf_weight]
    fm["IS_REPORTABLE_PROBLEM"] = fm["SEED_LABEL"].isin(PROBLEM_LABELS).astype(int)
    fm["IS_SUPPRESSED_NORMAL"] = fm["SEED_LABEL"].isin(SUPPRESSOR_LABELS).astype(int)
    fm["NEEDS_MANUAL_REVIEW"] = fm["SEED_LABEL"].isin(HOLD_LABELS).astype(int)
    fm["TRAIN_FOR_MODEL_FLAG"] = (
        (fm["SEED_LABEL_CONFIDENCE"] >= float(args.min_seed_confidence_for_training))
        & (fm["TRAINING_WEIGHT"] > 0)
        & (~fm["SEED_LABEL"].isin(HOLD_LABELS))
    ).astype(int)
    fm["FINAL_TRAINING_LABEL"] = fm["SEED_LABEL"]
    fm["MANUAL_LABEL"] = ""
    fm["MANUAL_LABEL_NOTES"] = ""

    def severity_band(x: float) -> str:
        if x >= 85:
            return "CRITICAL"
        if x >= 65:
            return "HIGH"
        if x >= 40:
            return "MEDIUM"
        if x >= 20:
            return "LOW"
        return "SUPPRESSED_OR_INFORMATIONAL"

    fm["SEVERITY_BAND"] = fm["SEED_RULE_SCORE"].map(severity_band)
    fm["SUPPRESSION_REASON"] = ""
    fm.loc[fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] == 1, "SUPPRESSION_REASON"] = "NORMAL_STABLE_SOURCE_CHANGE"
    fm.loc[fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] == 1, "SUPPRESSION_REASON"] = "BULK_OR_REFRESH_PATTERN_AMONG_CANDIDATES"
    fm.loc[fm["COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG"] == 1, "SUPPRESSION_REASON"] = "COORDINATED_MULTI_FIELD_CHANGE"
    fm.loc[fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] == 1, "SUPPRESSION_REASON"] = "STABLE_SOURCE_HISTORY_AFTER_DB_MISMATCH_GATE"
    fm.loc[fm["IS_REPORTABLE_PROBLEM"] == 1, "SUPPRESSION_REASON"] = ""

    fm["SOURCE_FEATURE_EVIDENCE_SUMMARY"] = fm.apply(
        lambda r: (
            f"{r['FEATURE']} latest source={short_value(r.get('LATEST_SOURCE_VALUE',''))}; "
            f"source changed on {int(r.get('SOURCE_CHANGE_DAYS_COUNT',0))}/{requested_days} days; "
            f"distinct source values={int(r.get('DISTINCT_SOURCE_VALUES_30D',0))}; "
            f"seed_label={r['SEED_LABEL']}; confidence={float(r['SEED_LABEL_CONFIDENCE']):.2f}; "
            f"score={float(r['SEED_RULE_SCORE']):.1f}."
        ),
        axis=1,
    )
    fm["RECOMMENDED_ACTION"] = fm["SEED_LABEL"].map(recommended_action).fillna("Manual review recommended.")
    return fm.sort_values(["IS_REPORTABLE_PROBLEM", "SEED_RULE_SCORE"], ascending=[False, False]).reset_index(drop=True)


def recommended_action(label: str) -> str:
    p = str(label or "").upper()
    if p == "AUDIT_PUSH_NOT_APPLIED":
        return "Check server/DB application path: source is stable but latest source and DB values remain different."
    if p == "FLUCTUATING_FALLBACK_TO_DEFAULT":
        return "Review fluctuating/short-term default fallback; compare latest CESMLC value with RAN source-of-truth and confirm whether it is intermittent or already recovered."
    if p == "LONG_TERM_FALLBACK_TO_DEFAULT":
        return "Review long-remained default fallback; if many fields are default for the ECGI, validate possible site swap, rebuild, location/technology change, or missing source-data feed."
    if p == "FALLBACK_TO_DEFAULT_VALUE":
        return "Investigate why latest source fell back to a known default; validate upstream feed/defaulting logic."
    if p == "INVALID_LATEST_SOURCE_VALUE":
        return "Validate latest source value against RAN parameter requirements; correct out-of-range value if confirmed."
    if p == "REAL_BACK_AND_FORTH_INSTABILITY":
        return "Investigate repeated reversion/toggling in the source system; check competing loads or automation overwrites."
    if p == "HIGH_FREQUENCY_DIFFERENT_VALUES":
        return "Investigate high-frequency multi-value changes; check unstable source feed, repeated imports, or conflicting updates."
    if p == "SAME_DAY_SOURCE_CONFLICT":
        return "Investigate multiple same-day source values for the same ECGI/feature; check duplicate feed rows or inconsistent joins."
    if p == "PERSISTENT_SOURCE_INSTABILITY":
        return "Review persistent source instability and determine whether it is planned network activity or unresolved data quality issue."
    if p == "LATEST_DAY_SOURCE_CHANGE":
        return "Review latest-day source change in context of current DB_MISMATCH candidate."
    if p == "DB_PUSH_CHECK_CANDIDATE_STABLE_SOURCE":
        return "Source history is stable; if current DB_MISMATCH matters, run narrow source-vs-DB push check or manual review."
    if p.startswith("SUPPRESSED"):
        return "Suppressed as likely normal/stable/bulk/coordinated behavior; keep for audit trace but do not prioritize."
    return "Manual review recommended."



