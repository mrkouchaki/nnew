SELECT
    ecgi_cell_global_identity,
    rbss_latitude,
    rbss_longitude,
    COUNT(*) AS row_count
FROM E911.CSSNG_DATA_DEEP_STAGING
WHERE ecgi_cell_global_identity = '310410253519882'
GROUP BY
    ecgi_cell_global_identity,
    rbss_latitude,
    rbss_longitude
ORDER BY row_count DESC;




SELECT
    owner,
    name,
    type,
    COUNT(*) AS hits,
    MIN(line) AS first_line,
    MAX(line) AS last_line
FROM all_source
WHERE owner = 'E911'
  AND UPPER(text) LIKE '%CSSNG_DATA_DEEP_STAGING%'
GROUP BY owner, name, type
ORDER BY hits DESC;



